---
import { propertySales } from '../data/propertySales';

export interface Props {
  zh?: boolean;
}
const { zh = false } = Astro.props;

const labels = zh
  ? {
      housesTab: '独立屋',
      condosTab: '公寓',
      rentalTab: '租赁',
      viewDetails: '查看详情 →',
      bedroom: '卧室',
      bathroom: '浴室',
      parking: '车位',
      emptyState: '该分类下暂无成交记录。',
    }
  : {
      housesTab: 'House',
      condosTab: 'Condo',
      rentalTab: 'Rental',
      viewDetails: 'View details →',
      bedroom: 'Bedroom',
      bathroom: 'Bathroom',
      parking: 'Parking',
      emptyState: 'No listings in this category yet.',
    };
---
<section class="property-sales">
  <div class="wrap">
    <div class="sales-filter" role="tablist" aria-label="Filter by property type">
      <button type="button" class="sales-filter-tab is-active" data-filter="House" role="tab" aria-selected="true">{labels.housesTab}</button>
      <button type="button" class="sales-filter-tab" data-filter="Condo" role="tab" aria-selected="false">{labels.condosTab}</button>
      <button type="button" class="sales-filter-tab" data-filter="Rental" role="tab" aria-selected="false">{labels.rentalTab}</button>
    </div>
    <div class="sales-grid" data-empty-text={labels.emptyState}>
      {propertySales.map((p) => (
        <article class="sale-card" data-category={p.category}>
          <div class="sale-card-photo">
            <img src={p.photo} alt={`${zh ? p.propertyName_zh : p.propertyName_en}, ${zh ? p.address_zh : p.address_en}`} loading="lazy" />
          </div>
          <div class="sale-card-info">
            <div class="sale-status-group">
              <div class="sale-status">{zh ? p.status_zh : p.status_en}</div>
              {(zh ? p.representation_zh : p.representation_en) && (
                <div class="sale-rep">{zh ? p.representation_zh : p.representation_en}</div>
              )}
              {(zh ? p.representationNote_zh : p.representationNote_en) && (
                <div class="sale-rep-note">{zh ? p.representationNote_zh : p.representationNote_en}</div>
              )}
            </div>
            <div class="sale-price">{p.price}</div>
            <div class="sale-name">{zh ? p.propertyName_en : p.propertyName_en}</div>
            <div class="sale-address">{zh ? p.address_zh : p.address_en}</div>
            <div class="sale-features">
              <span>{p.bedrooms} {labels.bedroom}</span><span class="dot"> · </span><span>{p.bathrooms} {labels.bathroom}</span>{typeof p.parking === 'number' && p.parking > 0 && (<><span class="dot"> · </span><span>{p.parking} {labels.parking}</span></>)}{(zh ? p.houseStyle_zh : p.houseStyle_en) && (<><span>, </span><span>{zh ? p.houseStyle_zh : p.houseStyle_en}</span></>)}
            </div>
            <details class="sale-details">
              <summary class="sale-details-summary">{labels.viewDetails}</summary>
              <div class="sale-details-body">
                {(zh ? p.details_zh : p.details_en)
                  ? <p>{zh ? p.details_zh : p.details_en}</p>
                  : <p class="sale-details-empty">{zh ? '更多详情即将更新。' : 'More details coming soon.'}</p>}
              </div>
            </details>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function init() {
      document.querySelectorAll('.property-sales').forEach(function (section) {
        var tabs = section.querySelectorAll('.sales-filter-tab');
        var cards = section.querySelectorAll('.sale-card');
        var grid = section.querySelector('.sales-grid');
        function applyFilter(filter) {
          var visible = 0;
          cards.forEach(function (card) {
            var matches = card.getAttribute('data-category') === filter;
            card.style.display = matches ? '' : 'none';
            if (matches) visible++;
          });
          var emptyMsg = grid.querySelector('.sales-empty');
          if (visible === 0) {
            if (!emptyMsg) {
              emptyMsg = document.createElement('div');
              emptyMsg.className = 'sales-empty';
              emptyMsg.textContent = grid.getAttribute('data-empty-text') || '';
              grid.appendChild(emptyMsg);
            }
          } else if (emptyMsg) {
            emptyMsg.remove();
          }
        }
        tabs.forEach(function (tab) {
          tab.addEventListener('click', function () {
            tabs.forEach(function (t) {
              t.classList.remove('is-active');
              t.setAttribute('aria-selected', 'false');
            });
            tab.classList.add('is-active');
            tab.setAttribute('aria-selected', 'true');
            applyFilter(tab.getAttribute('data-filter'));
          });
        });
        var activeTab = section.querySelector('.sales-filter-tab.is-active');
        if (activeTab) applyFilter(activeTab.getAttribute('data-filter'));
      });
    }
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  })();
</script>

<style>
  .property-sales { padding: 24px 0 64px; }

  .sales-filter {
    display: flex;
    gap: 32px;
    margin-bottom: 28px;
    border-bottom: 1px solid var(--rule);
  }
  .sales-filter-tab {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 12px 0;
    font-family: inherit;
    font-size: 14px;
    color: var(--ink-mute);
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: color 0.15s, border-color 0.15s;
    margin-bottom: -1px;
  }
  .sales-filter-tab:hover { color: var(--ink-soft); }
  .sales-filter-tab.is-active {
    color: var(--ink);
    border-bottom-color: var(--ink);
    font-weight: 600;
  }

  .sales-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .sale-card {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 28px;
    padding: 22px;
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: 6px;
    align-items: center;
  }

  .sale-card-photo {
    aspect-ratio: 4 / 3;
    border-radius: 4px;
    overflow: hidden;
    background: var(--bg-warm);
  }
  .sale-card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sale-card-info { display: flex; flex-direction: column; position: relative; padding-right: 130px; }

  .sale-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 0;
  }
  .sale-price {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 28px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.1;
  }
  .sale-status-group {
    position: absolute;
    top: 0;
    right: 0;
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  .sale-status {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-mute);
    font-weight: 600;
  }
  .sale-rep {
    font-size: 12px;
    color: var(--ink-soft);
    letter-spacing: 0.01em;
    font-style: italic;
  }
  .sale-rep-note {
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.01em;
    margin-top: 2px;
  }

  .sale-name {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 20px;
    color: var(--ink);
    margin-top: 2px;
  }
  .sale-address {
    font-size: 13px;
    color: var(--ink-mute);
    margin-top: 2px;
  }
  .sale-features {
    font-size: 14px;
    color: var(--ink-soft);
    margin-top: 10px;
  }
  .sale-features .dot { color: var(--ink-mute); margin: 0 2px; }
  .sale-details {
    margin-top: 12px;
    align-self: stretch;
  }
  .sale-details-summary {
    cursor: pointer;
    list-style: none;
    font-size: 14px;
    color: var(--ink);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
    display: inline-block;
    transition: color 0.15s;
  }
  .sale-details-summary::-webkit-details-marker { display: none; }
  .sale-details-summary::marker { content: ''; }
  .sale-details-summary:hover { color: var(--ink-soft); }
  .sale-details[open] .sale-details-summary { color: var(--ink-soft); }
  .sale-details-body {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .sale-details-body p { margin: 0; }
  .sale-details-empty {
    color: var(--ink-mute);
    font-style: italic;
  }

  .sales-empty {
    text-align: center;
    padding: 56px 24px;
    color: var(--ink-mute);
    font-size: 15px;
    border: 1px dashed var(--rule);
    border-radius: 6px;
  }

  @media (max-width: 640px) {
    .sale-card-info { padding-right: 0; }
    .sale-status-group { position: static; align-items: flex-start; text-align: left; margin-bottom: 8px; }
    .sale-card { grid-template-columns: 1fr; padding: 18px; gap: 20px; }
    .sale-card-photo { aspect-ratio: 4 / 3; max-height: 240px; }
    .sale-price { font-size: 24px; }
    .sale-name { font-size: 18px; }
  }
</style>
