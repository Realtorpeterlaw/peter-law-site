---
import Logo from './Logo.astro';
interface Props {
  active?: 'rental' | 'sellers' | 'buyers' | 'about' | 'contact' | null;
  ctaLabel?: string;
}
const { active = null, ctaLabel = "预约咨询" } = Astro.props;
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<header>
  <div class="wrap head-inner">
    <a href="/zh" class="logo" aria-label="Peter Law — 首页"><Logo tagline="多伦多房地产" /><span class="logo-home-hint">(首页)</span></a>
    <nav class="primary" aria-label="主导航">
      <ul>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'rental' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">租赁</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/zh/for-renters">租客须知</a></li>
            <li><a href="/zh/for-landlords">房东须知</a></li>
            <li><a href="/zh/rental-tour">看房视频</a></li>
            <li><a href="/zh/rent-control">租金管制</a></li>
            <li><a href="/zh/lease-renewal">租约续签</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'sellers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">卖家</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/zh/free-home-evaluation">免费房屋估值</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'buyers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">买家</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/zh/buyer-guide">买家指南</a></li>
            <li><a href="/zh/land-transfer-tax">土地转让税</a></li>
            <li><a href="/zh/payment-calculator">按揭计算器</a></li>
            <li><a href="/zh/affordability-calculator">可负担能力计算器</a></li>
            <li><a href="/zh/closing-costs">交房费用</a></li>
          </ul>
        </li>
        <li class="nav-separator" aria-hidden="true"></li>
        <li><a href="/zh/about" class={active === 'about' ? 'active' : ''}>关于</a></li>
        <li><a href="/zh/contact" class={active === 'contact' ? 'active' : ''}>联系</a></li>
      </ul>
    </nav>
    <a href={BOOKING_URL} class="head-cta">{ctaLabel}</a>
  </div>
</header>
