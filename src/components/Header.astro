---
import Logo from './Logo.astro';
interface Props {
  active?: 'rental' | 'sellers' | 'buyers' | 'about' | 'contact' | null;
  ctaLabel?: string;
}
const { active = null, ctaLabel = "Book a viewing call" } = Astro.props;
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<header>
  <div class="wrap head-inner">
    <a href="/" class="logo" aria-label="Peter Law — home"><Logo /><span class="logo-home-hint">(Homepage)</span></a>
    <nav class="primary" aria-label="Primary">
      <ul>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'rental' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Rental</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/for-renters">For RENTERS</a></li>
            <li><a href="/for-landlords">For LANDLORDS</a></li>
            <li><a href="/rental-tour">Rental Tour</a></li>
            <li><a href="/rent-control">Rent Control</a></li>
            <li><a href="/lease-renewal">Lease Renewal</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'sellers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Sellers</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/free-home-evaluation">Free Home Evaluation</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'buyers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Buyers</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/buyer-guide">Buyer Guide</a></li>
            <li><a href="/land-transfer-tax">Land Transfer Tax</a></li>
            <li><a href="/payment-calculator">Mortgage Calculator</a></li>
            <li><a href="/affordability-calculator">Affordability Calculator</a></li>
            <li><a href="/closing-costs">Closing Costs</a></li>
          </ul>
        </li>
        <li class="nav-separator" aria-hidden="true"></li>
        <li><a href="/about" class={active === 'about' ? 'active' : ''}>About</a></li>
        <li><a href="/contact" class={active === 'contact' ? 'active' : ''}>Contact</a></li>
      </ul>
    </nav>
    <a href={BOOKING_URL} class="head-cta">{ctaLabel}</a>
  </div>
</header>
