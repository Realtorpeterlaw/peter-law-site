---
import Logo from './Logo.astro';
interface Props { active?: string | null; ctaLabel?: string; }
const { active = null, ctaLabel = "Записаться на звонок" } = Astro.props;
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<header>
  <div class="wrap head-inner">
    <a href="/russian" class="logo" aria-label="Peter Law — Главная"><Logo tagline="НЕДВИЖИМОСТЬ ТОРОНТО" /><span class="logo-home-hint">(Главная)</span></a>
    <nav class="primary" aria-label="Главная навигация">
      <ul>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'rental' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Аренда</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/russian/for-renters">Для арендаторов</a></li>
            <li><a href="/russian/for-landlords">Для арендодателей</a></li>
            <li><a href="/russian/rental-calculator">Калькулятор аренды</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'sellers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Продавцы</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/russian/free-home-evaluation">Бесплатная оценка</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'buyers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Покупатели</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/russian/buyer-guide">Гид покупателя</a></li>
            <li><a href="/russian/land-transfer-tax">Налог на передачу</a></li>
            <li><a href="/russian/closing-costs">Расходы на закрытие</a></li>
            <li><a href="/russian/all-calculator">Калькулятор ПОКУПКИ</a></li>
          </ul>
        </li>
        <li class="nav-separator" aria-hidden="true"></li>
        <li class="has-dropdown">
          <a href="/russian/about" class={'dropdown-trigger' + (active === 'about' ? ' active' : '')} aria-haspopup="true">
            <span class="trigger-text">Обо мне</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <ul class="dropdown-menu">
            <li><a href="/russian/about">О Peter</a></li>
            <li><a href="/russian/past-deals">История продаж</a></li>
          </ul>
        </li>
        <li><a href="/russian/contact" class={active === 'contact' ? 'active' : ''}>Контакты</a></li>
      </ul>
    </nav>
    <a href={BOOKING_URL} class="head-cta head-cta-desktop">{ctaLabel}</a>
    <a href="https://wa.me/16478888472" class="head-cta-call" aria-label="Позвонить в WhatsApp">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 15.5c-1.2 0-2.4-.2-3.5-.6-.3-.1-.7 0-1 .3l-2 2c-2.7-1.4-4.9-3.6-6.3-6.3l2-2c.3-.3.4-.7.3-1-.4-1.1-.6-2.3-.6-3.5 0-.5-.5-1-1-1H4c-.5 0-1 .5-1 1 0 9.4 7.6 17 17 17 .5 0 1-.5 1-1v-3.9c0-.5-.5-1-1-1z" fill="currentColor"/></svg>
      Звонок
    </a>
  </div>
</header>
