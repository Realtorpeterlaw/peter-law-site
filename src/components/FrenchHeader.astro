---
import Logo from './Logo.astro';
interface Props {
  active?: 'rental' | 'sellers' | 'buyers' | 'about' | 'contact' | null;
  ctaLabel?: string;
}
const { active = null, ctaLabel = "Réserver un appel" } = Astro.props;
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<header>
  <div class="wrap head-inner">
    <a href="/french" class="logo" aria-label="Peter Law — Accueil"><Logo tagline="IMMOBILIER TORONTO" /><span class="logo-home-hint">(Accueil)</span></a>
    <nav class="primary" aria-label="Navigation principale">
      <ul>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'rental' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Location</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/french/for-renters">Pour LOCATAIRES</a></li>
            <li><a href="/french/for-landlords">Pour PROPRIÉTAIRES</a></li>
            <li><a href="/french/rental-calculator">Calculateur de location</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'sellers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Vendeurs</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/free-home-evaluation">Évaluation gratuite</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'buyers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Acheteurs</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/french/buyer-guide">Guide de l'acheteur</a></li>
            <li><a href="/french/land-transfer-tax">Droits de mutation</a></li>
            <li><a href="/french/closing-costs">Frais de clôture</a></li>
            <li><a href="/french/all-calculator">Calculateur ACHAT</a></li>
          </ul>
        </li>
        <li class="nav-separator" aria-hidden="true"></li>
        <li class="has-dropdown">
          <a href="/french/about" class={'dropdown-trigger' + (active === 'about' ? ' active' : '')} aria-haspopup="true">
            <span class="trigger-text">À propos</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <ul class="dropdown-menu">
            <li><a href="/french/about">À propos de moi</a></li>
            <li><a href="/past-deals">Historique des ventes</a></li>
          </ul>
        </li>
        <li><a href="/french/contact" class={active === 'contact' ? 'active' : ''}>Contact</a></li>
      </ul>
    </nav>
    <a href={BOOKING_URL} class="head-cta head-cta-desktop">{ctaLabel}</a>
    <a href="https://wa.me/16478888472" class="head-cta-call" aria-label="Appelez Peter sur WhatsApp: 647-888-8472">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 15.5c-1.2 0-2.4-.2-3.5-.6-.3-.1-.7 0-1 .3l-2 2c-2.7-1.4-4.9-3.6-6.3-6.3l2-2c.3-.3.4-.7.3-1-.4-1.1-.6-2.3-.6-3.5 0-.5-.5-1-1-1H4c-.5 0-1 .5-1 1 0 9.4 7.6 17 17 17 .5 0 1-.5 1-1v-3.9c0-.5-.5-1-1-1z" fill="currentColor"/></svg>
      Appelez
    </a>
  </div>
</header>
