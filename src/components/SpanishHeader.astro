---
import Logo from './Logo.astro';
interface Props { active?: string | null; ctaLabel?: string; }
const { active = null, ctaLabel = "Reservar una llamada" } = Astro.props;
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<header>
  <div class="wrap head-inner">
    <a href="/spanish" class="logo" aria-label="Peter Law — Inicio"><Logo tagline="INMOBILIARIA TORONTO" /><span class="logo-home-hint">(Inicio)</span></a>
    <nav class="primary" aria-label="Navegación principal">
      <ul>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'rental' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Alquiler</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/spanish/for-renters">Para INQUILINOS</a></li>
            <li><a href="/spanish/for-landlords">Para PROPIETARIOS</a></li>
            <li><a href="/spanish/rental-calculator">Calculadora de alquiler</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'sellers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Vendedores</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/spanish/free-home-evaluation">Tasación gratuita</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'buyers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">Compradores</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/spanish/buyer-guide">Guía del comprador</a></li>
            <li><a href="/spanish/land-transfer-tax">Impuesto de transferencia</a></li>
            <li><a href="/spanish/closing-costs">Costos de cierre</a></li>
            <li><a href="/spanish/all-calculator">Calculadora de COMPRA</a></li>
          </ul>
        </li>
        <li class="nav-separator" aria-hidden="true"></li>
        <li class="has-dropdown">
          <a href="/spanish/about" class={'dropdown-trigger' + (active === 'about' ? ' active' : '')} aria-haspopup="true">
            <span class="trigger-text">Acerca de</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <ul class="dropdown-menu">
            <li><a href="/spanish/about">Sobre Peter</a></li>
            <li><a href="/spanish/past-deals">Historial de ventas</a></li>
          </ul>
        </li>
        <li><a href="/spanish/contact" class={active === 'contact' ? 'active' : ''}>Contacto</a></li>
      </ul>
    </nav>
    <a href={BOOKING_URL} class="head-cta head-cta-desktop">{ctaLabel}</a>
    <a href="https://wa.me/16478888472" class="head-cta-call" aria-label="Llamar por WhatsApp">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 15.5c-1.2 0-2.4-.2-3.5-.6-.3-.1-.7 0-1 .3l-2 2c-2.7-1.4-4.9-3.6-6.3-6.3l2-2c.3-.3.4-.7.3-1-.4-1.1-.6-2.3-.6-3.5 0-.5-.5-1-1-1H4c-.5 0-1 .5-1 1 0 9.4 7.6 17 17 17 .5 0 1-.5 1-1v-3.9c0-.5-.5-1-1-1z" fill="currentColor"/></svg>
      Llamar
    </a>
  </div>
</header>
