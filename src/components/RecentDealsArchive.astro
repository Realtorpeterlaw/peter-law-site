---
import { getDeals } from '../data/recentDeals';

export interface Props {
  zh?: boolean;
}
const { zh = false } = Astro.props;

const deals = getDeals(zh);

---

<section id="recent-deals" class="major recent-deals-archive">
  <div class="wrap">
    <div class="deals-archive-grid">
      {deals.map((d) => (
        <article class="deals-archive-card">
          <div class="deal-month-year">{d.monthYear}</div>
          <div class="deal-rent">
            <span class="deal-rent-amount">{d.rent}</span>
            <span class="deal-rent-period">{d.period}</span>
          </div>
          <div class="deal-location">{d.intersection}</div>
          <div class="deal-city">{d.city}</div>
          <p class="deal-note">{d.note}</p>
        </article>
      ))}
    </div>
  </div>
</section>
