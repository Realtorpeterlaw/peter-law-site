---
import Logo from './Logo.astro';
interface Props { active?: string | null; ctaLabel?: string; }
const { active = null, ctaLabel = "상담 예약" } = Astro.props;
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<header>
  <div class="wrap head-inner">
    <a href="/korean" class="logo" aria-label="Peter Law — 홈"><Logo tagline="토론토 부동산" /><span class="logo-home-hint">(홈)</span></a>
    <nav class="primary" aria-label="주요 내비게이션">
      <ul>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'rental' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">임대</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/korean/for-renters">세입자 안내</a></li>
            <li><a href="/korean/for-landlords">임대인 안내</a></li>
            <li><a href="/rental-calculator">임대 계산기</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'sellers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">판매자</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/free-home-evaluation">무료 주택 평가</a></li>
          </ul>
        </li>
        <li class="has-dropdown">
          <span class={'dropdown-trigger' + (active === 'buyers' ? ' active' : '')} tabindex="0" aria-haspopup="true">
            <span class="trigger-text">구매자</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <ul class="dropdown-menu">
            <li><a href="/korean/buyer-guide">구매자 가이드</a></li>
            <li><a href="/land-transfer-tax">토지 양도세</a></li>
            <li><a href="/closing-costs">클로징 비용</a></li>
            <li><a href="/all-calculator">구매 계산기</a></li>
          </ul>
        </li>
        <li class="nav-separator" aria-hidden="true"></li>
        <li class="has-dropdown">
          <a href="/korean/about" class={'dropdown-trigger' + (active === 'about' ? ' active' : '')} aria-haspopup="true">
            <span class="trigger-text">소개</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <ul class="dropdown-menu">
            <li><a href="/korean/about">Peter 소개</a></li>
            <li><a href="/past-deals">판매 기록</a></li>
          </ul>
        </li>
        <li><a href="/korean/contact" class={active === 'contact' ? 'active' : ''}>연락처</a></li>
      </ul>
    </nav>
    <a href={BOOKING_URL} class="head-cta head-cta-desktop">{ctaLabel}</a>
    <a href="https://wa.me/16478888472" class="head-cta-call" aria-label="WhatsApp로 전화">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 15.5c-1.2 0-2.4-.2-3.5-.6-.3-.1-.7 0-1 .3l-2 2c-2.7-1.4-4.9-3.6-6.3-6.3l2-2c.3-.3.4-.7.3-1-.4-1.1-.6-2.3-.6-3.5 0-.5-.5-1-1-1H4c-.5 0-1 .5-1 1 0 9.4 7.6 17 17 17 .5 0 1-.5 1-1v-3.9c0-.5-.5-1-1-1z" fill="currentColor"/></svg>
      전화
    </a>
  </div>
</header>
