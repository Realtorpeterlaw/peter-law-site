---
interface Props { heading?: string; lead?: string; ctaTitle?: string; ctaSubtitle?: string; ctaLabel?: string; }
const {
  heading = "준비되시면 시작해요.",
  lead = "15분 무료 상담. 이 시장에서 당신의 검색이 어떻게 진행될지, 무엇을 준비해야 하는지, 제가 당신에게 맞는 사람인지 정확히 알려드립니다.",
  ctaTitle = "상담 예약",
  ctaSubtitle = "15분 · Google Meet 또는 전화 · 무료",
  ctaLabel = "시간 선택",
} = Astro.props;
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<section class="cta-section" id="book">
  <div class="wrap cta-grid">
    <div><h2>{heading}</h2><p>{lead}</p></div>
    <div class="cta-box">
      <h3>{ctaTitle}</h3><p>{ctaSubtitle}</p>
      <a href={BOOKING_URL} class="btn-primary">{ctaLabel}<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      <span class="alt">또는 647-888-8472로 문자</span>
    </div>
  </div>
  <div class="wrap affiliations">
    <div class="affiliations-label">전문 협회</div>
    <ul class="affiliations-list">
      <li><a href="https://trreb.ca/" target="_blank" rel="noopener noreferrer"><span class="aff-acronym">TRREB</span></a></li>
      <li><a href="https://www.orea.com/" target="_blank" rel="noopener noreferrer"><span class="aff-acronym">OREA</span></a></li>
      <li><a href="https://www.crea.ca/" target="_blank" rel="noopener noreferrer"><span class="aff-acronym">CREA</span></a></li>
      <li><a href="https://www.reco.on.ca/" target="_blank" rel="noopener noreferrer"><span class="aff-acronym">RECO</span></a></li>
    </ul>
  </div>
</section>
