---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
interface HreflangAlt { hreflang: string; href: string; }
interface Props {
  title: string;
  description?: string;
  zh?: boolean;
  bodyClass?: string;
  lang?: string;
  dir?: 'ltr' | 'rtl';
  hreflangAlternates?: HreflangAlt[];
}
const {
  title,
  description = "Bilingual Toronto real estate. Pre-approved fast, moved in calmly. Hospitality-grade service from a former Airbnb host with 400+ guest reviews.",
  zh = false,
  bodyClass = "",
  lang: langProp,
  dir: dirProp,
  hreflangAlternates = [],
} = Astro.props;
const htmlLang = langProp || (zh ? 'zh-CN' : 'en');
const htmlDir = dirProp || 'ltr';
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// Auto-generate BreadcrumbList JSON-LD from URL path
const _path = Astro.url.pathname.replace(/\/$/, '');
const _segments = _path.split('/').filter(Boolean);
const _labelMap: Record<string, string> = {
  chinese: '中文', russian: 'Русский', farsi: 'فارسی', hindi: 'हिंदी',
  korean: '한국어', japanese: '日本語', spanish: 'Español',
  blog: 'Blog', 'past-deals': 'Sale History', about: 'About', contact: 'Contact',
  'buyer-guide': 'Buyer Guide', 'for-renters': 'For Renters', 'for-landlords': 'For Landlords',
  'rental-tour': 'Rental Tour', 'rent-control': 'Rent Control', 'lease-renewal': 'Lease Renewal',
  'n-forms': 'N Forms', 'land-transfer-tax': 'Land Transfer Tax',
  'payment-calculator': 'Mortgage Calculator', 'affordability-calculator': 'Affordability Calculator',
  'cmhc-insurance-calculator': 'CMHC Insurance Calculator', 'closing-costs': 'Closing Costs',
  'all-calculator': 'BUY Calculator', 'rental-calculator': 'Rental Calculator',
  'free-home-evaluation': 'Free Home Evaluation', apply: 'Apply',
  terms: 'Terms of Service', privacy: 'Privacy Policy',
  disclaimer: 'Disclaimer', accessibility: 'Accessibility',
};
function _title(seg: string): string {
  if (_labelMap[seg]) return _labelMap[seg];
  return seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}
const _crumbs: {name: string, url: string}[] = [{ name: 'Home', url: 'https://www.realtorpeterlaw.com/' }];
let _acc = '';
for (const seg of _segments) {
  _acc += '/' + seg;
  _crumbs.push({ name: _title(seg), url: 'https://www.realtorpeterlaw.com' + _acc });
}
const _breadcrumbLd = _crumbs.length > 1 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: _crumbs.map((c, i) => ({
    '@type': 'ListItem', position: i + 1, name: c.name, item: c.url,
  })),
} : null;
---
<!DOCTYPE html>
<html lang={htmlLang} dir={htmlDir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600&family=Noto+Serif+KR:wght@400;500&display=swap" rel="stylesheet" />
  {hreflangAlternates.map((alt) => (
    <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
  ))}
  {_breadcrumbLd && (
    <script type="application/ld+json" set:html={JSON.stringify(_breadcrumbLd)} />
  )}
  <slot name="head" />
</head>
<body class={bodyClass + (zh ? ' zh' : '')}>
  <slot />
  <Analytics />
</body>
</html>
