---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-03';
const articleTitle = 'Time-of-Use (TOU) — как снизить счёт за электричество';
const articleDescription = 'Простое руководство по тарифу Time-of-Use (TOU) в Онтарио: три тарифа, время действия каждого и 7 простых способов уменьшить счёт за свет без изменения образа жизни.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/time-of-use-tou';
const enUrl = 'https://www.realtorpeterlaw.com/blog/time-of-use-tou';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Недвижимость в Торонто', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'Time of Use Онтарио, TOU электричество, тариф электричества Онтарио, off-peak часы, ULO тариф, снизить счёт за свет Торонто',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/time-of-use-tou/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/time-of-use-tou/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/time-of-use-tou/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/time-of-use-tou/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/time-of-use-tou/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/time-of-use-tou/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/time-of-use-tou/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Счёт за электричество</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">В вашем счёте за электричество три цены. Используете свет в правильное время суток — платите заметно меньше. Разберём это простыми словами.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-03</time>
          <span class="dot">·</span>
          <span>4 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#prices">Три тарифа</a></li>
              <li><a href="#when">Когда какой тариф</a></li>
              <li><a href="#tips">7 простых шагов</a></li>
              <li><a href="#ulo">Тариф ULO</a></li>
              <li><a href="#savings">Реальная экономия</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Система</span><span class="qf-val">Time-of-Use (TOU) в Онтарио</span></div>
              <div class="qf-row"><span class="qf-label">Число тарифов</span><span class="qf-val">3 (Off-peak, Mid-peak, On-peak)</span></div>
              <div class="qf-row"><span class="qf-label">Самый дешёвый</span><span class="qf-val">Off-peak — ночь и выходные</span></div>
              <div class="qf-row"><span class="qf-label">Самый дорогой</span><span class="qf-val">On-peak — утро и вечер будней</span></div>
              <div class="qf-row"><span class="qf-label">Альтернатива</span><span class="qf-val">ULO — ещё дешевле ночью</span></div>
            </div>


            <h2 id="prices">Три тарифа</h2>
            <p><strong>Off-peak</strong>: самый низкий — обычно с 19:00 до 7:00 в будни и все выходные. <strong>Mid-peak</strong>: середина дня в будни. <strong>On-peak</strong>: утро (около 7–11) и вечер (около 17–19) в будни.</p>

            <h2 id="when">Когда какой тариф</h2>
            <p>Точные интервалы слегка меняются по сезону, но принцип один: <strong>«прожорливые» приборы</strong> (посудомойка, стиралка, сушилка) — на off-peak, и вы экономите, ничего больше не меняя.</p>

            <h2 id="tips">7 простых шагов</h2>
            <p>1) Ставить посудомойку после 19:00. 2) Стирка и сушка — по выходным. 3) Зарядка электромобиля ночью. 4) Заготовки на неделю по воскресеньям. 5) Программируемый термостат. 6) Отключать неиспользуемые приборы. 7) Проверить сквозняки у окон.</p>

            <h2 id="ulo">Тариф ULO</h2>
            <p><strong>Ultra-Low Overnight (ULO)</strong> — ещё более низкий ночной тариф (23:00–7:00), выгоден владельцам электромобилей и тем, кто отапливается тепловым насосом.</p>

            <h2 id="savings">Реальная экономия</h2>
            <p>Средняя семья экономит <strong>10–20 %</strong>, просто перенося пользование крупными приборами в off-peak — без потери комфорта.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
