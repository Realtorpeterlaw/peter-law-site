---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-07';
const articleTitle = 'HELOC (кредитная линия под залог дома) — Канада';
const articleDescription = 'Простое руководство по HELOC в Канаде: как работает, кто подходит, лимиты (правила 65 %/80 %), реальные ставки, и сравнение с обратной ипотекой и рефинансированием.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/heloc';
const enUrl = 'https://www.realtorpeterlaw.com/blog/heloc';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Недвижимость в Торонто', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'HELOC Канада, кредитная линия под залог дома, правило 65 80 процентов, использовать капитал дома, рефинансирование против HELOC, Торонто HELOC',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/heloc/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/heloc/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/heloc/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/heloc/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/heloc/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/heloc/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/heloc/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Финансирование для владельцев</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Простое руководство по кредитной линии под залог дома в Канаде: как она работает, кто подходит, сколько реально стоит и как решить, подходит ли она для получения средств под ваш дом.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-07</time>
          <span class="dot">·</span>
          <span>5 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#what">Что это такое</a></li>
              <li><a href="#limits">Сколько можно взять</a></li>
              <li><a href="#who">Кто подходит</a></li>
              <li><a href="#cost">Реальная стоимость</a></li>
              <li><a href="#vs">HELOC против альтернатив</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Тип</span><span class="qf-val">Возобновляемая кредитная линия под залог дома</span></div>
              <div class="qf-row"><span class="qf-label">Лимит HELOC отдельно</span><span class="qf-val">До 65 % оценочной стоимости</span></div>
              <div class="qf-row"><span class="qf-label">Совокупный лимит (HELOC+ипотека)</span><span class="qf-val">До 80 %</span></div>
              <div class="qf-row"><span class="qf-label">Проценты</span><span class="qf-val">Плавающие, базируются на ставке prime</span></div>
              <div class="qf-row"><span class="qf-label">Погашение</span><span class="qf-val">Можно только проценты, тело — гибко</span></div>
            </div>


            <h2 id="what">Что это такое</h2>
            <p>HELOC — это <strong>возобновляемая кредитная линия под залог доли</strong> (equity) вашего дома. Вы берёте столько, сколько нужно, и когда нужно, в пределах одобренного лимита. Ставка обычно <strong>плавающая</strong> и следует ставке prime банка.</p>

            <h2 id="limits">Сколько можно взять</h2>
            <p>Стандартное правило: только HELOC — до <strong>65 % оценочной стоимости</strong> дома. HELOC вместе с ипотекой — суммарно до <strong>80 %</strong>.</p>

            <h2 id="who">Кто подходит</h2>
            <p>Нужны стабильный доход, хорошая кредитная история и достаточная доля собственности. Банк обычно требует <strong>официальную оценку</strong> и применяет <strong>stress test</strong>, как для ипотеки.</p>

            <h2 id="cost">Реальная стоимость</h2>
            <p>Плавающая ставка — есть риск подорожания. Многие платят только проценты и не гасят тело, что дорого в долгосрочной перспективе. Проверьте комиссии за открытие, ежегодные сборы и штрафы при закрытии.</p>

            <h2 id="vs">HELOC против альтернатив</h2>
            <p><strong>HELOC</strong>: максимальная гибкость, плавающая ставка, удобно для поэтапного ремонта. <strong>Рефинансирование</strong>: возможна фиксированная ставка, лучше при разовом большом займе. <strong>Обратная ипотека</strong>: только 55+, без обязательных ежемесячных платежей.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
