---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-07-14';
const articleTitle = 'Программа снабжения арендным жильём (RHSP) — Торонто';
const articleDescription = 'Простое руководство по программе снабжения арендным жильём (RHSP) города Торонто: что это, кто подаёт заявку, пять направлений финансирования и что это значит для арендаторов Торонто.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/rhsp';
const enUrl = 'https://www.realtorpeterlaw.com/blog/rhsp';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Недвижимость в Торонто', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'RHSP Торонто, программа арендного жилья Торонто, доступная аренда Торонто, муниципальная программа аренды, субсидия застройщику арендного жилья',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/rhsp/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/rhsp/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/rhsp/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/rhsp/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/rhsp/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/rhsp/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/rhsp/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Арендаторам Торонто</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Торонто помогает застройщикам строить больше арендного жилья. Часть квартир будет доступна по льготной аренде до 40 лет, часть — по рыночной цене. Разберём, что это за программа, кто в ней участвует и что это меняет для арендаторов.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-07-14</time>
          <span class="dot">·</span>
          <span>5 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#what">Что это такое</a></li>
              <li><a href="#streams">Пять потоков</a></li>
              <li><a href="#who">Кто подаёт заявку</a></li>
              <li><a href="#affordable">Условия доступной аренды</a></li>
              <li><a href="#impact">Что это меняет для вас</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Организатор</span><span class="qf-val">Город Торонто</span></div>
              <div class="qf-row"><span class="qf-label">Цель</span><span class="qf-val">Новое арендное жильё на 10 лет</span></div>
              <div class="qf-row"><span class="qf-label">Направления</span><span class="qf-val">5 потоков финансирования</span></div>
              <div class="qf-row"><span class="qf-label">Доступность</span><span class="qf-val">Часть квартир — доступная аренда до 40 лет</span></div>
              <div class="qf-row"><span class="qf-label">Кто подаёт</span><span class="qf-val">Застройщики и арендодатели, не арендаторы</span></div>
            </div>


            <h2 id="what">Что это такое</h2>
            <p>RHSP — муниципальная программа, которая выделяет застройщикам арендного жилья <strong>субсидии, льготные кредиты, налоговые послабления, участки</strong> — чтобы построить тысячи новых арендных квартир за 10 лет. Часть из них будет <strong>с зафиксированной доступной арендой</strong>.</p>

            <h2 id="streams">Пять потоков</h2>
            <p>Программа делится на пять направлений: новое доступное арендное жильё, аренда по рынку, сохранение существующего арендного фонда, сопровождаемое жильё (supportive housing) и повторное использование городских земель.</p>

            <h2 id="who">Кто подаёт заявку</h2>
            <p>Заявителями выступают <strong>застройщики, девелоперы и арендодатели</strong> — не сами арендаторы. Вы, как арендатор, получаете выгоду косвенно, когда одобренный проект достраивается рядом с вашим районом.</p>

            <h2 id="affordable">Условия доступной аренды</h2>
            <p>Доступные квартиры ограничены городскими лимитами (часто 80 % медианной рыночной аренды) и остаются такими <strong>до 40 лет</strong>. Это принципиальное отличие от простых стимулов на строительство.</p>

            <h2 id="impact">Что это меняет для вас</h2>
            <p>Больше предложения, особенно в новых районах, и медленно, но стабильно растущий фонд доступной аренды. Это не мгновенное снижение цен, а долгосрочная стабилизация рынка.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
