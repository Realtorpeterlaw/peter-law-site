---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-03';
const articleTitle = 'Закон Bill 60 (Онтарио): что должны знать арендаторы и арендодатели';
const articleDescription = 'Простое руководство по закону Bill 60 в Онтарио: пять изменений в правилах аренды, сравнение до/после, и что делать арендатору и арендодателю.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/bill-60-ontario';
const enUrl = 'https://www.realtorpeterlaw.com/blog/bill-60-ontario';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Недвижимость в Торонто', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'Bill 60 Онтарио, изменения аренды Онтарио 2025, RTA Онтарио, выселение Онтарио, возврат для личного пользования, права арендатора Онтарио',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/bill-60-ontario/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/bill-60-ontario/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/bill-60-ontario/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/bill-60-ontario/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/bill-60-ontario/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/bill-60-ontario/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/bill-60-ontario/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Арендаторам и арендодателям</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">В конце 2025 года Онтарио принял закон Bill 60. Он меняет правила аренды. Большая часть изменений — в пользу арендодателей, у арендаторов меньше времени и меньше рычагов. Разбираем изменения простыми словами.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-03</time>
          <span class="dot">·</span>
          <span>5 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#what">Что меняет закон</a></li>
              <li><a href="#changes">Пять ключевых изменений</a></li>
              <li><a href="#tenants">Если вы арендатор</a></li>
              <li><a href="#landlords">Если вы арендодатель</a></li>
              <li><a href="#action">Что делать сейчас</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Закон</span><span class="qf-val">Bill 60 Онтарио</span></div>
              <div class="qf-row"><span class="qf-label">Вступил в силу</span><span class="qf-val">Конец 2025</span></div>
              <div class="qf-row"><span class="qf-label">Сфера</span><span class="qf-val">Жилая аренда (RTA)</span></div>
              <div class="qf-row"><span class="qf-label">Общий эффект</span><span class="qf-val">Усиление позиции арендодателей</span></div>
              <div class="qf-row"><span class="qf-label">Пять изменений</span><span class="qf-val">Сроки короче + процедура проще</span></div>
            </div>


            <h2 id="what">Что меняет закон</h2>
            <p>Bill 60 меняет ряд <strong>сроков и процедур</strong> в законе о жилой аренде (RTA). Он <strong>сокращает сроки</strong> для арендаторов и <strong>упрощает процедуру</strong> для арендодателей — в особенности при возврате жилья для личного пользования и выселении за неуплату.</p>

            <h2 id="changes">Пять ключевых изменений</h2>
            <p>Сокращённые сроки обжалования для арендаторов; упрощённый порядок возврата для личного пользования; повышенные штрафы за недобросовестный возврат; уточнённые правила повышения арендной платы сверх лимита; пересмотренный график слушаний LTB.</p>

            <h2 id="tenants">Если вы арендатор</h2>
            <p>Записывайте каждую дату. Никогда не оставляйте уведомление формы N без ответа. Возврат для личного пользования должен быть <strong>добросовестным</strong> — иначе вы вправе требовать компенсацию. При получении N12 или N13 обратитесь в местную юридическую клинику.</p>

            <h2 id="landlords">Если вы арендодатель</h2>
            <p>Процедуры быстрее, но <strong>штрафы за недобросовестный возврат увеличены</strong>. Тщательно документируйте любой возврат для личного пользования и убедитесь, что член семьи действительно проживает там минимум год.</p>

            <h2 id="action">Что делать сейчас</h2>
            <p>Арендаторы: храните все документы (договор, квитанции, уведомления) и следите за каждой стадией. Арендодатели: обновите шаблоны уведомлений, проинформируйте управляющего и соблюдайте новые правила буквально.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
