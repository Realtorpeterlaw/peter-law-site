---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-09';
const articleTitle = 'Запрет на покупку жилья иностранцами в Канаде (до 2026)';
const articleDescription = 'Простое руководство по канадскому Закону о запрете покупки жилой недвижимости не-канадцами: кто считается не-канадцем, какие объекты попадают под запрет, исключения (рабочая виза, супруг), штрафы, срок действия до 31 декабря 2026.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/foreign-buyer-ban';
const enUrl = 'https://www.realtorpeterlaw.com/blog/foreign-buyer-ban';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Недвижимость в Торонто', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'запрет иностранцам покупать жильё Канада, не-канадец запрет недвижимость, рабочая виза покупка жилья Канада, супруг канадец исключение, 2026 запрет иностранцы',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/foreign-buyer-ban/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/foreign-buyer-ban/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/foreign-buyer-ban/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/foreign-buyer-ban/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/foreign-buyer-ban/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/foreign-buyer-ban/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/foreign-buyer-ban/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Федеральное регулирование</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Канадский запрет на покупку жилья иностранцами действует с 1 января 2023 года и сохраняется до <strong>31 декабря 2026 года</strong>. Правила уже, чем звучит заголовок — и исключения имеют значение. Разбираем, к кому это на самом деле относится.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-09</time>
          <span class="dot">·</span>
          <span>5 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#what">Что запрещено</a></li>
              <li><a href="#who">Кто считается не-канадцем</a></li>
              <li><a href="#exceptions">Основные исключения</a></li>
              <li><a href="#properties">Какие объекты подпадают</a></li>
              <li><a href="#penalties">Штрафы</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Закон</span><span class="qf-val">Prohibition on the Purchase of Residential Property by Non-Canadians Act</span></div>
              <div class="qf-row"><span class="qf-label">Действует</span><span class="qf-val">1 января 2023 — 31 декабря 2026</span></div>
              <div class="qf-row"><span class="qf-label">Кто под запретом</span><span class="qf-val">Не-канадцы (кроме исключений)</span></div>
              <div class="qf-row"><span class="qf-label">Какие объекты</span><span class="qf-val">Жилые в CMA/CA (крупных агломерациях)</span></div>
              <div class="qf-row"><span class="qf-label">Санкция</span><span class="qf-val">Штраф до 10 000 $ + принудительная продажа</span></div>
            </div>


            <h2 id="what">Что запрещено</h2>
            <p>Федеральный закон запрещает <strong>не-канадцам</strong> покупать жилую недвижимость в крупных агломерациях (CMA) и переписных зонах (CA). Срок действия — с 1 января 2023 до <strong>31 декабря 2026</strong>.</p>

            <h2 id="who">Кто считается не-канадцем</h2>
            <p>Любой, кто не является гражданином Канады, постоянным резидентом или зарегистрирован по Indian Act. Также — компании, где не-канадец владеет более 10 % долей.</p>

            <h2 id="exceptions">Основные исключения</h2>
            <p>Иностранные студенты при определённых условиях; <strong>обладатели рабочей визы</strong>, отработавшие в Канаде определённое число лет; <strong>супруги канадских граждан или постоянных резидентов</strong>; беженцы и лица с защищённым статусом; покупка вне зон CMA/CA.</p>

            <h2 id="properties">Какие объекты подпадают</h2>
            <p>Односемейные, полу-отдельные, таунхаусы, кондо, дуплексы до 3 квартир в CMA/CA. Здания <strong>от 4 квартир и выше — исключены</strong>. Некоторые рекреационные объекты вне CMA/CA также вне запрета.</p>

            <h2 id="penalties">Штрафы</h2>
            <p>Штраф до <strong>10 000 $</strong> для покупателя и любого посредника (риэлтор, юрист). Суд также может назначить <strong>принудительную продажу</strong> купленной с нарушением недвижимости.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
