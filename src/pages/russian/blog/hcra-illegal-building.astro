---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-07-15';
const articleTitle = 'HCRA и незаконное строительство в Онтарио';
const articleDescription = 'В Онтарио любой, кто строит или продаёт новое жильё, должен иметь лицензию HCRA. Что означает «незаконное строительство» и почему это важно при покупке.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/hcra-illegal-building';
const enUrl = 'https://www.realtorpeterlaw.com/blog/hcra-illegal-building';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: {
    '@type': 'Organization',
    name: 'Peter Law — Недвижимость в Торонто',
    logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' },
  },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'HCRA Онтарио, незаконная новостройка, лицензия застройщика Онтарио, гарантия Tarion, защита покупателя нового жилья, проверить лицензию застройщика',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/hcra-illegal-building/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/hcra-illegal-building/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/hcra-illegal-building/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/hcra-illegal-building/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/hcra-illegal-building/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/hcra-illegal-building/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/hcra-illegal-building/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Защита покупателя</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">В Онтарио тот, кто строит или продаёт новое жильё, обязан иметь лицензию HCRA (Home Construction Regulatory Authority). Работа без лицензии называется «незаконным строительством». Разбираем, что это значит и почему это важно для покупателя.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-07-15</time>
          <span class="dot">·</span>
          <span>4 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#what">Что это значит</a></li>
              <li><a href="#why">Почему это важно</a></li>
              <li><a href="#check">Как проверить</a></li>
              <li><a href="#flags">Тревожные сигналы</a></li>
              <li><a href="#protect">Как себя защитить</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Регулятор</span><span class="qf-val">HCRA — Home Construction Regulatory Authority</span></div>
              <div class="qf-row"><span class="qf-label">Лицензия обязательна</span><span class="qf-val">Для любого строителя/продавца нового жилья</span></div>
              <div class="qf-row"><span class="qf-label">Связанная гарантия</span><span class="qf-val">Программа Tarion для покупателя</span></div>
              <div class="qf-row"><span class="qf-label">Как проверить</span><span class="qf-val">Публичный реестр лицензий HCRA</span></div>
              <div class="qf-row"><span class="qf-label">Главный риск</span><span class="qf-val">Нет покрытия Tarion + ограниченная защита</span></div>
            </div>


            <h2 id="what">Что это значит</h2>
            <p>HCRA выдаёт лицензии строителям и продавцам нового жилья в Онтарио. Без лицензии они <strong>по закону не могут ни строить, ни продавать</strong>. Если это происходит — это <strong>незаконное строительство</strong>.</p><p>Главная проблема для покупателя: жильё без лицензии не подпадает под <strong>гарантию Tarion</strong> — провинциальную защиту от серьёзных дефектов.</p>

            <h2 id="why">Почему это важно</h2>
            <p>Легальная новостройка <strong>автоматически регистрируется в Tarion</strong> и получает защиту от 1 до 7 лет в зависимости от типа дефекта. Без лицензии этой защиты нет, и все дефекты — конструкция, влага, отделка — <strong>полностью за ваш счёт</strong>.</p><p>Кроме того, продать такое жильё в будущем сложнее: осведомлённые покупатели и их адвокаты откажутся от сделки.</p>

            <h2 id="check">Как проверить</h2>
            <p>Перед подписанием оффера на новостройку проверьте застройщика в <strong>публичном реестре HCRA (hcraontario.ca)</strong>. Там видны лицензия, история жалоб и санкций.</p><p>Также запросите <strong>номер регистрации Tarion</strong> именно этого дома, а не только застройщика.</p>

            <h2 id="flags">Тревожные сигналы</h2>
            <p>Цена сильно ниже рынка новостроек, давление быстро подписать, договор без логотипа компании, отказ дать номер HCRA, обещание «гарантии от застройщика» вместо Tarion. Один-два таких сигнала — повод для дополнительной проверки.</p>

            <h2 id="protect">Как себя защитить</h2>
            <p>Работайте только с риэлтором с опытом по новостройкам и с адвокатом по недвижимости. Не вносите депозит, пока не проверены <strong>лицензия HCRA и регистрация Tarion</strong>. В спорных ситуациях свяжитесь с HCRA напрямую.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card {
    background: #fff;
    border: 1px solid var(--line, #e6e2dc);
    border-radius: 14px;
    padding: 18px 20px;
    margin: 0 0 28px;
    display: grid;
    gap: 10px;
  }
  .qf-row {
    display: grid;
    grid-template-columns: 42% 1fr;
    gap: 14px;
    align-items: baseline;
    padding-bottom: 8px;
    border-bottom: 1px dashed #eee;
  }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta {
    margin-top: 36px;
    padding: 22px;
    background: #f8f5ef;
    border: 1px solid var(--line, #e6e2dc);
    border-radius: 14px;
    text-align: center;
  }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary {
    display: inline-block;
    background: #b8845b;
    color: #fff;
    padding: 12px 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
