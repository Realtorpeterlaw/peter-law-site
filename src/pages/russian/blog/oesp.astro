---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-09';
const articleTitle = 'OESP — снизьте счёт за электричество почти вдвое';
const articleDescription = 'Простое руководство по программе OESP в Онтарио: кто подходит, суммы ежемесячного кредита (35–113 $), и как совмещать с LEAP и OER, чтобы небольшая семья снизила счёт почти вдвое.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/oesp';
const enUrl = 'https://www.realtorpeterlaw.com/blog/oesp';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Недвижимость в Торонто', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'OESP Онтарио, помощь за электричество Онтарио, кредит счёт за свет, LEAP Онтарио, OER Onтарио скидка на электричество',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/oesp/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/oesp/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/oesp/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/oesp/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/oesp/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/oesp/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/oesp/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Помощь по счетам за свет</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">OESP — вероятно, самая недоиспользуемая программа помощи по счетам в Онтарио. Подходящие домохозяйства получают ежемесячный кредит в размере <strong>35–113 $</strong> прямо на счёте — для многих небольших семей это почти половина цены.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-09</time>
          <span class="dot">·</span>
          <span>4 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#what">Что это</a></li>
              <li><a href="#who">Кто подходит</a></li>
              <li><a href="#amount">Размер кредита</a></li>
              <li><a href="#stack">Сочетание с другими программами</a></li>
              <li><a href="#apply">Как подать заявку</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Программа</span><span class="qf-val">OESP — Ontario Electricity Support Program</span></div>
              <div class="qf-row"><span class="qf-label">Тип помощи</span><span class="qf-val">Ежемесячный кредит прямо в счёте</span></div>
              <div class="qf-row"><span class="qf-label">Сумма</span><span class="qf-val">35 $ – 113 $ в месяц</span></div>
              <div class="qf-row"><span class="qf-label">Основа права</span><span class="qf-val">Доход домохозяйства + число членов</span></div>
              <div class="qf-row"><span class="qf-label">Совмещается</span><span class="qf-val">С LEAP + OER (Ontario Electricity Rebate)</span></div>
            </div>


            <h2 id="what">Что это</h2>
            <p>OESP — это <strong>ежемесячный кредит</strong>, автоматически применяемый к вашему счёту за электричество. Не требует возврата. Финансируется провинцией; действует, пока вы соответствуете условиям.</p>

            <h2 id="who">Кто подходит</h2>
            <p>Право определяется <strong>доходом домохозяйства</strong> и <strong>числом членов семьи</strong>. Более крупные или менее обеспеченные семьи получают больший кредит. Заявка подаётся онлайн на ontarioelectricitysupport.ca.</p>

            <h2 id="amount">Размер кредита</h2>
            <p>От <strong>35 $ в месяц</strong> (базовый уровень) до <strong>113 $ в месяц</strong> для больших семей или домов с электрическим отоплением.</p>

            <h2 id="stack">Сочетание с другими программами</h2>
            <p>OESP суммируется с <strong>LEAP</strong> (разовая экстренная помощь при задолженности) и с <strong>OER</strong> (Ontario Electricity Rebate), который уже снижает счёт на несколько процентов. Все три вместе — счёт небольшой семьи может уменьшиться почти вдвое.</p>

            <h2 id="apply">Как подать заявку</h2>
            <p>Онлайн-форма + подтверждение дохода (T4, Notice of Assessment). После одобрения кредит появляется автоматически на следующих счетах. Право нужно периодически подтверждать.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
