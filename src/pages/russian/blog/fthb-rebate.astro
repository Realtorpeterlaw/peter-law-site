---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-08';
const articleTitle = 'Возврат GST/HST для первого покупателя (новостройка)';
const articleDescription = 'Новый федеральный возврат GST/HST для первых покупателей может вернуть до 50 000 $ при покупке новостройки. Кто подходит, какие дома подпадают и как он суммируется с существующим возвратом.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/fthb-rebate';
const enUrl = 'https://www.realtorpeterlaw.com/blog/fthb-rebate';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: {
    '@type': 'Organization',
    name: 'Peter Law — Недвижимость в Торонто',
    logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' },
  },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'возврат GST HST первый покупатель, новостройка Онтарио возврат, 50000 первый покупатель, возврат HST Онтарио, новый кондо Торонто',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/fthb-rebate/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/fthb-rebate/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/fthb-rebate/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/fthb-rebate/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/fthb-rebate/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/fthb-rebate/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/fthb-rebate/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Возврат для покупателя</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Канада ввела новый возврат GST/HST, который может вернуть до 50 000 $ первым покупателям при покупке новостройки. Разберём, кто имеет право, какие объекты подходят, и как этот возврат сочетается с уже существующим.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-08</time>
          <span class="dot">·</span>
          <span>5 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#what">Суть программы</a></li>
              <li><a href="#who">Кто подходит</a></li>
              <li><a href="#which">Какое жильё подходит</a></li>
              <li><a href="#math">Быстрый расчёт</a></li>
              <li><a href="#careful">На что обратить внимание</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Максимум</span><span class="qf-val">До 50 000 $ (часть GST в HST)</span></div>
              <div class="qf-row"><span class="qf-label">Статус</span><span class="qf-val">Первый покупатель по федеральному определению</span></div>
              <div class="qf-row"><span class="qf-label">Тип жилья</span><span class="qf-val">Новостройка или существенная реконструкция</span></div>
              <div class="qf-row"><span class="qf-label">Порог цены</span><span class="qf-val">Постепенное снижение свыше 450 000 $</span></div>
              <div class="qf-row"><span class="qf-label">Суммируется</span><span class="qf-val">С существующим возвратом HST в Онтарио</span></div>
            </div>


            <h2 id="what">Суть программы</h2>
            <p>Новый федеральный возврат GST/HST возмещает <strong>часть GST (5 %)</strong>, уплаченную при покупке новостройки — до 50 000 $. Он добавляется к существующему провинциальному возврату HST в Онтарио.</p><p>Цель — снизить нагрузку на первых покупателей, покупающих новое жильё, где GST/HST начисляется на цену (в отличие от вторичного рынка, где налог не платится).</p>

            <h2 id="who">Кто подходит</h2>
            <p>Нужно быть <strong>первым покупателем</strong> по федеральному определению: ни вы, ни ваш(а) супруг(а) не должны были владеть жильём, использовавшимся как основное место жительства, <strong>в последние четыре года</strong>. Также требуется 18+ и статус резидента Канады.</p><p>Дом должен стать вашим <strong>основным местом жительства</strong> — не дачей и не арендной недвижимостью.</p>

            <h2 id="which">Какое жильё подходит</h2>
            <p>Новостройки от застройщика, новые кондо, крупные реконструкции, приравненные к новостройке. Покупка участка с постройкой на заказ тоже возможна при определённых условиях.</p><p><strong>Вторичный рынок не подходит</strong> — там GST/HST не начисляется изначально.</p>

            <h2 id="math">Быстрый расчёт</h2>
            <p>Новый кондо в Торонто за 800 000 $: часть GST — 40 000 $. Это ниже потолка 50 000 $, значит возврат полный. Также сохраняется существующий возврат HST в Онтарио. Точный расчёт до подписания — с Peter.</p>

            <h2 id="careful">На что обратить внимание</h2>
            <p>Программа <strong>новая</strong> — итоговые правила могут меняться. Перед подписанием обязательно перепроверьте право у бухгалтера и у застройщика. Правило четырёх лет строгое — даже короткий период владения в прошлом может лишить вас возврата.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card {
    background: #fff;
    border: 1px solid var(--line, #e6e2dc);
    border-radius: 14px;
    padding: 18px 20px;
    margin: 0 0 28px;
    display: grid;
    gap: 10px;
  }
  .qf-row {
    display: grid;
    grid-template-columns: 42% 1fr;
    gap: 14px;
    align-items: baseline;
    padding-bottom: 8px;
    border-bottom: 1px dashed #eee;
  }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta {
    margin-top: 36px;
    padding: 22px;
    background: #f8f5ef;
    border: 1px solid var(--line, #e6e2dc);
    border-radius: 14px;
    text-align: center;
  }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary {
    display: inline-block;
    background: #b8845b;
    color: #fff;
    padding: 12px 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
