---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-03';
const articleTitle = 'Обратная ипотека (Reverse Mortgage) — Канада';
const articleDescription = 'Простое руководство по обратной ипотеке в Канаде: как работает, кто подходит (55+), сколько можно взять, ставки, комиссии, и реальные компромиссы перед подписанием. Издание для владельцев жилья в Торонто.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/reverse-mortgage';
const enUrl = 'https://www.realtorpeterlaw.com/blog/reverse-mortgage';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Недвижимость в Торонто', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'обратная ипотека Канада, 55 плюс владелец, использовать капитал дома пенсия, пенсионная ипотека Канада, стоимость обратной ипотеки',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/reverse-mortgage/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/reverse-mortgage/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/reverse-mortgage/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/reverse-mortgage/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/reverse-mortgage/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/reverse-mortgage/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/reverse-mortgage/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Владельцам 55+</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Понятное объяснение для канадских владельцев жилья 55+: как реально работает обратная ипотека, что она стоит, и какие компромиссы банк не всегда озвучивает до подписания.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-03</time>
          <span class="dot">·</span>
          <span>5 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#what">Что это</a></li>
              <li><a href="#who">Кто подходит</a></li>
              <li><a href="#how-much">Сколько можно взять</a></li>
              <li><a href="#cost">Реальная стоимость</a></li>
              <li><a href="#tradeoff">Настоящие компромиссы</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Мин. возраст</span><span class="qf-val">55 лет (все зарегистрированные владельцы)</span></div>
              <div class="qf-row"><span class="qf-label">Тип жилья</span><span class="qf-val">Основное место жительства</span></div>
              <div class="qf-row"><span class="qf-label">Макс. заём</span><span class="qf-val">Обычно до 55 % от стоимости</span></div>
              <div class="qf-row"><span class="qf-label">Ежемесячные платежи</span><span class="qf-val">Нет, пока вы живёте в доме</span></div>
              <div class="qf-row"><span class="qf-label">Ставка</span><span class="qf-val">Фиксированная или плавающая, выше обычной ипотеки</span></div>
            </div>


            <h2 id="what">Что это</h2>
            <p>Обратная ипотека — это заём под залог доли в доме для владельцев 55+ <strong>без обязательных ежемесячных платежей</strong>. Проценты накапливаются на остатке, а долг выплачивается при продаже, переезде или уходе из жизни.</p>

            <h2 id="who">Кто подходит</h2>
            <p>Вы и <strong>все зарегистрированные владельцы</strong> должны быть <strong>55 лет и старше</strong>. Дом должен быть <strong>основным местом жительства</strong>. Нет проверки дохода и кредитной истории — что делает продукт доступным пенсионерам.</p>

            <h2 id="how-much">Сколько можно взять</h2>
            <p>Обычно до <strong>55 % оценочной стоимости</strong> — в зависимости от возраста и типа жилья. <strong>Чем старше</strong>, тем больше сумма (потому что ожидаемый срок займа короче).</p>

            <h2 id="cost">Реальная стоимость</h2>
            <p>Ставка <strong>выше обычной ипотеки</strong>, а проценты накапливаются. За 15–20 лет долг может съесть значительную часть капитала. Добавьте оценку, юридические и открытие счёта.</p>

            <h2 id="tradeoff">Настоящие компромиссы</h2>
            <p>+ Нет ежемесячных платежей, деньги без налога, остаётесь в доме. − Существенное уменьшение наследства, дороже HELOC, серьёзные штрафы за досрочное закрытие. Обязательно проконсультируйтесь у <strong>независимого финансового и юридического советника</strong>.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
