---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/RussianTopBar.astro';
import Header from '../../../components/RussianHeader.astro';
import Footer from '../../../components/RussianFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-09';
const articleTitle = 'Сберегательный счёт для первого дома (FHSA)';
const articleDescription = 'Простое руководство по FHSA — регистрированному счёту, объединяющему налоговый вычет при взносе (как RRSP) и безналоговый вывод (как TFSA). 8 000 $/год, 40 000 $ пожизненно, комбинация с HBP.';
const articleUrl = 'https://www.realtorpeterlaw.com/russian/blog/fhsa';
const enUrl = 'https://www.realtorpeterlaw.com/blog/fhsa';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/russian/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Недвижимость в Торонто', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'ru',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'FHSA Канада, счёт первого покупателя, налоговый вычет первый дом, HBP FHSA сочетание, максимальный первоначальный взнос Канада',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/fhsa/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/fhsa/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/fhsa/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/fhsa/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/fhsa/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/fhsa/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/fhsa/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Недвижимость в Торонто`}
  description={articleDescription}
  lang="ru"
  bodyClass="ru guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/russian/blog" class="back-link">Блог</a> · Первым покупателям</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">FHSA — лучший сберегательный инструмент из тех, что когда-либо были у первых покупателей в Канаде. Налоговый вычет при взносе, безналоговый вывод. Разбираем, как работает, кто подходит, и как сочетать с HBP для максимального первоначального взноса.</p>
        <div class="article-byline">
          <span>Автор <a href="/russian/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-09</time>
          <span class="dot">·</span>
          <span>5 мин чтения</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>На этой странице</h4>
            <ul>
              <li><a href="#what">Что это</a></li>
              <li><a href="#who">Кто подходит</a></li>
              <li><a href="#limits">Лимиты</a></li>
              <li><a href="#stack">Сочетание с HBP</a></li>
              <li><a href="#watch">На что обратить внимание</a></li>
              <li><a href="#read-full">Читать полное руководство на английском →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Годовой взнос</span><span class="qf-val">8 000 $</span></div>
              <div class="qf-row"><span class="qf-label">Пожизненный лимит</span><span class="qf-val">40 000 $</span></div>
              <div class="qf-row"><span class="qf-label">Вход</span><span class="qf-val">Налоговый вычет (как RRSP)</span></div>
              <div class="qf-row"><span class="qf-label">Выход</span><span class="qf-val">Без налогов (как TFSA)</span></div>
              <div class="qf-row"><span class="qf-label">Комбинация</span><span class="qf-val">С HBP — до ~60 000 $ вместе</span></div>
            </div>


            <h2 id="what">Что это</h2>
            <p>FHSA — <strong>федеральный регистрированный счёт</strong>, доступный только первым покупателям. Он объединяет <strong>лучшее от RRSP и TFSA</strong>: вычет при взносе, полностью безналоговый вывод — при условии покупки подходящего основного жилья.</p>

            <h2 id="who">Кто подходит</h2>
            <p>Нужно быть <strong>резидентом Канады</strong>, возраст 18–71, и ни вы, ни супруг(а) не владели <strong>основным жильём в последние 4 года</strong>.</p>

            <h2 id="limits">Лимиты</h2>
            <p><strong>8 000 $ в год</strong>, пожизненный максимум — <strong>40 000 $</strong>. Неиспользованные лимиты переносятся (до одного года переноса). Счёт можно держать до 15 лет.</p>

            <h2 id="stack">Сочетание с HBP</h2>
            <p>FHSA и HBP можно использовать <strong>одновременно</strong>. Максимум для одного покупателя — около 60 000 $, для пары — до 120 000 $. Это база максимально возможного первоначального взноса.</p>

            <h2 id="watch">На что обратить внимание</h2>
            <p>Если деньги не пошли на дом, их можно <strong>без налогов</strong> перевести в RRSP или RRIF; при прямом снятии они облагаются налогом. Открывайте счёт заранее, чтобы копить право на взнос.</p>

            <div id="read-full" class="read-full-cta">
              <p>Полная версия этого руководства (цифры, исключения, пошаговые действия) — на английском:</p>
              <a class="btn-primary" href={enUrl}>Читать полное руководство на английском →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
