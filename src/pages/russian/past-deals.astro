const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="\u0418\u0441\u0442\u043e\u0440\u0438\u044f \u043f\u0440\u043e\u0434\u0430\u0436 \u2014 Peter Law \u041d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c \u0422\u043e\u0440\u043e\u043d\u0442\u043e" description="\u0420\u0435\u0433\u0438\u0441\u0442\u0440 \u043d\u0435\u0434\u0430\u0432\u043d\u0438\u0445 \u0430\u0440\u0435\u043d\u0434 \u0438 \u043f\u0440\u043e\u0434\u0430\u0436, \u0437\u0430\u043a\u0440\u044b\u0442\u044b\u0445 Peter Law \u0432 \u0411\u043e\u043b\u044c\u0448\u043e\u043c \u0422\u043e\u0440\u043e\u043d\u0442\u043e." lang="ru" bodyClass="ru">
