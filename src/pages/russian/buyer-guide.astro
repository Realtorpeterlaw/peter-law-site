---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangTopBar from '../../components/RussianTopBar.astro';
import LangHeader from '../../components/RussianHeader.astro';
import LangFooter from '../../components/RussianFooter.astro';
import LangCTA from '../../components/RussianCTASection.astro';
---
<BaseLayout title="\u0413\u0438\u0434 \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u0435\u043b\u044f \u2014 Peter Law \u00b7 \u041d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c \u0422\u043e\u0440\u043e\u043d\u0442\u043e" description="\u041f\u043e\u043b\u043d\u044b\u0439 \u0433\u0438\u0434 \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u0435\u043b\u044f \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u0438 \u0432 \u0422\u043e\u0440\u043e\u043d\u0442\u043e." lang="ru" bodyClass="ru">
  <LangTopBar />
  <LangHeader active="buyers" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Покупатели · Гид</div>
      <h1>Покупать в Торонто — без сюрпризов.</h1>
      <p>От предодобрения до передачи ключей.</p>
    </div>
  </section>

  <section class="major">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side"><h4>—</h4><ul>
          <li><a href="#preapproval">1. Предодобрение</a></li>
          <li><a href="#search">2. Поиск</a></li>
          <li><a href="#offer">3. Оффер</a></li>
          <li><a href="#inspection">4. Инспекция</a></li>
          <li><a href="#closing">5. Закрытие</a></li>
        </ul></aside>
        <div class="prose-body">
          <h2 id="preapproval">1. Предодобрение</h2>
          <p>До показов знайте, сколько занять. Письмо фиксирует ставку на 90-120 дней.</p>
          <h2 id="search">2. Поиск</h2>
          <p>Ежедневный список: критерии, район, цена.</p>
          <h2 id="offer">3. Оффер</h2>
          <p>На аукционах требуется твёрдый оффер. Депозит обычно 5%.</p>
          <h2 id="inspection">4. Инспекция</h2>
          <p>Инспектор (300-500 $) оценивает структуру, крышу, HVAC.</p>
          <h2 id="closing">5. Закрытие</h2>
          <p>Адвокат переводит остаток, оплачивает налоги, передаёт ключи.</p>
        </div>
      </div>
    </div>
  </section>

  <LangCTA heading="\u0413\u043e\u0442\u043e\u0432\u044b \u043d\u0430\u0447\u0430\u0442\u044c \u043f\u043e\u0438\u0441\u043a?" lead="15 \u043c\u0438\u043d\u0443\u0442 \u2014 \u0447\u0442\u043e\u0431\u044b \u043f\u043e\u043d\u044f\u0442\u044c \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044e \u0438 \u043f\u043b\u0430\u043d." />
  <LangFooter />
</BaseLayout>
