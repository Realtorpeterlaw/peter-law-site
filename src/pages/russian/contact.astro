---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RussianTopBar from '../../components/RussianTopBar.astro';
import RussianHeader from '../../components/RussianHeader.astro';
import RussianFooter from '../../components/RussianFooter.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
const FORMSPREE_ENDPOINT = "https://formspree.io/f/xnjrzgda";
---
<BaseLayout title="Контакты — Peter Law · Недвижимость Торонто" description="Свяжитесь с Peter Law. Электронная почта, SMS, или запишитесь на 15-минутный звонок." lang="ru" bodyClass="ru">

  <RussianTopBar />
  <RussianHeader active="contact" ctaLabel="Или записаться на звонок" />

  <section class="page-hero"><div class="wrap"><div class="eyebrow">Свяжитесь со мной</div><h1>Самый быстрый способ получить реальные ответы.</h1><p>Отправьте сообщение, SMS, или запишитесь на звонок.</p></div></section>

  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="contact-grid">
    <form class="contact-form" method="POST" action={FORMSPREE_ENDPOINT}>
      <div class="form-row"><label for="name">Имя <span class="required">*</span></label><input id="name" name="name" type="text" autocomplete="name" required /></div>
      <div class="form-row"><label for="email">Электронная почта <span class="required">*</span></label><input id="email" name="email" type="email" autocomplete="email" required /></div>
      <div class="form-row"><label for="phone">Телефон <span class="required">*</span></label><input id="phone" name="phone" type="tel" autocomplete="tel" required /></div>
      <div class="form-row"><label for="message">Что вам нужно? <span class="required">*</span></label><textarea id="message" name="message" rows="6" required placeholder="Целевой район, сроки, всё, что мне следует знать."></textarea></div>
      <div class="hp-field" aria-hidden="true"><label for="gotcha">Не заполняйте</label><input id="gotcha" name="_gotcha" type="text" tabindex="-1" autocomplete="off"></div>
      <input type="hidden" name="_subject" value="Новое сообщение (русский)">
      <input type="hidden" name="_next" value="https://www.realtorpeterlaw.com/contact/thanks">
      <button type="submit" class="btn-primary">Отправить<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
    </form>
    <aside class="contact-side">
      <div class="contact-block"><div class="contact-lbl">Записаться на звонок</div><a href={BOOKING_URL} class="btn-secondary">15 мин · Google Meet или телефон · Бесплатно</a></div>
      <div class="contact-block"><span class="contact-lbl">Телефон / SMS</span><a href="tel:+16478888472">647-888-8472</a></div>
      <div class="contact-block"><span class="contact-lbl">Электронная почта</span><a href="mailto:Admin@RealtorPeterLaw.com">Admin@RealtorPeterLaw.com</a></div>
      <div class="contact-block"><span class="contact-lbl">Брокерская компания</span><p>HomeLife Golconda Realty Inc.<br>215 – 3601 HWY 7 East<br>Markham, ON L3R 0M3</p></div>
    </aside>
  </div></div></section>

  <RussianFooter />
</BaseLayout>
