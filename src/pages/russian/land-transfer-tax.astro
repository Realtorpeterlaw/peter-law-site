---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/RussianTopBar.astro';
import LHeader from '../../components/RussianHeader.astro';
import LFooter from '../../components/RussianFooter.astro';
import LCTA from '../../components/RussianCTASection.astro';
export const prerender = true;
---
<BaseLayout title="\u041d\u0430\u043b\u043e\u0433 \u043d\u0430 \u043f\u0435\u0440\u0435\u0434\u0430\u0447\u0443 \u2014 \u041e\u043d\u0442\u0430\u0440\u0438\u043e + \u0422\u043e\u0440\u043e\u043d\u0442\u043e | Peter Law" description="\u0420\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u0439\u0442\u0435 \u043d\u0430\u043b\u043e\u0433 \u043d\u0430 \u043f\u0435\u0440\u0435\u0434\u0430\u0447\u0443 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u0438 (LTT) \u043f\u0440\u043e\u0432\u0438\u043d\u0446\u0438\u0430\u043b\u044c\u043d\u044b\u0439 \u0438 \u043c\u0443\u043d\u0438\u0446\u0438\u043f\u0430\u043b\u044c\u043d\u044b\u0439. \u0412\u043e\u0437\u0432\u0440\u0430\u0442 \u0434\u043b\u044f \u043f\u0435\u0440\u0432\u043e\u0433\u043e \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u0435\u043b\u044f \u0432\u043a\u043b\u044e\u0447\u0451\u043d." lang="ru" bodyClass="ru">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Покупатели · Налог на передачу</div><h1>Налог на передачу недвижимости</h1><p>Каждая покупка недвижимости в Онтарио облагается провинциальным налогом на передачу. Покупатели в Торонто также платят муниципальный (MLTT). Первые покупатели получают частичный возврат.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="calc">
    <div class="calc-fields">
      <div class="calc-field calc-field-full"><label for="ltt-price">Цена покупки</label><div class="input-prefix"><input type="number" id="ltt-price" value="900000" min="0" step="5000" /></div></div>
      <div class="calc-field"><label for="ltt-toronto">Местоположение</label><select id="ltt-toronto"><option value="yes" selected>Город Торонто</option><option value="no">Остальная часть Онтарио</option></select></div>
      <div class="calc-field"><label for="ltt-fthb">Первый покупатель?</label><select id="ltt-fthb"><option value="yes" selected>Да</option><option value="no">Нет</option></select></div>
    </div>
    <div class="calc-result">
      <div class="calc-result-main"><span class="label">Итого к оплате</span><span id="ltt-total">$0</span></div>
      <div class="calc-result-breakdown">
        <div class="row"><span>LTT Онтарио</span><strong id="ltt-ont">$0</strong></div>
        <div class="row" id="ltt-mltt-row"><span>MLTT Торонто</span><strong id="ltt-mltt">$0</strong></div>
        <div class="row" id="ltt-rebate-row" style="display:none;"><span>Возврат первому покупателю</span><strong id="ltt-rebate">−$0</strong></div>
      </div>
    </div>
    <p class="calc-disclaimer">В качестве ориентира. Используются ставки 2026. Уточните финальные цифры у адвоката.</p>
  </div></div></section>
  <LCTA />
  <LFooter />
  <script is:inline>
    (function(){
      function fmt(n){return (n||0).toLocaleString('en-CA',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function ontLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000)t+=(p-2000000)*.025;return t;}
      function torMLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000){const lx=[[3000000,.025],[4000000,.035],[5000000,.045],[10000000,.055],[20000000,.065]];let l=2000000;for(const[u,r]of lx){if(p>l){const x=Math.min(p,u)-l;if(x>0)t+=x*r;}l=u;}if(p>20000000)t+=(p-20000000)*.075;}return t;}
      function c(){const p=parseFloat(document.getElementById('ltt-price').value)||0;const isTo=document.getElementById('ltt-toronto').value==='yes';const fthb=document.getElementById('ltt-fthb').value==='yes';const o=ontLTT(p);const m=isTo?torMLTT(p):0;let re=0;if(fthb){re=Math.min(o,4000);if(isTo)re+=Math.min(m,4475);}const t=Math.max(0,o+m-re);document.getElementById('ltt-total').textContent=fmt(t);document.getElementById('ltt-ont').textContent=fmt(o);document.getElementById('ltt-mltt').textContent=fmt(m);document.getElementById('ltt-mltt-row').style.display=isTo?'':'none';if(re>0){document.getElementById('ltt-rebate-row').style.display='';document.getElementById('ltt-rebate').textContent='−'+fmt(re);}else{document.getElementById('ltt-rebate-row').style.display='none';}}
      ['ltt-price','ltt-toronto','ltt-fthb'].forEach(id=>{const el=document.getElementById(id);el.addEventListener('input',c);el.addEventListener('change',c);});c();
    })();
  </script>
</BaseLayout>
