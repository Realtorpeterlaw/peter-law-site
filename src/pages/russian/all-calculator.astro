---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/RussianTopBar.astro';
import LHeader from '../../components/RussianHeader.astro';
import LFooter from '../../components/RussianFooter.astro';
import LCTA from '../../components/RussianCTASection.astro';
export const prerender = true;
---
<BaseLayout title="\u041a\u0430\u043b\u044c\u043a\u0443\u043b\u044f\u0442\u043e\u0440 \u041f\u041e\u041a\u0423\u041f\u041a\u0418 \u2014 \u0438\u043f\u043e\u0442\u0435\u043a\u0430, LTT, CMHC, \u0440\u0430\u0441\u0445\u043e\u0434\u044b \u043d\u0430 \u0437\u0430\u043a\u0440\u044b\u0442\u0438\u0435 | Peter Law" description="\u041e\u0434\u043d\u0430 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0430. \u0412\u0432\u0435\u0434\u0438\u0442\u0435 \u0434\u043e\u0445\u043e\u0434, \u0446\u0435\u043d\u0443 \u0434\u043e\u043c\u0430 \u0438 \u0432\u0430\u0448\u0438 \u0441\u0431\u0435\u0440\u0435\u0436\u0435\u043d\u0438\u044f. \u0423\u0432\u0438\u0434\u0438\u0442\u0435 \u0435\u0436\u0435\u043c\u0435\u0441\u044f\u0447\u043d\u044b\u0439 \u043f\u043b\u0430\u0442\u0451\u0436, \u043d\u0430\u043b\u043e\u0433 \u043d\u0430 \u043f\u0435\u0440\u0435\u0434\u0430\u0447\u0443, \u0441\u0442\u0440\u0430\u0445\u043e\u0432\u0430\u043d\u0438\u0435 \u0438\u043f\u043e\u0442\u0435\u043a\u0438, \u0440\u0430\u0441\u0445\u043e\u0434\u044b \u043d\u0430 \u0437\u0430\u043a\u0440\u044b\u0442\u0438\u0435." lang="ru" bodyClass="ru">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Калькулятор ПОКУПКИ</div><h1>Простой и удобный генератор расчётов</h1><p>Свяжитесь с PETER для получения дополнительной информации о ПОКУПКЕ и ФИНАНСИРОВАНИИ. Может быть рекомендован ипотечный брокер.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="ac-shell">
    <div class="ac-inputs">
      <div class="ac-input-group"><label>1. Сколько зарабатываете в год? <span class="hint">До налогов.</span></label><div class="input-prefix"><input type="number" id="ac-income" value="250000" min="0" step="1000" /></div></div>
      <div class="ac-input-group"><label>2. Одобренная цена дома <span class="hint">Кондо, таунхаус или дом.</span></label><div class="input-prefix"><input type="number" id="ac-price" value="1000000" min="0" step="5000" /></div></div>
      <div class="ac-input-group"><label>3. Первоначальный взнос <span class="hint">Идеально 20-25% от цены покупки.</span></label><div class="input-prefix"><input type="number" id="ac-savings" value="100000" min="0" step="1000" /></div></div>
      <div class="ac-input-group ac-checkbox-group"><label class="ac-checkbox"><input type="checkbox" id="ac-fthb" checked /><span class="ac-checkbox-text">Я покупатель первого жилья <span class="hint">Даёт возврат налога на передачу.</span></span></label></div>
      <div class="ac-input-group"><label>4. Тип недвижимости <span class="hint">Определяет применяемые ежемесячные расходы.</span></label><select id="ac-proptype"><option value="freehold" selected>Свободное владение (Дом)</option><option value="freehold-hoa">Свободное владение с HOA</option><option value="condo">Кондо</option></select></div>
      <div class="ac-input-group" id="ac-tax-row"><label>5. Налог на недвижимость <span class="hint">В месяц. Оставьте пустым — авто-оценка 0.7% от цены / год.</span></label><div class="input-prefix"><input type="number" id="ac-proptax" value="" min="0" step="5" placeholder="e.g. 400" /></div></div>
      <div class="ac-input-group" id="ac-fee-row" style="display:none;"><label id="ac-fee-label">6. Плата HOA <span class="hint">В месяц. Спрашивайте перед подписью — некоторые включают отопление, воду или электричество.</span></label><div class="input-prefix"><input type="number" id="ac-fee" value="" min="0" step="5" placeholder="e.g. 150" /></div></div>
      <details class="ac-more"><summary>Дополнительные опции</summary><div class="ac-more-body">
        <div class="ac-input-group"><label>Ставка ипотеки <span class="hint">5% нормально в 2026.</span></label><div class="input-suffix"><input type="number" id="ac-rate" value="5.0" min="0" step="0.05" /></div></div>
        <div class="ac-input-group"><label>Амортизация</label><select id="ac-amort"><option value="20">20</option><option value="25" selected>25</option><option value="30">30</option></select></div>
        <div class="ac-input-group"><label>Где находится недвижимость?</label><select id="ac-location"><option value="toronto" selected>Город Торонто</option><option value="ontario">Остальная часть Онтарио</option></select></div>
      </div></details>
    </div>
    <div class="ac-results">
      <div class="ac-headline">
        <div class="ac-headline-item"><div class="ac-headline-label">Ваш ежемесячный платёж</div><div class="ac-headline-value" id="ac-monthly">$0</div><div class="ac-headline-sub">Только ипотека. См. разбивку для общей ежемесячной стоимости.</div></div>
        <div class="ac-headline-item"><div class="ac-headline-label">Наличные, необходимые на закрытие</div><div class="ac-headline-value" id="ac-cash">$0</div><div class="ac-headline-sub">Первоначальный взнос + налог на передачу + адвокат + корректировки.</div></div>
      </div>
      <div class="ac-verdict" id="ac-verdict"><span class="ac-verdict-dot"></span><div><div class="ac-verdict-title" id="ac-verdict-title">Введите ваши числа выше.</div><div class="ac-verdict-sub" id="ac-verdict-sub">Банк смотрит, какая часть вашего дохода идёт на жильё. Менее 32% безопасно. Более 39% — банк, вероятно, откажет.</div></div></div>
      <h3 class="ac-section-h">Куда уходят деньги</h3>
      <div class="ac-breakdown">
        <div class="ac-row"><span>Первоначальный взнос</span><strong id="ac-down">$0</strong></div>
        <div class="ac-row"><span>Общая ипотека</span><strong id="ac-mortgage">$0</strong></div>
        <div class="ac-row"><span>CMHC / страхование по умолчанию <em class="ac-note" id="ac-cmhc-note"></em></span><strong id="ac-cmhc">$0</strong></div>
        <div class="ac-row"><span>Налог на передачу Онтарио</span><strong id="ac-ltt-on">$0</strong></div>
        <div class="ac-row" id="ac-ltt-mltt-row"><span>Налог на передачу Торонто</span><strong id="ac-ltt-mltt">$0</strong></div>
        <div class="ac-row" id="ac-ltt-rebate-row" style="display:none;"><span>Возврат первому покупателю</span><strong id="ac-ltt-rebate">−$0</strong></div>
        <div class="ac-row" id="ac-mo-taxrow"><span>Ежемесячный налог на недвижимость (оценка)</span><strong id="ac-mo-tax">$0</strong></div>
        <div class="ac-row" id="ac-mo-feerow" style="display:none;"><span id="ac-mo-feelbl">Ежемесячная плата HOA</span><strong id="ac-mo-fee">$0</strong></div>
        <div class="ac-row"><span>Юр. услуги + право + корректировки <em class="ac-note">приблизительно</em></span><strong id="ac-legal">$0</strong></div>
        <div class="ac-row ac-row-total"><span>Прибл. общая наличность на закрытие</span><strong id="ac-total-cash">~$0</strong></div>
      </div>
      <p class="calc-disclaimer">Числа ориентировочные. См. <a href="/disclaimer#calculators">Отказ от ответственности</a>.</p>
    </div>
  </div></div></section>
  <LCTA heading="\u0425\u043e\u0442\u0438\u0442\u0435 \u043f\u0440\u043e\u0439\u0442\u0438 \u0447\u0435\u0440\u0435\u0437 \u0440\u0435\u0430\u043b\u044c\u043d\u044b\u0435 \u0447\u0438\u0441\u043b\u0430?" lead="\u041f\u0440\u0438\u043d\u0435\u0441\u0438\u0442\u0435 \u0432\u0430\u0448 \u0434\u043e\u0445\u043e\u0434 \u0438 \u0440\u0430\u0439\u043e\u043d. 15 \u043c\u0438\u043d\u0443\u0442 \u043f\u043e \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0443 \u2014 \u0438 \u0432\u044b \u0431\u0443\u0434\u0435\u0442\u0435 \u0437\u043d\u0430\u0442\u044c, \u043a\u0430\u043a\u043e\u0439 \u0446\u0435\u043d\u043e\u0432\u043e\u0439 \u0434\u0438\u0430\u043f\u0430\u0437\u043e\u043d \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442 \u0438\u043c\u0435\u043d\u043d\u043e \u0432\u0430\u043c." />
  <LFooter />

  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('en-CA',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function pRate(r,n){const s=r/200;return Math.pow(1+s,2/n)-1;}
      function mPay(p,r,y){if(p<=0||y<=0)return 0;const rr=pRate(r,12),n=y*12;if(rr===0)return p/n;return p*rr/(1-Math.pow(1+rr,-n));}
      function cmhc(l){if(l>95)return null;if(l>90)return .04;if(l>85)return .031;if(l>80)return .028;return 0;}
      function minDp(p){if(p>1500000)return p*.2;if(p<=500000)return p*.05;return 500000*.05+(p-500000)*.1;}
      function ontLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000)t+=(p-2000000)*.025;return t;}
      function torMLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000){const lx=[[3000000,.025],[4000000,.035],[5000000,.045],[10000000,.055],[20000000,.065]];let l=2000000;for(const[u,r]of lx){if(p>l){const x=Math.min(p,u)-l;if(x>0)t+=x*r;}l=u;}if(p>20000000)t+=(p-20000000)*.075;}return t;}
      const FT_ONT=4000,FT_TOR=4475;
      const $=id=>document.getElementById(id);
      ['ac-income','ac-price','ac-savings','ac-rate','ac-amort','ac-location','ac-fthb','ac-proptype','ac-proptax','ac-fee'].forEach(id=>{const el=$(id);if(!el)return;el.addEventListener('input',calc);el.addEventListener('change',calc);});
      function calc(){
        const inc=Math.max(0,parseFloat($('ac-income').value)||0);const p=Math.max(0,parseFloat($('ac-price').value)||0);
        const s=Math.max(0,parseFloat($('ac-savings').value)||0);const r=Math.max(0,parseFloat($('ac-rate').value)||0);
        const am=parseInt($('ac-amort').value,10)||25;const loc=$('ac-location').value;const fthb=$('ac-fthb').checked;
        const pt=$('ac-proptype').value;const ptx=parseFloat($('ac-proptax').value);const fee=parseFloat($('ac-fee').value);
        const fr=$('ac-fee-row'),fl=$('ac-fee-label');
        if(pt==='freehold')fr.style.display='none';
        else if(pt==='freehold-hoa'){fr.style.display='';fl.innerHTML="6. \u041f\u043b\u0430\u0442\u0430 HOA"+' <span class="hint">'+"\u0412 \u043c\u0435\u0441\u044f\u0446. \u0421\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0439\u0442\u0435 \u043f\u0435\u0440\u0435\u0434 \u043f\u043e\u0434\u043f\u0438\u0441\u044c\u044e \u2014 \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u043a\u043b\u044e\u0447\u0430\u044e\u0442 \u043e\u0442\u043e\u043f\u043b\u0435\u043d\u0438\u0435, \u0432\u043e\u0434\u0443 \u0438\u043b\u0438 \u044d\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043e."+'</span>';}
        else{fr.style.display='';fl.innerHTML="6. \u041f\u043b\u0430\u0442\u0430 \u0437\u0430 \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u0435"+' <span class="hint">'+"\u0412 \u043c\u0435\u0441\u044f\u0446. \u0421\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0439\u0442\u0435 \u043f\u0435\u0440\u0435\u0434 \u043f\u043e\u0434\u043f\u0438\u0441\u044c\u044e \u2014 \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u043a\u043b\u044e\u0447\u0430\u044e\u0442 \u043e\u0442\u043e\u043f\u043b\u0435\u043d\u0438\u0435, \u0432\u043e\u0434\u0443 \u0438\u043b\u0438 \u044d\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043e."+'</span>';}
        const mDp=minDp(p),ds=Math.min(s,p),sh=Math.max(0,mDp-ds),ad=ds;
        const ltv=p>0?(p-ad)/p*100:0,pr=cmhc(ltv);const bl=Math.max(0,p-ad);
        const cp=(pr!==null&&pr>0)?bl*pr:0;const tm=bl+cp,m=mPay(tm,r,am);
        const ot=ontLTT(p),mt=loc==='toronto'?torMLTT(p):0;
        let re=0;if(fthb){re=Math.min(ot,FT_ONT);if(loc==='toronto')re+=Math.min(mt,FT_TOR);}
        const tl=Math.max(0,ot+mt-re),le=2500,ctc=ad+tl+le;
        const sr=Math.max(r+2,5.25),sp=mPay(tm,sr,am);
        const mi=inc/12,ptm=(isFinite(ptx)&&ptx>=0)?ptx:(p*.007/12);
        const of=(isFinite(fee)&&fee>=0&&pt!=='freehold')?fee:0;
        const hm=pt==='condo'?0:150;const gds=mi>0?(sp+ptm+of+hm)/mi*100:0;
        $('ac-monthly').textContent=fmt(m);$('ac-cash').textContent=fmt(ctc);
        $('ac-down').textContent=fmt(ad);$('ac-mortgage').textContent=fmt(tm);$('ac-cmhc').textContent=fmt(cp);
        $('ac-cmhc-note').textContent=pr===null?"(\u043d\u0435 \u0440\u0430\u0437\u0440\u0435\u0448\u0435\u043d\u043e \u2014 \u043d\u0443\u0436\u043d\u043e \u0435\u0449\u0451 5%)":pr===0?"(\u0432\u0437\u043d\u043e\u0441 20%+ \u2014 \u0441\u0442\u0440\u0430\u0445\u043e\u0432\u043a\u0430 \u043d\u0435 \u043d\u0443\u0436\u043d\u0430)":"({pct}% \u043e\u0442 \u043a\u0440\u0435\u0434\u0438\u0442\u0430)".replace('{pct}',(pr*100).toFixed(2));
        $('ac-ltt-on').textContent=fmt(ot);$('ac-ltt-mltt').textContent=fmt(mt);$('ac-ltt-mltt-row').style.display=loc==='toronto'?'':'none';
        if(re>0){$('ac-ltt-rebate-row').style.display='';$('ac-ltt-rebate').textContent='−'+fmt(re);}else{$('ac-ltt-rebate-row').style.display='none';}
        $('ac-mo-tax').textContent=fmt(ptm)+'/мес';
        const frb=$('ac-mo-feerow');if(pt==='freehold')frb.style.display='none';else{frb.style.display='';$('ac-mo-feelbl').textContent=pt==='condo'?"\u0415\u0436\u0435\u043c\u0435\u0441\u044f\u0447\u043d\u0430\u044f \u043f\u043b\u0430\u0442\u0430 \u0437\u0430 \u043e\u0431\u0441\u043b\u0443\u0436\u0438\u0432\u0430\u043d\u0438\u0435":Ежемесячная плата HOA;$('ac-mo-fee').textContent=fmt(of)+'/мес';}
        $('ac-legal').textContent=fmt(le);$('ac-total-cash').textContent='~'+fmt(ctc);
        let vt,vs,vc;
        if(inc<=0||p<=0){vt=Введите ваши числа выше.;vs=Банк смотрит, какая часть вашего дохода идёт на жильё. Менее 32% безопасно. Более 39% — банк, вероятно, откажет.;vc='ac-verdict-neutral';}
        else if(pr===null){vt="\u041d\u0443\u0436\u043d\u043e \u0431\u043e\u043b\u044c\u0448\u0435 \u0441\u0431\u0435\u0440\u0435\u0436\u0435\u043d\u0438\u0439 \u0434\u043b\u044f \u044d\u0442\u043e\u0439 \u0446\u0435\u043d\u044b.";vs="\u041c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u0437\u043d\u043e\u0441 \u0434\u043b\u044f \u0434\u043e\u043c\u0430 \u043e\u0442 1.5 \u043c\u043b\u043d $ \u2014 20%. \u0412\u044b \u043d\u0438\u0436\u0435. \u041a\u043e\u043f\u0438\u0442\u0435 \u0431\u043e\u043b\u044c\u0448\u0435 \u0438\u043b\u0438 \u0438\u0449\u0438\u0442\u0435 \u0431\u043e\u043b\u0435\u0435 \u043d\u0438\u0437\u043a\u0443\u044e \u0446\u0435\u043d\u0443.";vc='ac-verdict-red';}
        else if(sh>0){vt="\u041d\u0435\u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e \u0441\u0440\u0435\u0434\u0441\u0442\u0432.";vs="\u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044f {mDp}. \u041d\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442 {sh}. \u0411\u0430\u043d\u043a \u043d\u0435 \u043c\u043e\u0436\u0435\u0442 \u043e\u0434\u043e\u0431\u0440\u0438\u0442\u044c.".replace('{mDp}',fmt(mDp)).replace('{sh}',fmt(sh));vc='ac-verdict-red';}
        else if(gds>39){vt="\u0411\u0430\u043d\u043a, \u0432\u0435\u0440\u043e\u044f\u0442\u043d\u043e, \u043d\u0435 \u043e\u0434\u043e\u0431\u0440\u0438\u0442.";vs="\u041f\u0440\u0438 {gds}% \u0436\u0438\u043b\u044c\u0451 \u0441\u044a\u0435\u0434\u0430\u0435\u0442 \u0441\u043b\u0438\u0448\u043a\u043e\u043c \u043c\u043d\u043e\u0433\u043e. \u041f\u043e\u043f\u0440\u043e\u0431\u0443\u0439\u0442\u0435 \u0431\u043e\u043b\u0435\u0435 \u043d\u0438\u0437\u043a\u0443\u044e \u0446\u0435\u043d\u0443 \u0438\u043b\u0438 \u0431\u043e\u043b\u044c\u0448\u0435 \u0432\u0437\u043d\u043e\u0441\u0430.".replace('{gds}',gds.toFixed(1));vc='ac-verdict-red';}
        else if(gds>32){vt="\u041d\u0430\u043f\u0440\u044f\u0436\u0451\u043d\u043d\u043e. \u0412\u043e\u0437\u043c\u043e\u0436\u043d\u043e, \u043d\u043e \u043f\u043e\u0447\u0443\u0432\u0441\u0442\u0432\u0443\u0435\u0442\u0435.";vs="\u041f\u0440\u0438 {gds}% \u0432\u044b \u0432 \u0436\u0451\u0441\u0442\u043a\u043e\u043c \u043b\u0438\u043c\u0438\u0442\u0435 \u0431\u0430\u043d\u043a\u0430 (39%), \u043d\u043e \u0432\u044b\u0448\u0435 \u043a\u043e\u043c\u0444\u043e\u0440\u0442\u043d\u043e\u0439 \u0437\u043e\u043d\u044b (32%).".replace('{gds}',gds.toFixed(1));vc='ac-verdict-yellow';}
        else{vt="\u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0441\u0435\u0431\u0435 \u044d\u0442\u043e \u043f\u043e\u0437\u0432\u043e\u043b\u0438\u0442\u044c.";vs="\u041f\u0440\u0438 {gds}% \u0436\u0438\u043b\u044c\u0451 \u043a\u043e\u043c\u0444\u043e\u0440\u0442\u043d\u043e \u0432 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0439 \u0437\u043e\u043d\u0435.".replace('{gds}',gds.toFixed(1));vc='ac-verdict-green';}
        const v=$('ac-verdict');v.classList.remove('ac-verdict-neutral','ac-verdict-green','ac-verdict-yellow','ac-verdict-red');v.classList.add(vc);
        $('ac-verdict-title').textContent=vt;$('ac-verdict-sub').textContent=vs;
      }
      calc();
    })();
  </script>
