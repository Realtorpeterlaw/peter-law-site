---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangTopBar from '../../components/RussianTopBar.astro';
import LangHeader from '../../components/RussianHeader.astro';
import LangFooter from '../../components/RussianFooter.astro';
import LangCTA from '../../components/RussianCTASection.astro';
---
<BaseLayout title="\u0414\u043b\u044f \u0430\u0440\u0435\u043d\u0434\u043e\u0434\u0430\u0442\u0435\u043b\u0435\u0439 \u2014 Peter Law \u00b7 \u0410\u0440\u0435\u043d\u0434\u0430 \u0432 \u0422\u043e\u0440\u043e\u043d\u0442\u043e" description="\u0421\u0434\u0430\u0451\u0442\u0435 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c \u0432 \u0422\u043e\u0440\u043e\u043d\u0442\u043e? \u041a\u0430\u043a \u044f \u043d\u0430\u0445\u043e\u0436\u0443 \u0430\u0440\u0435\u043d\u0434\u0430\u0442\u043e\u0440\u0430 AAA." lang="ru" bodyClass="ru">
  <LangTopBar />
  <LangHeader active="rental" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Аренда · Арендодатели</div>
      <h1>Сдавайте быстрее. С правильным арендатором.</h1>
      <p>Скорость и полнота выигрывают объявления. Досье в 48 часов после показа.</p>
    </div>
  </section>

  <section class="major">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side"><h4>—</h4><ul>
          <li><a href="#pricing">Цена</a></li>
          <li><a href="#staging">Маркетинг</a></li>
          <li><a href="#screening">Отбор</a></li>
          <li><a href="#lease">Договор</a></li>
        </ul></aside>
        <div class="prose-body">
          <h2 id="pricing">Цена</h2>
          <p>Слишком низко — теряете деньги. Слишком высоко — стоит 6 недель.</p>
          <h2 id="staging">Маркетинг</h2>
          <p>Профессиональные фото, размещение на TRREB / MLS® / Realtor.ca.</p>
          <h2 id="screening">Отбор</h2>
          <p>Проверяю каждую заявку: работодатель, кредит, предыдущий арендодатель.</p>
          <h2 id="lease">Договор</h2>
          <p>Стандартный договор Онтарио (форма 2229E) заполненный правильно.</p>
        </div>
      </div>
    </div>
  </section>

  <LangCTA heading="\u0413\u043e\u0442\u043e\u0432\u044b \u0441\u0434\u0430\u0442\u044c \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c?" lead="\u041f\u0440\u0438\u0448\u043b\u0438\u0442\u0435 \u0430\u0434\u0440\u0435\u0441. \u041e\u0442\u0432\u0435\u0447\u0443 \u0432 24 \u0447\u0430\u0441\u0430 \u0441 \u0446\u0435\u043d\u043e\u0439 \u0438 \u043f\u043b\u0430\u043d\u043e\u043c." />
  <LangFooter />
</BaseLayout>
