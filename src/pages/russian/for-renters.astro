---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangTopBar from '../../components/RussianTopBar.astro';
import LangHeader from '../../components/RussianHeader.astro';
import LangFooter from '../../components/RussianFooter.astro';
import LangCTA from '../../components/RussianCTASection.astro';
---
<BaseLayout title="\u0414\u043b\u044f \u0430\u0440\u0435\u043d\u0434\u0430\u0442\u043e\u0440\u043e\u0432 \u2014 Peter Law \u00b7 \u0410\u0440\u0435\u043d\u0434\u0430 \u0432 \u0422\u043e\u0440\u043e\u043d\u0442\u043e" description="\u0418\u0449\u0435\u0442\u0435 \u0430\u0440\u0435\u043d\u0434\u0443 \u0432 \u0422\u043e\u0440\u043e\u043d\u0442\u043e? \u041a\u0430\u043a \u044f \u043f\u043e\u043c\u043e\u0433\u0430\u044e \u0431\u044b\u0441\u0442\u0440\u043e \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c \u043e\u0434\u043e\u0431\u0440\u0435\u043d\u0438\u0435." lang="ru" bodyClass="ru">
  <LangTopBar />
  <LangHeader active="rental" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Аренда · Арендаторы</div>
      <h1>Аренда в Торонто — одобрение быстро, заселение спокойно.</h1>
      <p>Рынок аренды Торонто движется быстро. День колебаний — и квартира ушла.</p>
    </div>
  </section>

  <section class="major">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side"><h4>—</h4><ul>
          <li><a href="#search">Поиск</a></li>
          <li><a href="#application">Заявка</a></li>
          <li><a href="#negotiation">Переговоры</a></li>
          <li><a href="#moveIn">Заселение</a></li>
        </ul></aside>
        <div class="prose-body">
          <h2 id="search">Поиск</h2>
          <p>Каждый день короткий список по вашим критериям.</p>
          <h2 id="application">Заявка</h2>
          <p>Слабое досье не проходит. Сильное — свежее письмо от работодателя, кредитный рейтинг — проходит.</p>
          <h2 id="negotiation">Переговоры</h2>
          <p>По цене, но также по включениям (отопление, вода, интернет) и дате въезда.</p>
          <h2 id="moveIn">Заселение</h2>
          <p>Координирую подписание, приёмку, перенос коммунальных услуг.</p>
        </div>
      </div>
    </div>
  </section>

  <LangCTA heading="\u0413\u043e\u0442\u043e\u0432\u044b \u043d\u0430\u0447\u0430\u0442\u044c \u043f\u043e\u0438\u0441\u043a?" lead="\u041e\u0442\u043f\u0440\u0430\u0432\u044c\u0442\u0435 \u043a\u0440\u0438\u0442\u0435\u0440\u0438\u0438. \u041e\u0442\u0432\u0435\u0447\u0443 \u0432 24 \u0447\u0430\u0441\u0430 \u0441 5-8 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u0430\u043c\u0438." />
  <LangFooter />
</BaseLayout>
