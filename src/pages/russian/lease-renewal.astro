---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/RussianTopBar.astro';
import LHeader from '../../components/RussianHeader.astro';
import LFooter from '../../components/RussianFooter.astro';
import LCTA from '../../components/RussianCTASection.astro';
---
<BaseLayout title="\u041f\u0440\u043e\u0434\u043b\u0435\u043d\u0438\u0435 \u0430\u0440\u0435\u043d\u0434\u044b \u0432 \u041e\u043d\u0442\u0430\u0440\u0438\u043e | Peter Law" description="\u0427\u0442\u043e \u043f\u0440\u043e\u0438\u0441\u0445\u043e\u0434\u0438\u0442 \u0432 \u043a\u043e\u043d\u0446\u0435 \u0432\u0430\u0448\u0435\u0433\u043e \u0441\u0440\u043e\u0447\u043d\u043e\u0433\u043e \u0434\u043e\u0433\u043e\u0432\u043e\u0440\u0430, \u0432\u0430\u0448\u0435 \u043f\u0440\u0430\u0432\u043e \u043e\u0441\u0442\u0430\u0442\u044c\u0441\u044f, \u043f\u0440\u0430\u0432\u0438\u043b\u0430 \u0430\u0440\u0435\u043d\u0434\u043d\u043e\u0439 \u043f\u043b\u0430\u0442\u044b." lang="ru" bodyClass="ru">
  <LTopBar />
  <LHeader active="rental" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Ресурс арендатора</div>
      <h1>Продление аренды в Онтарио.</h1>
      <p>Что происходит по окончании срочного договора, ваше право остаться, правила арендной платы, и что делать если арендодатель хочет вас выселить.</p>
    </div>
  </section>

  <section class="major" style="padding-top:32px;">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side">
          <h4>—</h4>
          <ul>          <li><a href="#default">По умолчанию: помесячно</a></li>
          <li><a href="#stay">Ваше право остаться</a></li>
          <li><a href="#rent">Арендная плата при продлении</a></li>
          <li><a href="#endout">Если арендодатель хочет вас выселить</a></li>
          <li><a href="#leave">Если вы хотите уехать</a></li></ul>
        </aside>
        <div class="prose-body">
          <h2 id="default">По умолчанию: помесячно</h2>
          <p>В Онтарио по окончании срочного договора (обычно 12 месяцев) <strong>договор не заканчивается</strong>. Он автоматически преобразуется в помесячную аренду на тех же условиях. Не нужно ничего подписывать. Не нужно разрешение арендодателя.</p>
          <h2 id="stay">Ваше право остаться</h2>
          <p>Арендодатель <strong>не может заставить вас подписать новый срочный договор</strong>. Вы можете платить помесячно бесконечно.</p>
          <h2 id="rent">Арендная плата при продлении</h2>
          <p>Плата может расти только раз в 12 месяцев. Для контролируемых юнитов — по годовой директиве. Уведомление за 90 дней на форме N1 LTB.</p>
          <h2 id="endout">Если арендодатель хочет вас выселить</h2>
          <p>Нужны <strong>законные основания</strong> (N12 для личного использования, N13 для крупного ремонта). Устное уведомление недействительно.</p>
          <h2 id="leave">Если вы хотите уехать</h2>
          <p>На помесячной аренде дайте <strong>письменное уведомление за 60 дней</strong>, заканчивающееся в последний день месяца аренды (форма N9).</p>
        </div>
      </div>
    </div>
  </section>

  <LCTA heading="\u0414\u043e\u0433\u043e\u0432\u043e\u0440 \u0441\u043a\u043e\u0440\u043e \u0438\u0441\u0442\u0435\u043a\u0430\u0435\u0442?" lead="\u041e\u0442\u043f\u0440\u0430\u0432\u044c\u0442\u0435 \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u044b \u2014 \u0437\u0430 10 \u043c\u0438\u043d\u0443\u0442 \u0441\u043a\u0430\u0436\u0443, \u043e\u0441\u0442\u0430\u0432\u0430\u0442\u044c\u0441\u044f, \u043f\u0435\u0440\u0435\u0441\u043c\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044c \u0438\u043b\u0438 \u043f\u0435\u0440\u0435\u0435\u0437\u0436\u0430\u0442\u044c." />
  <LFooter />
</BaseLayout>
