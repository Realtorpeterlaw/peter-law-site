---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/RussianTopBar.astro';
import LHeader from '../../components/RussianHeader.astro';
import LFooter from '../../components/RussianFooter.astro';
import LCTA from '../../components/RussianCTASection.astro';
---
<BaseLayout title="\u0411\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u0430\u044f \u043e\u0446\u0435\u043d\u043a\u0430 \u2014 \u0421\u043a\u043e\u043b\u044c\u043a\u043e \u0441\u0442\u043e\u0438\u0442 \u0432\u0430\u0448\u0430 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c \u0432 \u0422\u043e\u0440\u043e\u043d\u0442\u043e? | Peter Law" description="\u041f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u0443\u044e \u043e\u0446\u0435\u043d\u043a\u0443 \u0442\u0435\u043a\u0443\u0449\u0435\u0439 \u0440\u044b\u043d\u043e\u0447\u043d\u043e\u0439 \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u0438 \u0432\u0430\u0448\u0435\u0439 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u0438 \u0432 \u0422\u043e\u0440\u043e\u043d\u0442\u043e. \u041f\u043e\u0434\u0440\u043e\u0431\u043d\u0430\u044f CMA \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 48 \u0447\u0430\u0441\u043e\u0432." lang="ru" bodyClass="ru">
  <LTopBar />
  <LHeader active="sellers" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Бесплатная оценка</div>
      <h1>Сколько на самом деле стоит ваш дом сегодня?</h1>
      <p>Подробный сравнительный анализ рынка от агента, знающего ваш район. Бесплатно, без обязательств, за 48 часов.</p>
    </div>
  </section>

  <section class="major" style="padding-top:32px;">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side">
          <h4>—</h4>
          <ul>          <li><a href="#what">Что вы получите</a></li>
          <li><a href="#how">Как это работает</a></li>
          <li><a href="#why">Почему через меня</a></li>
          <li><a href="#form">Запросить оценку</a></li></ul>
        </aside>
        <div class="prose-body">
          <h2 id="what">Что вы получите</h2>
          <p><strong>Подробную CMA</strong> — недавние продажи сопоставимых юнитов в радиусе 1 км, скорректированные по размеру, состоянию, удобствам. <strong>Реалистичный диапазон цен</strong> — низкий, ожидаемый, амбициозный. <strong>Рекомендации по максимизации стоимости</strong>. <strong>Честный срок</strong> — сколько времени продаются похожие объекты.</p>
          <h2 id="how">Как это работает</h2>
          <p>1. Заполняете форму ниже (~3 мин). 2. Собираю данные продаж TRREB и активные объявления. 3. Быстрый осмотр или виртуальный обход в течение 24 часов. 4. Отчёт CMA по электронной почте в течение 48 часов.</p>
          <h2 id="why">Почему через меня</h2>
          <p>Я зарегистрированный в RECO Sales Representative в HomeLife Golconda. За CMA не беру плату, потому что 30% продавцов, получивших честную оценку, в итоге нанимают меня для продажи. Никаких навязываний.</p>
          <h2 id="form">Запросить оценку</h2>
          <p>Используйте форму контакта ниже или <a href="/russian/contact">отправьте прямое сообщение</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <LCTA heading="\u0413\u043e\u0442\u043e\u0432\u044b \u0443\u0437\u043d\u0430\u0442\u044c \u0440\u0435\u0430\u043b\u044c\u043d\u0443\u044e \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c?" lead="\u041e\u0442\u043f\u0440\u0430\u0432\u044c\u0442\u0435 \u0430\u0434\u0440\u0435\u0441 \u2014 \u0432\u0435\u0440\u043d\u0443\u0441\u044c \u0441 \u043f\u043e\u043b\u043d\u043e\u0439 CMA \u0437\u0430 48 \u0447\u0430\u0441\u043e\u0432, \u0434\u0430\u0436\u0435 \u0435\u0441\u043b\u0438 \u043f\u0440\u043e\u0434\u0430\u0451\u0442\u0435 \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0430 \u0433\u043e\u0434\u0430." />
  <LFooter />
</BaseLayout>
