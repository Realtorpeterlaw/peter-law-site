---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/RussianTopBar.astro';
import LHeader from '../../components/RussianHeader.astro';
import LFooter from '../../components/RussianFooter.astro';
import LCTA from '../../components/RussianCTASection.astro';
const TIKTOK_PROFILE = "https://www.tiktok.com/@rentwithpeter";
const tours = [
  { id: "7642839542482930964", title: "9 Clegg Rd", tag: "Markham Downtown · 1 bed + den" },
  { id: "7643443700663848212", title: "Liberty Village", tag: "Downtown · utilities included" },
  { id: "7642835431985335573", title: "Danforth · East York", tag: "$2,100/mo · 1 bedroom" },
  { id: "7638804681673690389", title: "Move-in ready condo", tag: "Tranquil setting" },
  { id: "7638803774139829524", title: "2-storey unit", tag: "East & west views" },
  { id: "7638803030602779924", title: "Sizable 1 bed + den", tag: "Unobstructed view" },
  { id: "7641439020634967317", title: "Markham condos", tag: "Boutique-style" },
  { id: "7638802160574106900", title: "Brand-new 1 bed + den", tag: "Never lived in" },
  { id: "7638801525833239828", title: "Waterfront condo", tag: "Lake views" },
  { id: "7638800822398160148", title: "Junior 1BR", tag: "Waterfront · Lakeshore" },
  { id: "7638799683430763797", title: "Yonge & Bloor", tag: "Furnished 2 bed/2 bath · Aug 1" },
  { id: "7635749462324841748", title: "Lake Shore condo", tag: "2 bedroom" },
];
---
<BaseLayout title="\u042d\u043a\u0441\u043a\u0443\u0440\u0441\u0438\u0438 \u043f\u043e \u0430\u0440\u0435\u043d\u0434\u0435 \u2014 \u0412\u0438\u0434\u0435\u043e \u0442\u0443\u0440\u044b \u043f\u043e \u0422\u043e\u0440\u043e\u043d\u0442\u043e | Peter Law" description="\u041f\u0440\u043e\u0439\u0434\u0438\u0442\u0435\u0441\u044c \u043f\u043e \u0430\u0440\u0435\u043d\u0434\u0443\u0435\u043c\u044b\u043c \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430\u043c \u0432 \u0446\u0435\u043d\u0442\u0440\u0435 \u0422\u043e\u0440\u043e\u043d\u0442\u043e \u0434\u043e \u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f. \u0415\u0436\u0435\u043d\u0435\u0434\u0435\u043b\u044c\u043d\u043e \u043e\u0431\u043d\u043e\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0432 TikTok Peter." lang="ru" bodyClass="ru tour-page">
  <LTopBar />
  <LHeader active="rental" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Туры по аренде</div><h1>Узнайте каждую комнату до открытия двери.</h1><p>Быстрые видео-туры по арендуемым квартирам Торонто в этом месяце. Нажмите на юнит, чтобы спросить о нём. Новые видео добавляются ежедневно в <a href={TIKTOK_PROFILE} target="_blank" rel="noopener" style="text-decoration: underline; text-underline-offset: 3px;">@rentwithpeter</a>.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="tour-grid">
    {tours.map((t) => (
      <div class="tour-card">
        <div class="tour-embed">
          <button class="tour-play-btn" type="button" data-video-id={t.id} aria-label={`Смотреть тур: ${t.title}`}>
            <span class="tour-play-icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M7 5l12 7-12 7V5z" fill="currentColor"/></svg></span>
            <span class="tour-play-hint">Смотреть тур</span>
          </button>
        </div>
        <div class="tour-meta">
          <div class="tour-title">{t.title}</div>
          <div class="tour-tag">{t.tag}</div>
          <a href={`/contact?subject=Inquiry%20about%20${encodeURIComponent(t.title)}`} class="tour-cta">Спросить об этом<svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    ))}
  </div>
  <div class="tour-bottom">
    <a href={TIKTOK_PROFILE} target="_blank" rel="noopener" class="btn-primary">Смотреть все туры на TikTok<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
    <p class="tour-disclosure">Только для маркетинга и образования. Доступность, цены и требования могут меняться.</p>
  </div>
  </div></section>
  <LCTA heading="\u0427\u0442\u043e-\u0442\u043e \u043f\u043e\u043d\u0440\u0430\u0432\u0438\u043b\u043e\u0441\u044c?" lead="\u0411\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u043e \u044e\u043d\u0438\u0442\u043e\u0432 \u0441\u0434\u0430\u0451\u0442\u0441\u044f \u0437\u0430 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0434\u043d\u0435\u0439. \u0421\u043a\u0430\u0436\u0438\u0442\u0435, \u043a\u0430\u043a\u043e\u0439 \u043f\u0440\u0438\u0432\u043b\u0451\u043a \u0432\u0430\u0448\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435, \u0438 \u044f \u043f\u0440\u043e\u0432\u0435\u0440\u044e \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u044c." />
  <LFooter />
  <script is:inline>
    document.addEventListener('click', function(e){
      const btn = e.target.closest('.tour-play-btn'); if (!btn) return;
      const wrap = btn.parentElement; const videoId = btn.dataset.videoId;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.tiktok.com/player/v1/${videoId}?autoplay=1`;
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'width:100%;height:100%;border:0;';
      wrap.innerHTML = ''; wrap.appendChild(iframe);
    });
  </script>
</BaseLayout>
