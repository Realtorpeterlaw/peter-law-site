---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/FrenchTopBar.astro';
import LHeader from '../../components/FrenchHeader.astro';
import LFooter from '../../components/FrenchFooter.astro';
import LCTA from '../../components/FrenchCTASection.astro';
import PropertySales from '../../components/PropertySales.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="Historique des ventes \u2014 Peter Law Immobilier Toronto" description="Un registre des locations et ventes r\u00e9centes conclues par Peter Law dans la r\u00e9gion du Grand Toronto." lang="fr" bodyClass="fr">
  <LTopBar />
  <LHeader active="about" ctaLabel="R\u00e9server un appel" />

  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <div class="eyebrow"><a href="/french/about" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>À propos</a> · Historique des ventes</div>
        <h1 class="hero-h">Historique des ventes</h1>
        <p class="sale-history-lead">L'historique inclut la représentation de propriétaires, d'acheteurs, de locataires, ou dans certains cas, une combinaison.</p>
        <p class="sale-history-disc"><em>Les prix, adresses et rôles de représentation reflètent l'information à jour au moment de chaque transaction, provenant des dossiers publics MLS® / TRREB et/ou partagés avec le consentement du client. Les identités des clients restent confidentielles. Les résultats passés ne garantissent pas les résultats futurs. Voir l'<a href='/disclaimer#past-deals'>Avis de non-responsabilité</a>.</em></p>
      </div>
      <div>
        <div class="hero-photo">
          <img src="/photos/peter-cn-tower.jpg" alt="Peter Law, repr\u00e9sentant commercial immobilier de Toronto, avec la tour CN en arri\u00e8re-plan." width="1500" height="1887" loading="eager" />
        </div>
        <div class="agent-byline">
          <div class="agent-name">Peter Law</div>
          <div class="agent-title">Représentant commercial</div>
          <div class="agent-brokerage">Home Life Golconda Realty., Inc Brokerage.</div>
          <div class="agent-phones">
            <div><span class="lbl">DIRECT:</span> <a href="tel:+16478888472">(647) 888 - 8472</a></div>
            <div><span class="lbl">BUREAU:</span> <a href="tel:+19058888819">(905) 888 - 8819</a></div>
            <div><a href="mailto:Admin@RealtorPeterLaw.com">Admin@RealtorPeterLaw.com</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <PropertySales />

  <LCTA />
  <LFooter />
</BaseLayout>
