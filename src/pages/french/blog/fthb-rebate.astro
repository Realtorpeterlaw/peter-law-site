---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/FrenchTopBar.astro';
import Header from '../../../components/FrenchHeader.astro';
import Footer from '../../../components/FrenchFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-08';
const articleTitle = 'Remboursement TPS/TVH pour premiers acheteurs (construction neuve)';
const articleDescription = "Le nouveau remboursement TPS/TVH pour premiers acheteurs peut rendre jusqu'a 50 000 $. Qui y a droit, quelles constructions sont visees, et comment il s'ajoute au remboursement existant.";
const articleUrl = 'https://www.realtorpeterlaw.com/french/blog/fthb-rebate';
const enUrl = 'https://www.realtorpeterlaw.com/blog/fthb-rebate';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/french/about' },
  publisher: {
    '@type': 'Organization',
    name: 'Peter Law — Immobilier a Toronto',
    logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' },
  },
  inLanguage: 'fr',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'remboursement TPS TVH premier acheteur, construction neuve Ontario, remise 50000 acheteur, remboursement TVH Ontario, premier acheteur Toronto condo neuf',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/fthb-rebate/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/fthb-rebate/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/fthb-rebate/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/fthb-rebate/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/fthb-rebate/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/fthb-rebate/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/fthb-rebate/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Immobilier a Toronto`}
  description={articleDescription}
  lang="fr"
  bodyClass="fr guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/french/blog" class="back-link">Blog</a> · Remise pour acheteur</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Le Canada a introduit un nouveau remboursement TPS/TVH pouvant remettre jusqu'a 50 000 $ dans votre poche a l'achat d'une construction neuve. Voici qui se qualifie, les habitations admissibles, et comment il s'empile avec le remboursement existant.</p>
        <div class="article-byline">
          <span>Par <a href="/french/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-08</time>
          <span class="dot">·</span>
          <span>5 min de lecture</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>Sur cette page</h4>
            <ul>
              <li><a href="#what">Ce que c'est</a></li>
              <li><a href="#who">Qui se qualifie</a></li>
              <li><a href="#which">Quelles habitations</a></li>
              <li><a href="#math">Calcul rapide</a></li>
              <li><a href="#careful">A surveiller</a></li>
              <li><a href="#read-full">Lire l'article complet en anglais →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Remise maximale</span><span class="qf-val">Jusqu'a 50 000 $ (partie TPS de la TVH)</span></div>
              <div class="qf-row"><span class="qf-label">Statut requis</span><span class="qf-val">Premier acheteur au sens federal</span></div>
              <div class="qf-row"><span class="qf-label">Type de logement</span><span class="qf-val">Construction neuve ou fortement renovee</span></div>
              <div class="qf-row"><span class="qf-label">Plafond de prix</span><span class="qf-val">Diminution progressive au-dela de 450 000 $</span></div>
              <div class="qf-row"><span class="qf-label">S'ajoute a</span><span class="qf-val">Remboursement TVH Ontario existant</span></div>
            </div>


            <h2 id="what">Ce que c'est</h2>
            <p>Le nouveau remboursement federal TPS/TVH pour premiers acheteurs rembourse la <strong>partie TPS (5 %)</strong> payee sur l'achat d'une construction neuve, jusqu'a un plafond de 50 000 $. Il s'ajoute au remboursement TVH provincial existant en Ontario.</p><p>Il vise a alleger la charge des premiers acheteurs qui achetent du neuf — ou la TPS/TVH est due sur le prix — contrairement a la revente, qui en est exemptee.</p>

            <h2 id="who">Qui se qualifie</h2>
            <p>Vous devez etre <strong>premier acheteur</strong> au sens federal : ni vous ni votre conjoint n'avez ete proprietaire d'une habitation utilisee comme residence principale au cours des <strong>quatre annees precedentes</strong>. Vous devez aussi avoir 18 ans et etre resident canadien.</p><p>La maison doit devenir votre <strong>residence principale</strong> — pas un chalet, pas un immeuble locatif.</p>

            <h2 id="which">Quelles habitations</h2>
            <p>Constructions neuves d'un constructeur, condos neufs, et renovations majeures equivalant a une construction neuve. L'achat d'un terrain avec construction sur mesure peut aussi etre admissible sous certaines conditions.</p><p>Les <strong>reventes ne comptent pas</strong> : la TPS/TVH n'y est deja pas due.</p>

            <h2 id="math">Calcul rapide</h2>
            <p>Sur un condo neuf de 800 000 $ a Toronto : la partie TPS est de 40 000 $. Comme c'est sous le plafond de 50 000 $, vous recuperez la totalite. Vous continuez aussi a obtenir le remboursement TVH Ontario existant selon le prix. Consultez Peter pour une estimation precise avant de signer.</p>

            <h2 id="careful">A surveiller</h2>
            <p>Ce remboursement est <strong>recent</strong> — les regles finales peuvent evoluer. Faites toujours confirmer votre admissibilite par votre comptable et par le constructeur avant de signer. La regle des quatre ans est stricte : meme une petite periode de propriete recente peut vous disqualifier.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version longue de ce guide (chiffres, cas particuliers, procedure detaillee) est en anglais :</p>
              <a class="btn-primary" href={enUrl}>Lire l'article complet en anglais →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card {
    background: #fff;
    border: 1px solid var(--line, #e6e2dc);
    border-radius: 14px;
    padding: 18px 20px;
    margin: 0 0 28px;
    display: grid;
    gap: 10px;
  }
  .qf-row {
    display: grid;
    grid-template-columns: 42% 1fr;
    gap: 14px;
    align-items: baseline;
    padding-bottom: 8px;
    border-bottom: 1px dashed #eee;
  }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta {
    margin-top: 36px;
    padding: 22px;
    background: #f8f5ef;
    border: 1px solid var(--line, #e6e2dc);
    border-radius: 14px;
    text-align: center;
  }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary {
    display: inline-block;
    background: #b8845b;
    color: #fff;
    padding: 12px 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
