  bolt: `<svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M44 8 L20 44 L36 44 L30 72 L60 32 L44 32 Z" fill="var(--bg-warm)" stroke="currentColor" stroke-width="2.4" stroke-linejoin="round"/></svg>`,
