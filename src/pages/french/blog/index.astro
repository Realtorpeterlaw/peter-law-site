  tou: `<svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="40" cy="40" r="30" stroke="currentColor" stroke-width="2.4" fill="none"/><line x1="40" y1="14" x2="40" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="62" y1="40" x2="66" y2="40" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="40" y1="62" x2="40" y2="66" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="14" y1="40" x2="18" y2="40" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="40" y1="40" x2="30" y2="28" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/><line x1="40" y1="40" x2="54" y2="26" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="40" cy="40" r="2" fill="currentColor"/></svg>`,
