const posts = [
  { slug: 'vacant-home-tax', title: 'Taxe sur les logements vacants', eyebrow: 'Propriétaires Toronto · Fiscalité', readMin: 5, iconKey: 'percent' },
  { slug: 'hcra-illegal-building', title: 'HCRA : construction illégale', eyebrow: 'Protection acheteur · Ontario', readMin: 4, iconKey: 'warning' },
  { slug: 'rhsp', title: 'Rental Housing Supply Program (RHSP)', eyebrow: 'Logement Toronto · Politique', readMin: 5, iconKey: 'building' },
  { slug: 'oesp', title: 'OESP — réduire la facture d\'électricité', eyebrow: 'Économies d\'énergie · Ontario', readMin: 4, iconKey: 'bolt' },
  { slug: 'foreign-buyer-ban', title: 'Interdiction d\'achat aux non-Canadiens (2026)', eyebrow: 'Politique · Loi fédérale', readMin: 5, iconKey: 'shield' },
  { slug: 'fhsa', title: 'CELIAPP (FHSA) — épargne premier acheteur', eyebrow: 'Épargne acheteur · Fiscalité', readMin: 5, iconKey: 'coins' },
  { slug: 'fthb-rebate', title: 'Remboursement TPS/TVH premier acheteur', eyebrow: 'Remise acheteur · 2026', readMin: 5, iconKey: 'key' },
  { slug: 'heloc', title: 'Marge de crédit hypothécaire (HELOC)', eyebrow: 'Financement · Valeur nette', readMin: 5, iconKey: 'card' },
  { slug: 'time-of-use-tou', title: 'Time-of-Use (TOU) — réduire l\'hydro', eyebrow: 'Astuces maison · Hydro', readMin: 4, iconKey: 'tou' },
  { slug: 'bill-60-ontario', title: 'Loi 60 Ontario — locataires et propriétaires', eyebrow: 'Législation · 2026', readMin: 5, iconKey: 'scroll' },
  { slug: 'reverse-mortgage', title: 'Hypothèque inversée — 55 ans et plus', eyebrow: 'Acheteurs aînés · Financement', readMin: 5, iconKey: 'house' },
];

const hreflangAlternates = [
  { hreflang: 'en-CA', href: 'https://www.realtorpeterlaw.com/blog/' },
  { hreflang: 'zh-CN', href: 'https://www.realtorpeterlaw.com/chinese/blog/' },
  { hreflang: 'fr-CA', href: 'https://www.realtorpeterlaw.com/french/blog/' },
  { hreflang: 'x-default', href: 'https://www.realtorpeterlaw.com/blog/' },
];
---
<BaseLayout
  title="Blog Immobilier Toronto | Peter Law"
  description="Explications simples sur la location, l'achat, le financement et la législation immobilière ontarienne — par un courtier bilingue de Toronto. Mis à jour régulièrement."
  lang="fr"
  bodyClass="fr blog-page"
  hreflangAlternates={hreflangAlternates}
>
  <TopBar />
  <Header active="blog" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Blog</div>
      <h1>L'immobilier torontois, en clair.</h1>
      <p>Rumeurs, tendances, marchés, finance, politique, immigration — pour garder une longueur d'avance.</p>
      <div class="blog-search" role="search">
        <svg class="blog-search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.6"/><path d="M11 11l3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        <input id="blog-search-input" type="search" placeholder="Chercher un article…" aria-label="Chercher un article" autocomplete="off" />
      </div>
    </div>
  </section>

  <section class="major" style="padding-top: 32px;">
    <div class="wrap">
      <div class="blog-list">
        {posts.map((post) => (
          <article class="blog-card" data-search={`${post.title} ${post.eyebrow}`.toLowerCase()}>
            <a href={`/french/blog/${post.slug}`} class="blog-card-link" aria-label={`Lire : ${post.title}`}>
              {post.iconKey && icons[post.iconKey] && (
                <div class="blog-card-icon" set:html={icons[post.iconKey]} />
              )}
              <div class="blog-card-text">
                <div class="blog-card-eyebrow">{post.eyebrow}</div>
                <h2 class="blog-card-title">{post.title}</h2>
                <div class="blog-card-meta">
                  <span>{post.readMin} min de lecture</span>
                  <span class="blog-card-read">Lire
                    <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="blog-newsletter">
        <div class="eyebrow">Bulletin mensuel du marché</div>
        <h3>Chaque nouvel article, directement dans votre boîte.</h3>
        <p>Abonnez-vous au bulletin mensuel — vous recevrez chaque nouvel article le jour de sa publication. Gratuit, sans pression.</p>
        <form class="newsletter-form" method="GET" action="https://peters-newsletter-469474.beehiiv.com/subscribe" style="margin-top:14px;max-width:520px;">
          <label for="blog-newsletter-email" class="sr-only">Adresse courriel</label>
          <input id="blog-newsletter-email" type="email" name="email" placeholder="votre@courriel.com" required autocomplete="email" />
          <button type="submit" class="btn-primary">S'abonner
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
        <p style="font-size:12px;color:var(--ink-mute);margin-top:10px;">Désabonnement en tout temps. Votre courriel n'est jamais partagé.</p>
      </div>
    </div>
  </section>

  <p class="blog-no-results" id="blog-no-results" hidden>Aucun article ne correspond à cette recherche. Essayez un autre mot.</p>

  <CTASection />
  <Footer />

  <script>
    (function() {
      const input = document.getElementById('blog-search-input');
      const cards = document.querySelectorAll('.blog-card');
      const noResults = document.getElementById('blog-no-results');
      if (!input || !cards.length) return;
      function filter() {
        const q = input.value.trim().toLowerCase();
        let visibleCount = 0;
        cards.forEach(function(card) {
          const text = card.getAttribute('data-search') || '';
          const match = !q || text.indexOf(q) !== -1;
          card.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });
        if (noResults) noResults.hidden = (q.length === 0 || visibleCount > 0);
      }
      input.addEventListener('input', filter);
    })();
  </script>
</BaseLayout>
