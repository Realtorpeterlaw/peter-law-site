---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/FrenchTopBar.astro';
import Header from '../../../components/FrenchHeader.astro';
import Footer from '../../../components/FrenchFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-03';
const articleTitle = "Time-of-Use (TOU) — comment reduire votre facture d'hydro";
const articleDescription = "Guide simple sur le tarif Time-of-Use (TOU) en Ontario : les trois prix, quand chacun s'applique, et 7 gestes faciles pour baisser votre facture sans changer votre mode de vie.";
const articleUrl = 'https://www.realtorpeterlaw.com/french/blog/time-of-use-tou';
const enUrl = 'https://www.realtorpeterlaw.com/blog/time-of-use-tou';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/french/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Immobilier a Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'fr',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'Time of Use Ontario, TOU hydro Ontario, tarif electricite Ontario, heures creuses electricite, ULO Ontario, reduire facture electricite Toronto',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/time-of-use-tou/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/time-of-use-tou/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/time-of-use-tou/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/time-of-use-tou/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/time-of-use-tou/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/time-of-use-tou/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/time-of-use-tou/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Immobilier a Toronto`}
  description={articleDescription}
  lang="fr"
  bodyClass="fr guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/french/blog" class="back-link">Blog</a> · Facture d'electricite</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Votre facture d'hydro a trois prix. Utilisez l'electricite au bon moment de la journee et vous payez beaucoup moins. Voici comment ca marche, en clair.</p>
        <div class="article-byline">
          <span>Par <a href="/french/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-03</time>
          <span class="dot">·</span>
          <span>4 min de lecture</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>Sur cette page</h4>
            <ul>
              <li><a href="#prices">Les trois prix</a></li>
              <li><a href="#when">Quand chaque prix s'applique</a></li>
              <li><a href="#tips">7 gestes faciles</a></li>
              <li><a href="#ulo">Tarif ULO</a></li>
              <li><a href="#savings">Economies realistes</a></li>
              <li><a href="#read-full">Lire l'article complet en anglais →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Regime</span><span class="qf-val">Time-of-Use (TOU) en Ontario</span></div>
              <div class="qf-row"><span class="qf-label">Nombre de prix</span><span class="qf-val">3 (creux, moyen, pointe)</span></div>
              <div class="qf-row"><span class="qf-label">Prix le plus bas</span><span class="qf-val">Creux — nuit et fin de semaine</span></div>
              <div class="qf-row"><span class="qf-label">Prix le plus haut</span><span class="qf-val">Pointe — matin et fin d'apres-midi</span></div>
              <div class="qf-row"><span class="qf-label">Alternative</span><span class="qf-val">Tarif ULO — encore plus bas la nuit</span></div>
            </div>


            <h2 id="prices">Les trois prix</h2>
            <p><strong>Creux</strong> : le prix le plus bas, generalement de 19 h a 7 h en semaine et toute la fin de semaine. <strong>Moyen</strong> : milieu de journee en semaine. <strong>Pointe</strong> : matin (env. 7 h-11 h) et fin d'apres-midi (env. 17 h-19 h) en semaine.</p>

            <h2 id="when">Quand chaque prix s'applique</h2>
            <p>Les plages exactes varient legerement selon la saison, mais la logique reste la meme : appareils gourmands (lave-vaisselle, secheuse, laveuse) tournent en creux — vous economisez sans rien changer d'autre.</p>

            <h2 id="tips">7 gestes faciles</h2>
            <p>1) Programmer le lave-vaisselle apres 19 h. 2) Faire tourner laveuse/secheuse la fin de semaine. 3) Recharger la voiture electrique la nuit. 4) Cuisiner en batch le dimanche. 5) Utiliser un thermostat programmable. 6) Debrancher les appareils inutilises. 7) Verifier les fuites d'air aux fenetres.</p>

            <h2 id="ulo">Tarif ULO</h2>
            <p>Le tarif <strong>Ultra-Low Overnight (ULO)</strong> offre un prix encore plus bas la nuit (23 h-7 h) — ideal pour les proprietaires de VE ou pour ceux qui chauffent avec pompe a chaleur.</p>

            <h2 id="savings">Economies realistes</h2>
            <p>Un menage moyen peut economiser 10-20 % en decalant simplement l'usage des appareils gros consommateurs vers les heures creuses — sans changer son confort.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version longue de ce guide (chiffres, cas particuliers, procedure detaillee) est en anglais :</p>
              <a class="btn-primary" href={enUrl}>Lire l'article complet en anglais →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
