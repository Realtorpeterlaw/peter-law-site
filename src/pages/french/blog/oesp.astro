---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/FrenchTopBar.astro';
import Header from '../../../components/FrenchHeader.astro';
import Footer from '../../../components/FrenchFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-09';
const articleTitle = "OESP — reduire de moitie votre facture d'electricite";
const articleDescription = "Guide en clair du Programme d'aide aux frais d'electricite de l'Ontario (OESP) : qui se qualifie, les montants de credit mensuel (35 $ a 113 $), et comment le combiner au LEAP et au Rabais de l'Ontario pour l'electricite.";
const articleUrl = 'https://www.realtorpeterlaw.com/french/blog/oesp';
const enUrl = 'https://www.realtorpeterlaw.com/blog/oesp';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/french/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Immobilier a Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'fr',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'OESP Ontario, programme aide electricite Ontario, credit facture hydro Ontario, LEAP Ontario, Rabais Ontario electricite OER',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/oesp/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/oesp/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/oesp/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/oesp/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/oesp/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/oesp/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/oesp/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Immobilier a Toronto`}
  description={articleDescription}
  lang="fr"
  bodyClass="fr guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/french/blog" class="back-link">Blog</a> · Aide facture electricite</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">L'OESP est probablement le programme d'allegement le plus sous-utilise en Ontario. Les menages admissibles recoivent un credit mensuel direct de 35 $ a 113 $ sur leur facture d'electricite — pour beaucoup, c'est presque la moitie du cout.</p>
        <div class="article-byline">
          <span>Par <a href="/french/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-09</time>
          <span class="dot">·</span>
          <span>4 min de lecture</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>Sur cette page</h4>
            <ul>
              <li><a href="#what">Ce que c'est</a></li>
              <li><a href="#who">Qui se qualifie</a></li>
              <li><a href="#amount">Montant du credit</a></li>
              <li><a href="#stack">Cumul avec d'autres aides</a></li>
              <li><a href="#apply">Comment demander</a></li>
              <li><a href="#read-full">Lire l'article complet en anglais →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Programme</span><span class="qf-val">OESP — Ontario Electricity Support Program</span></div>
              <div class="qf-row"><span class="qf-label">Type d'aide</span><span class="qf-val">Credit mensuel direct sur la facture</span></div>
              <div class="qf-row"><span class="qf-label">Montant</span><span class="qf-val">De 35 $ a 113 $ par mois</span></div>
              <div class="qf-row"><span class="qf-label">Base d'admissibilite</span><span class="qf-val">Revenu du menage + taille du foyer</span></div>
              <div class="qf-row"><span class="qf-label">Cumulable</span><span class="qf-val">Avec LEAP + Rabais Ontario pour l'electricite (OER)</span></div>
            </div>


            <h2 id="what">Ce que c'est</h2>
            <p>L'OESP est un <strong>credit direct mensuel</strong> applique automatiquement sur votre facture d'electricite. Il n'a pas a etre rembourse. Il est finance par la province et s'applique tant que vous remplissez les conditions.</p>

            <h2 id="who">Qui se qualifie</h2>
            <p>L'admissibilite est basee sur le <strong>revenu du menage</strong> et la <strong>taille du foyer</strong>. Un menage plus grand ou a revenu tres modeste beneficie d'un credit plus eleve. La demande se fait en ligne sur ontarioelectricitysupport.ca.</p>

            <h2 id="amount">Montant du credit</h2>
            <p>Le credit va de <strong>35 $ par mois</strong> (niveau de base) jusqu'a <strong>113 $ par mois</strong> pour les grands foyers ou foyers a chauffage electrique.</p>

            <h2 id="stack">Cumul avec d'autres aides</h2>
            <p>OESP se cumule avec le <strong>LEAP</strong> (aide d'urgence ponctuelle pour arrieres) et avec le <strong>Rabais de l'Ontario pour l'electricite (OER)</strong>, qui reduit deja votre facture de plusieurs pourcents. En combinant les trois, un petit menage peut voir sa facture reduite de pres de moitie.</p>

            <h2 id="apply">Comment demander</h2>
            <p>Formulaire en ligne + preuve de revenu (T4, avis de cotisation). Une fois approuve, le credit apparait automatiquement sur les factures suivantes. La demande doit etre renouvelee periodiquement.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version longue de ce guide (chiffres, cas particuliers, procedure detaillee) est en anglais :</p>
              <a class="btn-primary" href={enUrl}>Lire l'article complet en anglais →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
