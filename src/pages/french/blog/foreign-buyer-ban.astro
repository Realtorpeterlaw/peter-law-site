---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/FrenchTopBar.astro';
import Header from '../../../components/FrenchHeader.astro';
import Footer from '../../../components/FrenchFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-09';
const articleTitle = "Interdiction d'achat aux non-Canadiens (2026)";
const articleDescription = "Guide en clair de la Loi sur l'interdiction d'achat de proprietes residentielles par des non-Canadiens : qui est vise, quelles proprietes, les exceptions (permis de travail, conjoint), penalites, et ce qui reste en vigueur jusqu'au 31 decembre 2026.";
const articleUrl = 'https://www.realtorpeterlaw.com/french/blog/foreign-buyer-ban';
const enUrl = 'https://www.realtorpeterlaw.com/blog/foreign-buyer-ban';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/french/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Immobilier a Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'fr',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'interdiction acheteur etranger Canada, ban non-Canadien immobilier, achat immobilier permis travail Canada, conjoint canadien exception, 2026 interdiction achat',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/foreign-buyer-ban/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/foreign-buyer-ban/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/foreign-buyer-ban/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/foreign-buyer-ban/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/foreign-buyer-ban/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/foreign-buyer-ban/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/foreign-buyer-ban/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Immobilier a Toronto`}
  description={articleDescription}
  lang="fr"
  bodyClass="fr guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/french/blog" class="back-link">Blog</a> · Reglementation federale</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">L'interdiction canadienne d'achat aux acheteurs etrangers est en vigueur depuis le 1er janvier 2023 et reste en place jusqu'au 31 decembre 2026. Les regles sont plus etroites que le titre le suggere — et les exceptions comptent. Voici a qui l'interdiction s'applique reellement.</p>
        <div class="article-byline">
          <span>Par <a href="/french/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-09</time>
          <span class="dot">·</span>
          <span>5 min de lecture</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>Sur cette page</h4>
            <ul>
              <li><a href="#what">Ce que la loi interdit</a></li>
              <li><a href="#who">Qui est un non-Canadien</a></li>
              <li><a href="#exceptions">Exceptions principales</a></li>
              <li><a href="#properties">Proprietes visees</a></li>
              <li><a href="#penalties">Penalites</a></li>
              <li><a href="#read-full">Lire l'article complet en anglais →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Loi</span><span class="qf-val">Prohibition on the Purchase of Residential Property by Non-Canadians Act</span></div>
              <div class="qf-row"><span class="qf-label">En vigueur</span><span class="qf-val">1er janvier 2023 — 31 decembre 2026</span></div>
              <div class="qf-row"><span class="qf-label">Qui est vise</span><span class="qf-val">Non-Canadiens (sauf exceptions)</span></div>
              <div class="qf-row"><span class="qf-label">Proprietes visees</span><span class="qf-val">Residentielles dans les regions RMR/AR</span></div>
              <div class="qf-row"><span class="qf-label">Sanction</span><span class="qf-val">Amende jusqu'a 10 000 $ + revente forcee</span></div>
            </div>


            <h2 id="what">Ce que la loi interdit</h2>
            <p>La loi federale interdit aux <strong>non-Canadiens</strong> d'acheter une propriete residentielle dans les grandes zones metropolitaines (RMR) et agglomerations de recensement (AR). L'interdiction est en vigueur du 1er janvier 2023 au <strong>31 decembre 2026</strong>.</p>

            <h2 id="who">Qui est un non-Canadien</h2>
            <p>Toute personne qui n'est ni citoyen canadien, ni resident permanent, ni personne inscrite en vertu de la Loi sur les Indiens. Les societes controlees a plus de 10 % par un non-Canadien sont aussi visees.</p>

            <h2 id="exceptions">Exceptions principales</h2>
            <p>Etudiants internationaux avec certaines conditions ; <strong>titulaires de permis de travail</strong> ayant travaille au Canada un nombre minimum d'annees ; <strong>conjoints canadiens ou residents permanents</strong> ; refugies et titulaires de statut protege ; achat en zones non RMR/AR.</p>

            <h2 id="properties">Proprietes visees</h2>
            <p>Maisons unifamiliales, semi-detachees, en rangee, condos et duplex jusqu'a 3 unites en RMR/AR. Immeubles de 4 unites et plus sont exclus. Certaines proprietes recreatives hors RMR/AR sont egalement hors du champ.</p>

            <h2 id="penalties">Penalites</h2>
            <p>Amende jusqu'a <strong>10 000 $</strong> pour l'acheteur et toute personne aidant a la transaction (agent, avocat). Le tribunal peut aussi ordonner la <strong>revente forcee</strong> de la propriete achetee en violation.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version longue de ce guide (chiffres, cas particuliers, procedure detaillee) est en anglais :</p>
              <a class="btn-primary" href={enUrl}>Lire l'article complet en anglais →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
