---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/FrenchTopBar.astro';
import Header from '../../../components/FrenchHeader.astro';
import Footer from '../../../components/FrenchFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-03';
const articleTitle = "Hypotheque inversee au Canada — ce qu'il faut savoir avant de signer";
const articleDescription = "Guide en clair de l'hypotheque inversee au Canada : fonctionnement, admissibilite (55+), combien vous pouvez emprunter, taux, frais, et les vrais compromis avant de signer. Edition proprietaires de Toronto.";
const articleUrl = 'https://www.realtorpeterlaw.com/french/blog/reverse-mortgage';
const enUrl = 'https://www.realtorpeterlaw.com/blog/reverse-mortgage';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/french/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Immobilier a Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'fr',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'hypotheque inversee Canada, 55 ans plus proprietaire, valeur nette maison retraite, retraite hypotheque Canada, cout hypotheque inversee',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/reverse-mortgage/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/reverse-mortgage/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/reverse-mortgage/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/reverse-mortgage/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/reverse-mortgage/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/reverse-mortgage/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/reverse-mortgage/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Immobilier a Toronto`}
  description={articleDescription}
  lang="fr"
  bodyClass="fr guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/french/blog" class="back-link">Blog</a> · Proprietaires 55+</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Analyse en clair pour proprietaires canadiens de 55 ans et plus : comment fonctionne l'hypotheque inversee, ce qu'elle coute vraiment, et les compromis que la banque ne detaille pas toujours avant la signature.</p>
        <div class="article-byline">
          <span>Par <a href="/french/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-03</time>
          <span class="dot">·</span>
          <span>5 min de lecture</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>Sur cette page</h4>
            <ul>
              <li><a href="#what">Ce que c'est</a></li>
              <li><a href="#who">Qui se qualifie</a></li>
              <li><a href="#how-much">Combien vous pouvez emprunter</a></li>
              <li><a href="#cost">Cout reel</a></li>
              <li><a href="#tradeoff">Les vrais compromis</a></li>
              <li><a href="#read-full">Lire l'article complet en anglais →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Age minimum</span><span class="qf-val">55 ans (tous les proprietaires inscrits)</span></div>
              <div class="qf-row"><span class="qf-label">Type de logement</span><span class="qf-val">Residence principale</span></div>
              <div class="qf-row"><span class="qf-label">Emprunt max</span><span class="qf-val">Generalement 55 % de la valeur</span></div>
              <div class="qf-row"><span class="qf-label">Paiement mensuel</span><span class="qf-val">Aucun tant que vous y vivez</span></div>
              <div class="qf-row"><span class="qf-label">Interet</span><span class="qf-val">Fixe ou variable, plus eleve qu'une hypotheque standard</span></div>
            </div>


            <h2 id="what">Ce que c'est</h2>
            <p>L'hypotheque inversee vous permet, si vous avez 55 ans et plus, d'emprunter contre la valeur de votre maison <strong>sans paiement mensuel obligatoire</strong>. L'interet s'accumule sur le solde, et le pret devient exigible lorsque vous vendez, quittez le domicile, ou decedez.</p>

            <h2 id="who">Qui se qualifie</h2>
            <p>Vous et tous les proprietaires inscrits devez avoir <strong>55 ans ou plus</strong>. La maison doit etre votre <strong>residence principale</strong>. Il n'y a pas de test de revenu ni de credit, ce qui la rend accessible a beaucoup de retraites.</p>

            <h2 id="how-much">Combien vous pouvez emprunter</h2>
            <p>En general, jusqu'a <strong>55 % de la valeur estimee</strong>, selon votre age et le type de propriete. Plus vous etes age, plus vous pouvez emprunter (parce que la duree prevue du pret est plus courte).</p>

            <h2 id="cost">Cout reel</h2>
            <p>Le taux est <strong>plus eleve</strong> qu'une hypotheque standard, et l'interet s'accumule. Sur 15-20 ans, il peut consommer une grande partie de la valeur nette. Ajoutez frais d'evaluation, frais juridiques, et frais d'ouverture.</p>

            <h2 id="tradeoff">Les vrais compromis</h2>
            <p>+ Aucun paiement mensuel, argent libre d'impot, restez chez vous. − Reduit fortement l'heritage, plus cher qu'une HELOC, penalites lourdes en cas de fermeture anticipee. Consultez toujours un conseiller independant avant de signer.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version longue de ce guide (chiffres, cas particuliers, procedure detaillee) est en anglais :</p>
              <a class="btn-primary" href={enUrl}>Lire l'article complet en anglais →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
