---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/FrenchTopBar.astro';
import Header from '../../../components/FrenchHeader.astro';
import Footer from '../../../components/FrenchFooter.astro';

export const prerender = true;

const publishedDate = '2026-07-14';
const articleTitle = 'Rental Housing Supply Program (RHSP) — Toronto';
const articleDescription = "Guide en clair du Rental Housing Supply Program (RHSP) de la Ville de Toronto. Ce que c'est, qui peut demander, les cinq volets de financement, et ce que cela veut dire pour les locataires torontois.";
const articleUrl = 'https://www.realtorpeterlaw.com/french/blog/rhsp';
const enUrl = 'https://www.realtorpeterlaw.com/blog/rhsp';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/french/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Immobilier a Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'fr',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'RHSP Toronto, Rental Housing Supply Program, logement abordable Toronto, programme locatif municipal, subvention constructeur locatif Toronto',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/rhsp/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/rhsp/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/rhsp/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/rhsp/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Immobilier a Toronto`}
  description={articleDescription}
  lang="fr"
  bodyClass="fr guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/french/blog" class="back-link">Blog</a> · Locataires a Toronto</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Toronto aide les constructeurs a batir plus de logements locatifs. Certains resteront abordables pendant 40 ans, d'autres seront des appartements reguliers. Voici en quoi consiste le programme, qui peut y participer, et ce qu'il change pour les locataires.</p>
        <div class="article-byline">
          <span>Par <a href="/french/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-07-14</time>
          <span class="dot">·</span>
          <span>5 min de lecture</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>Sur cette page</h4>
            <ul>
              <li><a href="#what">Ce que c'est</a></li>
              <li><a href="#streams">Les cinq volets</a></li>
              <li><a href="#who">Qui peut demander</a></li>
              <li><a href="#affordable">Loyers abordables</a></li>
              <li><a href="#impact">Ce que ca change pour vous</a></li>
              <li><a href="#read-full">Lire l'article complet en anglais →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Organisme</span><span class="qf-val">Ville de Toronto</span></div>
              <div class="qf-row"><span class="qf-label">Cible</span><span class="qf-val">Nouveaux logements locatifs sur 10 ans</span></div>
              <div class="qf-row"><span class="qf-label">Volets</span><span class="qf-val">5 flux de financement</span></div>
              <div class="qf-row"><span class="qf-label">Abordabilite</span><span class="qf-val">Certains geles a des loyers abordables jusqu'a 40 ans</span></div>
              <div class="qf-row"><span class="qf-label">Qui postule</span><span class="qf-val">Constructeurs et proprietaires-bailleurs, pas les locataires</span></div>
            </div>


            <h2 id="what">Ce que c'est</h2>
            <p>Le RHSP est un programme municipal qui verse du financement — subventions, prets, allegements fiscaux, terrains — aux constructeurs de logements locatifs a Toronto. Objectif : ajouter des milliers de logements locatifs sur les 10 prochaines annees, dont une partie <strong>abordables et geles</strong>.</p>

            <h2 id="streams">Les cinq volets</h2>
            <p>Le programme regroupe cinq flux distincts : locatif abordable neuf, locatif au prix du marche, preservation de locatif existant, logement supervise, et remise en service de terrains publics. Chaque volet vise un type de projet different.</p>

            <h2 id="who">Qui peut demander</h2>
            <p>Ce sont les <strong>constructeurs, developpeurs et proprietaires-bailleurs</strong> qui postulent — pas les locataires directement. Vous, comme locataire, en beneficiez indirectement quand un projet approuve arrive sur le marche pres de chez vous.</p>

            <h2 id="affordable">Loyers abordables</h2>
            <p>Les unites abordables sont plafonnees selon des seuils municipaux (souvent 80 % du loyer median du marche) et le restent <strong>jusqu'a 40 ans</strong>. C'est ce qui distingue le programme d'un simple incitatif a la construction.</p>

            <h2 id="impact">Ce que ca change pour vous</h2>
            <p>Plus d'offre locative, surtout dans les nouveaux quartiers, et un stock d'unites abordables qui grandit lentement mais reste protege. Ce n'est pas une baisse immediate des loyers, mais une stabilisation sur la duree.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version longue de ce guide (chiffres, cas particuliers, procedure detaillee) est en anglais :</p>
              <a class="btn-primary" href={enUrl}>Lire l'article complet en anglais →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
