---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FrenchTopBar from '../../components/FrenchTopBar.astro';
import FrenchHeader from '../../components/FrenchHeader.astro';
import FrenchFooter from '../../components/FrenchFooter.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
const FORMSPREE_ENDPOINT = "https://formspree.io/f/xnjrzgda";
---
<BaseLayout title="Contact — Peter Law · Immobilier à Toronto" description="Contactez Peter Law. Envoyez un courriel, un texto, ou réservez directement un appel initial de 15 minutes." lang="fr" bodyClass="fr">

  <FrenchTopBar />
  <FrenchHeader active="contact" ctaLabel="Ou réserver un appel" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Contactez-moi</div>
      <h1>La façon la plus rapide d'obtenir de vraies réponses.</h1>
      <p>Envoyez un message, un texto, ou réservez directement un appel.</p>
    </div>
  </section>

  <section class="major" style="padding-top:24px;">
    <div class="wrap">
      <div class="contact-grid">
        <form class="contact-form" method="POST" action={FORMSPREE_ENDPOINT}>
          <div class="form-row">
            <label for="name">Nom <span class="required">*</span></label>
            <input id="name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="form-row">
            <label for="email">Courriel <span class="required">*</span></label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="form-row">
            <label for="phone">Téléphone <span class="required">*</span></label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" required />
          </div>
          <div class="form-row">
            <label for="message">De quoi avez-vous besoin? <span class="required">*</span></label>
            <textarea id="message" name="message" rows="6" required placeholder="Le quartier visé, votre échéancier, tout ce que je devrais savoir."></textarea>
          </div>
          <div class="hp-field" aria-hidden="true">
            <label for="gotcha">Ne pas remplir</label>
            <input id="gotcha" name="_gotcha" type="text" tabindex="-1" autocomplete="off">
          </div>
          <input type="hidden" name="_subject" value="Nouveau message (site web — français)">
          <input type="hidden" name="_next" value="https://www.realtorpeterlaw.com/contact/thanks">
          <button type="submit" class="btn-primary">
            Envoyer
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>

        <aside class="contact-side">
          <div class="contact-block">
            <div class="contact-lbl">Réserver un appel</div>
            <a href={BOOKING_URL} class="btn-secondary">15 min · Google Meet ou téléphone · Gratuit</a>
          </div>
          <div class="contact-block">
            <span class="contact-lbl">Téléphone / texto</span>
            <a href="tel:+16478888472">647-888-8472</a>
          </div>
          <div class="contact-block">
            <span class="contact-lbl">Courriel</span>
            <a href="mailto:Admin@RealtorPeterLaw.com">Admin@RealtorPeterLaw.com</a>
          </div>
          <div class="contact-block">
            <span class="contact-lbl">Maison de courtage</span>
            <p>HomeLife Golconda Realty Inc., Brokerage<br>215 – 3601 HWY 7 East<br>Markham, ON L3R 0M3</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <FrenchFooter />
</BaseLayout>
