---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/FrenchTopBar.astro';
import LHeader from '../../components/FrenchHeader.astro';
import LFooter from '../../components/FrenchFooter.astro';
import LCTA from '../../components/FrenchCTASection.astro';
const TIKTOK_PROFILE = "https://www.tiktok.com/@rentwithpeter";
const tours = [
  { id: "7642839542482930964", title: "9 Clegg Rd", tag: "Markham Downtown · 1 bed + den" },
  { id: "7643443700663848212", title: "Liberty Village", tag: "Downtown · utilities included" },
  { id: "7642835431985335573", title: "Danforth · East York", tag: "$2,100/mo · 1 bedroom" },
  { id: "7638804681673690389", title: "Move-in ready condo", tag: "Tranquil setting" },
  { id: "7638803774139829524", title: "2-storey unit", tag: "East & west views" },
  { id: "7638803030602779924", title: "Sizable 1 bed + den", tag: "Unobstructed view" },
  { id: "7641439020634967317", title: "Markham condos", tag: "Boutique-style" },
  { id: "7638802160574106900", title: "Brand-new 1 bed + den", tag: "Never lived in" },
  { id: "7638801525833239828", title: "Waterfront condo", tag: "Lake views" },
  { id: "7638800822398160148", title: "Junior 1BR", tag: "Waterfront · Lakeshore" },
  { id: "7638799683430763797", title: "Yonge & Bloor", tag: "Furnished 2 bed/2 bath · Aug 1" },
  { id: "7635749462324841748", title: "Lake Shore condo", tag: "2 bedroom" },
];

const hreflangAlternates = [
  { hreflang: 'en-CA', href: 'https://www.realtorpeterlaw.com/rental-tour/' },
  { hreflang: 'zh-CN', href: 'https://www.realtorpeterlaw.com/chinese/rental-tour/' },
  { hreflang: 'fr-CA', href: 'https://www.realtorpeterlaw.com/french/rental-tour/' },
  { hreflang: 'x-default', href: 'https://www.realtorpeterlaw.com/rental-tour/' },
];
---
<BaseLayout title="Visites de location \u2014 Visites vid\u00e9o \u00e0 Toronto | Peter Law" description="Parcourez les locations du centre-ville de Toronto avant de r\u00e9server. Mis \u00e0 jour chaque semaine depuis le TikTok de Peter." lang="fr" bodyClass="fr tour-page"
  hreflangAlternates={hreflangAlternates}
>
  <LTopBar />
  <LHeader active="rental" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Visites de location</div><h1>Connaissez chaque pièce avant d'ouvrir la porte.</h1><p>Visites vidéo rapides des locations que j'ai visitées ce mois-ci. Touchez une unité pour poser une question. Nouvelles vidéos ajoutées quotidiennement sur <a href={TIKTOK_PROFILE} target="_blank" rel="noopener" style="text-decoration: underline; text-underline-offset: 3px;">@rentwithpeter</a>.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="tour-grid">
    {tours.map((t) => (
      <div class="tour-card">
        <div class="tour-embed">
          <button class="tour-play-btn" type="button" data-video-id={t.id} aria-label={`Lire la visite: ${t.title}`}>
            <span class="tour-play-icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M7 5l12 7-12 7V5z" fill="currentColor"/></svg></span>
            <span class="tour-play-hint">Lire la visite</span>
          </button>
        </div>
        <div class="tour-meta">
          <div class="tour-title">{t.title}</div>
          <div class="tour-tag">{t.tag}</div>
          <a href={`/contact?subject=Inquiry%20about%20${encodeURIComponent(t.title)}`} class="tour-cta">Poser une question<svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    ))}
  </div>
  <div class="tour-bottom">
    <a href={TIKTOK_PROFILE} target="_blank" rel="noopener" class="btn-primary">Voir toutes les visites sur TikTok<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
    <p class="tour-disclosure">À des fins de marketing et d'éducation uniquement. La disponibilité, les prix et les exigences peuvent changer. Les exigences documentaires varient selon le propriétaire.</p>
  </div>
  </div></section>
  <LCTA heading="Une unit\u00e9 vous pla\u00eet?" lead="La plupart de ces unit\u00e9s se louent en quelques jours. Dites-moi laquelle vous a attir\u00e9 et je v\u00e9rifierai la disponibilit\u00e9." />
  <LFooter />
  <script is:inline>
    document.addEventListener('click', function(e){
      const btn = e.target.closest('.tour-play-btn'); if (!btn) return;
      const wrap = btn.parentElement; const videoId = btn.dataset.videoId;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.tiktok.com/player/v1/${videoId}?autoplay=1`;
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'width:100%;height:100%;border:0;';
      wrap.innerHTML = ''; wrap.appendChild(iframe);
    });
  </script>
</BaseLayout>
