---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/FrenchTopBar.astro';
import LHeader from '../../components/FrenchHeader.astro';
import LFooter from '../../components/FrenchFooter.astro';
import LCTA from '../../components/FrenchCTASection.astro';
---
<BaseLayout title="Calculateur d'accessibilit\u00e9 | Peter Law" description="Combien pouvez-vous vous permettre? Estime votre prix maximum d'achat selon les r\u00e8gles canadiennes (RAB/RDT + test de stress)." lang="fr" bodyClass="fr calc-page">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Calculateur d'accessibilité</div><h1>Combien pouvez-vous vraiment vous permettre?</h1><p>Estime votre prix maximum d'achat selon les règles canadiennes — ratios GDS/TDS et test de stress fédéral.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="calc">
    <div class="calc-fields">
      <div class="calc-field"><label for="af-income">Revenu annuel du ménage</label><div class="input-prefix"><input type="number" id="af-income" value="120000" min="0" step="1000" /></div></div>
      <div class="calc-field"><label for="af-debt">Paiements de dette mensuels</label><div class="input-prefix"><input type="number" id="af-debt" value="500" min="0" step="50" /></div></div>
      <div class="calc-field"><label for="af-down">Mise de fonds</label><div class="input-prefix"><input type="number" id="af-down" value="100000" min="0" step="5000" /></div></div>
      <div class="calc-field"><label for="af-rate">Taux hypothécaire</label><div class="input-suffix"><input type="number" id="af-rate" value="5.0" min="0" step="0.05" /></div></div>
      <div class="calc-field"><label for="af-amort">Amortissement (années)</label><input type="number" id="af-amort" value="25" min="5" max="35" /></div>
    </div>
    <div class="calc-result">
      <div class="calc-result-main"><span class="label">Prix maximum</span><span id="af-max">$0</span></div>
      <div class="calc-result-breakdown">
        <div class="row"><span>Basé sur GDS 32%</span><strong id="af-gds">$0</strong></div>
        <div class="row"><span>Basé sur TDS 40%</span><strong id="af-tds">$0</strong></div>
        <div class="row"><em>Le plus bas des deux est votre limite</em></div>
      </div>
    </div>
    <p class="calc-disclaimer">Estimation seulement. Basé sur les ratios GDS/TDS standard et le test de stress. Consultez un courtier hypothécaire pour l'approbation réelle.</p>
  </div></div></section>
  <LCTA />
  <LFooter />
  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('fr-CA',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function pRate(r,n){const s=r/200;return Math.pow(1+s,2/n)-1;}
      function maxPrincipal(pmt,r,y){const rr=pRate(r,12),n=y*12;if(rr===0)return pmt*n;return pmt*(1-Math.pow(1+rr,-n))/rr;}
      function c(){
        const inc=parseFloat(document.getElementById('af-income').value)||0;
        const debt=parseFloat(document.getElementById('af-debt').value)||0;
        const dn=parseFloat(document.getElementById('af-down').value)||0;
        const r=parseFloat(document.getElementById('af-rate').value)||0;
        const y=parseInt(document.getElementById('af-amort').value,10)||25;
        const sr=Math.max(r+2,5.25);
        // Stress test at higher rate for qualifying
        const mi=inc/12;
        const gdsAvail=mi*.32; const tdsAvail=mi*.40-debt;
        // Assume $250/mo tax + $150/mo heat + $75/mo condo
        const otherHousing=475;
        const gdsPmt=Math.max(0,gdsAvail-otherHousing);
        const tdsPmt=Math.max(0,tdsAvail-otherHousing);
        const gdsMax=maxPrincipal(gdsPmt,sr,y)+dn;
        const tdsMax=maxPrincipal(tdsPmt,sr,y)+dn;
        const maxP=Math.min(gdsMax,tdsMax);
        document.getElementById('af-max').textContent=fmt(maxP);
        document.getElementById('af-gds').textContent=fmt(gdsMax);
        document.getElementById('af-tds').textContent=fmt(tdsMax);
      }
      ['af-income','af-debt','af-down','af-rate','af-amort'].forEach(id=>{const el=document.getElementById(id);el.addEventListener('input',c);el.addEventListener('change',c);});c();
    })();
  </script>
</BaseLayout>
