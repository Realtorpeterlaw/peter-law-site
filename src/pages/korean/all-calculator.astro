---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/KoreanTopBar.astro';
import LHeader from '../../components/KoreanHeader.astro';
import LFooter from '../../components/KoreanFooter.astro';
import LCTA from '../../components/KoreanCTASection.astro';
export const prerender = true;
---
<BaseLayout title="\uad6c\ub9e4 \uacc4\uc0b0\uae30 \u2014 \ubaa8\uae30\uc9c0, LTT, CMHC, \ud074\ub85c\uc9d5 \ube44\uc6a9 | Peter Law" description="\ud55c \ud398\uc774\uc9c0. \uc18c\ub4dd, \uc8fc\ud0dd \uac00\uaca9, \uc800\ucd95\uc744 \uc785\ub825\ud558\uc138\uc694. \uc6d4 \uc9c0\ubd88\uae08, \ud1a0\uc9c0 \uc591\ub3c4\uc138, \ubaa8\uae30\uc9c0 \ubcf4\ud5d8, \ud074\ub85c\uc9d5 \ube44\uc6a9\uc744 \uc989\uc2dc \ud655\uc778." lang="ko" bodyClass="ko">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">구매 계산기</div><h1>간단하고 쉬운 계산 생성기</h1><p>구매와 자금 조달에 대한 자세한 정보는 PETER에게 문의하세요. 모기지 브로커 상담 권장.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="ac-shell">
    <div class="ac-inputs">
      <div class="ac-input-group"><label>1. 연간 얼마나 벌으십니까? <span class="hint">세전.</span></label><div class="input-prefix"><input type="number" id="ac-income" value="250000" min="0" step="1000" /></div></div>
      <div class="ac-input-group"><label>2. 승인된 주택 가격 <span class="hint">콘도, 타운하우스 또는 하우스.</span></label><div class="input-prefix"><input type="number" id="ac-price" value="1000000" min="0" step="5000" /></div></div>
      <div class="ac-input-group"><label>3. 계약금 <span class="hint">이상적으로 구매가의 20-25%.</span></label><div class="input-prefix"><input type="number" id="ac-savings" value="100000" min="0" step="1000" /></div></div>
      <div class="ac-input-group ac-checkbox-group"><label class="ac-checkbox"><input type="checkbox" id="ac-fthb" checked /><span class="ac-checkbox-text">저는 첫 주택 구매자입니다 <span class="hint">토지 양도세 환급을 받습니다.</span></span></label></div>
      <div class="ac-input-group"><label>4. 부동산 유형 <span class="hint">월 지출 항목에 영향.</span></label><select id="ac-proptype"><option value="freehold" selected>단독 소유 (하우스)</option><option value="freehold-hoa">단독 소유 (HOA 포함)</option><option value="condo">콘도</option></select></div>
      <div class="ac-input-group" id="ac-tax-row"><label>5. 재산세 <span class="hint">월. 비워두면 가격 0.7%/년으로 자동 추정.</span></label><div class="input-prefix"><input type="number" id="ac-proptax" value="" min="0" step="5" placeholder="e.g. 400" /></div></div>
      <div class="ac-input-group" id="ac-fee-row" style="display:none;"><label id="ac-fee-label">6. HOA 수수료 <span class="hint">월. 서명 전 문의 — 일부는 난방, 물, 전기를 포함.</span></label><div class="input-prefix"><input type="number" id="ac-fee" value="" min="0" step="5" placeholder="e.g. 150" /></div></div>
      <details class="ac-more"><summary>추가 옵션</summary><div class="ac-more-body">
        <div class="ac-input-group"><label>모기지 이자율 <span class="hint">2026년에 5%가 일반적.</span></label><div class="input-suffix"><input type="number" id="ac-rate" value="5.0" min="0" step="0.05" /></div></div>
        <div class="ac-input-group"><label>상환 기간</label><select id="ac-amort"><option value="20">20</option><option value="25" selected>25</option><option value="30">30</option></select></div>
        <div class="ac-input-group"><label>부동산은 어디에 있습니까?</label><select id="ac-location"><option value="toronto" selected>토론토 시내</option><option value="ontario">온타리오 기타 지역</option></select></div>
      </div></details>
    </div>
    <div class="ac-results">
      <div class="ac-headline">
        <div class="ac-headline-item"><div class="ac-headline-label">월 지불금</div><div class="ac-headline-value" id="ac-monthly">$0</div><div class="ac-headline-sub">모기지만. 총 월 비용은 세부 내역 참조.</div></div>
        <div class="ac-headline-item"><div class="ac-headline-label">클로징 시 필요한 현금</div><div class="ac-headline-value" id="ac-cash">$0</div><div class="ac-headline-sub">계약금 + 토지 양도세 + 변호사 + 조정.</div></div>
      </div>
      <div class="ac-verdict" id="ac-verdict"><span class="ac-verdict-dot"></span><div><div class="ac-verdict-title" id="ac-verdict-title">위에 숫자를 입력하세요.</div><div class="ac-verdict-sub" id="ac-verdict-sub">은행은 수입의 얼마가 주거비에 사용되는지 확인합니다. 32% 미만이 안전. 39% 초과 시 은행은 거절할 가능성이 큽니다.</div></div></div>
      <h3 class="ac-section-h">돈이 어디로 가는가</h3>
      <div class="ac-breakdown">
        <div class="ac-row"><span>계약금</span><strong id="ac-down">$0</strong></div>
        <div class="ac-row"><span>총 모기지</span><strong id="ac-mortgage">$0</strong></div>
        <div class="ac-row"><span>CMHC / 기본 보험 <em class="ac-note" id="ac-cmhc-note"></em></span><strong id="ac-cmhc">$0</strong></div>
        <div class="ac-row"><span>온타리오 토지 양도세</span><strong id="ac-ltt-on">$0</strong></div>
        <div class="ac-row" id="ac-ltt-mltt-row"><span>토론토 토지 양도세</span><strong id="ac-ltt-mltt">$0</strong></div>
        <div class="ac-row" id="ac-ltt-rebate-row" style="display:none;"><span>첫 주택 구매자 환급</span><strong id="ac-ltt-rebate">−$0</strong></div>
        <div class="ac-row" id="ac-mo-taxrow"><span>월 예상 재산세</span><strong id="ac-mo-tax">$0</strong></div>
        <div class="ac-row" id="ac-mo-feerow" style="display:none;"><span id="ac-mo-feelbl">월 HOA 수수료</span><strong id="ac-mo-fee">$0</strong></div>
        <div class="ac-row"><span>변호사 + 권원 + 조정 <em class="ac-note">대략</em></span><strong id="ac-legal">$0</strong></div>
        <div class="ac-row ac-row-total"><span>대략 클로징 총 현금</span><strong id="ac-total-cash">~$0</strong></div>
      </div>
      <p class="calc-disclaimer">예시 수치입니다. 자세한 내용은 <a href="/disclaimer#calculators">면책 조항</a>을 참조하세요.</p>
    </div>
  </div></div></section>
  <LCTA heading="\uc2e4\uc81c \uc22b\uc790\ub85c \uc548\ub0b4\ud574\ub4dc\ub9b4\uae4c\uc694?" lead="\uc18c\ub4dd\uacfc \uad00\uc2ec \uc9c0\uc5ed\uc744 \uc54c\ub824\uc8fc\uc138\uc694. 15\ubd84 \ud1b5\ud654\ub85c \uc5b4\ub5a4 \uac00\uaca9\ub300\uac00 \uc2e4\uc81c \uc801\ud569\ud55c\uc9c0, \uc5b4\ub5a4 \uac83\uc774 \ubd80\uc801\ud569\ud55c\uc9c0 \uc815\ud655\ud788 \uc54c \uc218 \uc788\uc2b5\ub2c8\ub2e4." />
  <LFooter />

  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('en-CA',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function pRate(r,n){const s=r/200;return Math.pow(1+s,2/n)-1;}
      function mPay(p,r,y){if(p<=0||y<=0)return 0;const rr=pRate(r,12),n=y*12;if(rr===0)return p/n;return p*rr/(1-Math.pow(1+rr,-n));}
      function cmhc(l){if(l>95)return null;if(l>90)return .04;if(l>85)return .031;if(l>80)return .028;return 0;}
      function minDp(p){if(p>1500000)return p*.2;if(p<=500000)return p*.05;return 500000*.05+(p-500000)*.1;}
      function ontLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000)t+=(p-2000000)*.025;return t;}
      function torMLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000){const lx=[[3000000,.025],[4000000,.035],[5000000,.045],[10000000,.055],[20000000,.065]];let l=2000000;for(const[u,r]of lx){if(p>l){const x=Math.min(p,u)-l;if(x>0)t+=x*r;}l=u;}if(p>20000000)t+=(p-20000000)*.075;}return t;}
      const FT_ONT=4000,FT_TOR=4475;
      const $=id=>document.getElementById(id);
      ['ac-income','ac-price','ac-savings','ac-rate','ac-amort','ac-location','ac-fthb','ac-proptype','ac-proptax','ac-fee'].forEach(id=>{const el=$(id);if(!el)return;el.addEventListener('input',calc);el.addEventListener('change',calc);});
      function calc(){
        const inc=Math.max(0,parseFloat($('ac-income').value)||0);const p=Math.max(0,parseFloat($('ac-price').value)||0);
        const s=Math.max(0,parseFloat($('ac-savings').value)||0);const r=Math.max(0,parseFloat($('ac-rate').value)||0);
        const am=parseInt($('ac-amort').value,10)||25;const loc=$('ac-location').value;const fthb=$('ac-fthb').checked;
        const pt=$('ac-proptype').value;const ptx=parseFloat($('ac-proptax').value);const fee=parseFloat($('ac-fee').value);
        const fr=$('ac-fee-row'),fl=$('ac-fee-label');
        if(pt==='freehold')fr.style.display='none';
        else if(pt==='freehold-hoa'){fr.style.display='';fl.innerHTML="6. HOA \uc218\uc218\ub8cc"+' <span class="hint">'+"\uc6d4. \uc11c\uba85 \uc804 \ubb38\uc758 \u2014 \uc77c\ubd80\ub294 \ub09c\ubc29, \ubb3c, \uc804\uae30\ub97c \ud3ec\ud568."+'</span>';}
        else{fr.style.display='';fl.innerHTML="6. \uad00\ub9ac\ube44"+' <span class="hint">'+"\uc6d4. \uc11c\uba85 \uc804 \ubb38\uc758 \u2014 \uc77c\ubd80\ub294 \ub09c\ubc29, \ubb3c, \uc804\uae30\ub97c \ud3ec\ud568."+'</span>';}
        const mDp=minDp(p),ds=Math.min(s,p),sh=Math.max(0,mDp-ds),ad=ds;
        const ltv=p>0?(p-ad)/p*100:0,pr=cmhc(ltv);const bl=Math.max(0,p-ad);
        const cp=(pr!==null&&pr>0)?bl*pr:0;const tm=bl+cp,m=mPay(tm,r,am);
        const ot=ontLTT(p),mt=loc==='toronto'?torMLTT(p):0;
        let re=0;if(fthb){re=Math.min(ot,FT_ONT);if(loc==='toronto')re+=Math.min(mt,FT_TOR);}
        const tl=Math.max(0,ot+mt-re),le=2500,ctc=ad+tl+le;
        const sr=Math.max(r+2,5.25),sp=mPay(tm,sr,am);
        const mi=inc/12,ptm=(isFinite(ptx)&&ptx>=0)?ptx:(p*.007/12);
        const of=(isFinite(fee)&&fee>=0&&pt!=='freehold')?fee:0;
        const hm=pt==='condo'?0:150;const gds=mi>0?(sp+ptm+of+hm)/mi*100:0;
        $('ac-monthly').textContent=fmt(m);$('ac-cash').textContent=fmt(ctc);
        $('ac-down').textContent=fmt(ad);$('ac-mortgage').textContent=fmt(tm);$('ac-cmhc').textContent=fmt(cp);
        $('ac-cmhc-note').textContent=pr===null?"(\ud5c8\uc6a9 \uc548 \ub428 \u2014 \ucd5c\uc18c 5% \ub354 \ud544\uc694)":pr===0?"(\uacc4\uc57d\uae08 20%+ \u2014 \ubcf4\ud5d8 \ubd88\ud544\uc694)":"(\ub300\ucd9c\uc758 {pct}%)".replace('{pct}',(pr*100).toFixed(2));
        $('ac-ltt-on').textContent=fmt(ot);$('ac-ltt-mltt').textContent=fmt(mt);$('ac-ltt-mltt-row').style.display=loc==='toronto'?'':'none';
        if(re>0){$('ac-ltt-rebate-row').style.display='';$('ac-ltt-rebate').textContent='−'+fmt(re);}else{$('ac-ltt-rebate-row').style.display='none';}
        $('ac-mo-tax').textContent=fmt(ptm)+'/월';
        const frb=$('ac-mo-feerow');if(pt==='freehold')frb.style.display='none';else{frb.style.display='';$('ac-mo-feelbl').textContent=pt==='condo'?"\uc6d4 \uad00\ub9ac\ube44":월 HOA 수수료;$('ac-mo-fee').textContent=fmt(of)+'/월';}
        $('ac-legal').textContent=fmt(le);$('ac-total-cash').textContent='~'+fmt(ctc);
        let vt,vs,vc;
        if(inc<=0||p<=0){vt=위에 숫자를 입력하세요.;vs=은행은 수입의 얼마가 주거비에 사용되는지 확인합니다. 32% 미만이 안전. 39% 초과 시 은행은 거절할 가능성이 큽니다.;vc='ac-verdict-neutral';}
        else if(pr===null){vt="\uc774 \uac00\uaca9\uc5d0 \uc800\ucd95\uc774 \ub354 \ud544\uc694\ud569\ub2c8\ub2e4.";vs="150\ub9cc+ $ \uc8fc\ud0dd\uc758 \ucd5c\uc18c \uacc4\uc57d\uae08\uc740 20%. \uadf8 \uc774\ud558\uc785\ub2c8\ub2e4. \ub354 \uc800\ucd95\ud558\uac70\ub098 \ub0ae\uc740 \uac00\uaca9\uc744 \ubaa9\ud45c\ub85c \ud558\uc138\uc694.";vc='ac-verdict-red';}
        else if(sh>0){vt="\uacc4\uc57d\uae08\uc774 \ubd80\uc871\ud569\ub2c8\ub2e4.";vs="\ucd5c\uc18c {mDp}\uc774 \ud544\uc694. {sh} \ubd80\uc871\ud569\ub2c8\ub2e4. \uc740\ud589\uc774 \uc2b9\uc778\ud560 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4.".replace('{mDp}',fmt(mDp)).replace('{sh}',fmt(sh));vc='ac-verdict-red';}
        else if(gds>39){vt="\uc740\ud589\uc774 \uc2b9\uc778\ud558\uc9c0 \uc54a\uc744 \uac00\ub2a5\uc131\uc774 \ub192\uc2b5\ub2c8\ub2e4.";vs="\uc218\uc785\uc758 {gds}%\uc5d0\uc11c \uc8fc\uac70\ube44\uac00 \ub108\ubb34 \ub9ce\uc774 \ucc28\uc9c0\ud569\ub2c8\ub2e4. \ub354 \ub0ae\uc740 \uac00\uaca9 \ub610\ub294 \ub354 \ub9ce\uc740 \uacc4\uc57d\uae08\uc744 \uc2dc\ub3c4\ud558\uc138\uc694.".replace('{gds}',gds.toFixed(1));vc='ac-verdict-red';}
        else if(gds>32){vt="\ube60\ub4ef. \uac00\ub2a5\ud558\uc9c0\ub9cc \ub290\ub084 \uac83\uc785\ub2c8\ub2e4.";vs="{gds}%\uc5d0\uc11c \uc740\ud589\uc758 \uc5c4\uaca9\ud55c \ud55c\ub3c4(39%) \ub0b4\uc5d0 \uc788\uc9c0\ub9cc \ud3b8\uc548\ud55c \uad6c\uac04(32%) \uc704\uc785\ub2c8\ub2e4.".replace('{gds}',gds.toFixed(1));vc='ac-verdict-yellow';}
        else{vt="\uac10\ub2f9\ud558\uc2e4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.";vs="{gds}%\uc5d0\uc11c \uc8fc\uac70\ube44\uac00 \uc548\uc804 \uad6c\uac04 \ub0b4\uc5d0 \ud3b8\uc548\ud558\uac8c \uc788\uc2b5\ub2c8\ub2e4.".replace('{gds}',gds.toFixed(1));vc='ac-verdict-green';}
        const v=$('ac-verdict');v.classList.remove('ac-verdict-neutral','ac-verdict-green','ac-verdict-yellow','ac-verdict-red');v.classList.add(vc);
        $('ac-verdict-title').textContent=vt;$('ac-verdict-sub').textContent=vs;
      }
      calc();
    })();
  </script>
</BaseLayout>
