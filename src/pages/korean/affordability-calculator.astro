---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/KoreanTopBar.astro';
import LHeader from '../../components/KoreanHeader.astro';
import LFooter from '../../components/KoreanFooter.astro';
import LCTA from '../../components/KoreanCTASection.astro';
---
<BaseLayout title="\uad6c\ub9e4 \uac00\ub2a5 \uacc4\uc0b0\uae30 | Peter Law" description="\uc5bc\ub9c8\uc758 \uc9d1\uc744 \uc0b4 \uc218 \uc788\ub098\uc694? \uc18c\ub4dd, \ubd80\ucc44, \uce90\ub098\ub2e4 \ub300\ucd9c \uaddc\uce59(GDS/TDS + \uc2a4\ud2b8\ub808\uc2a4 \ud14c\uc2a4\ud2b8)\uc5d0 \uae30\ubc18\ud55c \ucd5c\ub300 \uad6c\ub9e4 \uac00\uaca9 \uacc4\uc0b0." lang="ko" bodyClass="ko calc-page">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">구매 가능 계산기</div><h1>실제로 얼마나 감당할 수 있나요?</h1><p>캐나다 대출 규칙에 기반한 최대 구매 가격 추정 — GDS/TDS 비율과 연방 모기지 스트레스 테스트.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="calc">
    <div class="calc-fields">
      <div class="calc-field"><label for="af-income">연간 가구 소득</label><div class="input-prefix"><input type="number" id="af-income" value="120000" min="0" step="1000" /></div></div>
      <div class="calc-field"><label for="af-debt">월간 부채 상환</label><div class="input-prefix"><input type="number" id="af-debt" value="500" min="0" step="50" /></div></div>
      <div class="calc-field"><label for="af-down">계약금</label><div class="input-prefix"><input type="number" id="af-down" value="100000" min="0" step="5000" /></div></div>
      <div class="calc-field"><label for="af-rate">모기지 이자율</label><div class="input-suffix"><input type="number" id="af-rate" value="5.0" min="0" step="0.05" /></div></div>
      <div class="calc-field"><label for="af-amort">상환 기간 (년)</label><input type="number" id="af-amort" value="25" min="5" max="35" /></div>
    </div>
    <div class="calc-result">
      <div class="calc-result-main"><span class="label">최대 가격</span><span id="af-max">$0</span></div>
      <div class="calc-result-breakdown">
        <div class="row"><span>GDS 32% 기준</span><strong id="af-gds">$0</strong></div>
        <div class="row"><span>TDS 40% 기준</span><strong id="af-tds">$0</strong></div>
        <div class="row"><em>둘 중 낮은 것이 한도</em></div>
      </div>
    </div>
    <p class="calc-disclaimer">추정치입니다. 표준 GDS/TDS 비율과 스트레스 테스트 기반. 실제 승인은 모기지 브로커에게 확인.</p>
  </div></div></section>
  <LCTA />
  <LFooter />
  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('en-CA',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function pRate(r,n){const s=r/200;return Math.pow(1+s,2/n)-1;}
      function maxPrincipal(pmt,r,y){const rr=pRate(r,12),n=y*12;if(rr===0)return pmt*n;return pmt*(1-Math.pow(1+rr,-n))/rr;}
      function c(){
        const inc=parseFloat(document.getElementById('af-income').value)||0;
        const debt=parseFloat(document.getElementById('af-debt').value)||0;
        const dn=parseFloat(document.getElementById('af-down').value)||0;
        const r=parseFloat(document.getElementById('af-rate').value)||0;
        const y=parseInt(document.getElementById('af-amort').value,10)||25;
        const sr=Math.max(r+2,5.25);
        // Stress test at higher rate for qualifying
        const mi=inc/12;
        const gdsAvail=mi*.32; const tdsAvail=mi*.40-debt;
        // Assume $250/mo tax + $150/mo heat + $75/mo condo
        const otherHousing=475;
        const gdsPmt=Math.max(0,gdsAvail-otherHousing);
        const tdsPmt=Math.max(0,tdsAvail-otherHousing);
        const gdsMax=maxPrincipal(gdsPmt,sr,y)+dn;
        const tdsMax=maxPrincipal(tdsPmt,sr,y)+dn;
        const maxP=Math.min(gdsMax,tdsMax);
        document.getElementById('af-max').textContent=fmt(maxP);
        document.getElementById('af-gds').textContent=fmt(gdsMax);
        document.getElementById('af-tds').textContent=fmt(tdsMax);
      }
      ['af-income','af-debt','af-down','af-rate','af-amort'].forEach(id=>{const el=document.getElementById(id);el.addEventListener('input',c);el.addEventListener('change',c);});c();
    })();
  </script>
</BaseLayout>
