---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/KoreanTopBar.astro';
import LHeader from '../../components/KoreanHeader.astro';
import LFooter from '../../components/KoreanFooter.astro';
import LCTA from '../../components/KoreanCTASection.astro';
---
<BaseLayout title="CMHC \ubcf4\ud5d8 \uacc4\uc0b0\uae30 | Peter Law" description="CMHC \ubaa8\uae30\uc9c0 \uae30\ubcf8 \ubcf4\ud5d8\ub8cc\ub97c \uba87 \ucd08 \ub9cc\uc5d0 \ucd94\uc815\ud558\uc138\uc694. \uce90\ub098\ub2e4 \uaddc\uc815: \ucd5c\uc18c \uacc4\uc57d\uae08, LTV \uae30\ubc18 \ubcf4\ud5d8\ub8cc\uc728, 150\ub9cc \ub2ec\ub7ec \ubcf4\ud5d8 \uac00\ub2a5 \ud55c\ub3c4." lang="ko" bodyClass="ko calc-page">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">CMHC 계산기</div><h1>모기지 기본 보험이 얼마인가요?</h1><p>계약금이 20% 미만이면 CMHC 보험을 지불해야 합니다. 보험료는 모기지에 포함됩니다.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="calc">
    <div class="calc-fields">
      <div class="calc-field calc-field-full"><label for="cm-price">구매 가격</label><div class="input-prefix"><input type="number" id="cm-price" value="800000" min="0" step="5000" /></div></div>
      <div class="calc-field"><label for="cm-down">계약금</label><div class="input-prefix"><input type="number" id="cm-down" value="80000" min="0" step="1000" /></div></div>
      <div class="calc-field"><label for="cm-down-pct">계약금 (%)</label><div class="input-suffix"><input type="number" id="cm-down-pct" value="10" min="0" max="100" step="0.5" /></div></div>
    </div>
    <div class="calc-result">
      <div class="calc-result-main"><span class="label">CMHC 보험료</span><span id="cm-premium">$0</span></div>
      <div class="calc-result-breakdown">
        <div class="row"><span>대출 대 가치 비율 (LTV)</span><strong id="cm-ltv">0%</strong></div>
        <div class="row"><span>기본 모기지 잔액</span><strong id="cm-loan">$0</strong></div>
        <div class="row"><span>총 모기지 (보험료 포함)</span><strong id="cm-total">$0</strong></div>
      </div>
    </div>
    <p class="calc-disclaimer">추정치입니다. 150만 달러 미만 자가 주택에 대한 2026년 표준 CMHC 요율 기반. 모기지 브로커에게 확인하세요.</p>
  </div></div></section>
  <LCTA />
  <LFooter />
  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('en-CA',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function cmhcR(l){if(l>95)return null;if(l>90)return .04;if(l>85)return .031;if(l>80)return .028;return 0;}
      let editing=null;
      function c(){
        const p=parseFloat(document.getElementById('cm-price').value)||0;
        let d=parseFloat(document.getElementById('cm-down').value)||0;
        let pct=parseFloat(document.getElementById('cm-down-pct').value)||0;
        if(editing==='pct'){d=p*pct/100;document.getElementById('cm-down').value=d.toFixed(0);}
        else if(editing==='dollar'){pct=p>0?d/p*100:0;document.getElementById('cm-down-pct').value=pct.toFixed(2);}
        else{pct=p>0?d/p*100:0;document.getElementById('cm-down-pct').value=pct.toFixed(2);}
        const ltv=p>0?(p-d)/p*100:0;
        const bl=Math.max(0,p-d);
        const rate=cmhcR(ltv);
        const premium=(rate!==null&&rate>0)?bl*rate:0;
        document.getElementById('cm-premium').textContent=fmt(premium);
        document.getElementById('cm-ltv').textContent=ltv.toFixed(1)+'%';
        document.getElementById('cm-loan').textContent=fmt(bl);
        document.getElementById('cm-total').textContent=fmt(bl+premium);
      }
      document.getElementById('cm-price').addEventListener('input',()=>{editing='price';c();editing=null;});
      document.getElementById('cm-down').addEventListener('input',()=>{editing='dollar';c();editing=null;});
      document.getElementById('cm-down-pct').addEventListener('input',()=>{editing='pct';c();editing=null;});
      c();
    })();
  </script>
</BaseLayout>
