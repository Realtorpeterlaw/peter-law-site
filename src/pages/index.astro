---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="Peter Law - Toronto Real Estate" description="Peter Law | Toronto Rental & Real Estate Expert. Helping renters find approved, move-in ready homes across Toronto. Full-service representation from search to keys. Call 647-888-8472.">

  <TopBar />
  <Header />

  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <div class="eyebrow">Toronto · Downtown · Waterfront · GTA</div>
        <h1 class="hero-h">Toronto rentals, <em>handled the right way.</em></h1>
        <p class="hero-sub">Helping newcomers, professionals, and families navigating Toronto's Rental Market. Pre-approved fast.</p>
        <div class="hero-ctas hero-ctas-stacked">
          <a href={BOOKING_URL} class="btn-primary">
            Book a 15-min call
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/free-home-evaluation" class="btn-outline">
            FREE HOME EVALUATION
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/for-renters" class="btn-secondary">Or — how renting with me works</a>
        </div>
        <div class="hero-trust">No pressure, no obligation. Real answers in your first call.</div>
      </div>
      <div>
        <div class="hero-photo">
          <img src="/photos/peter-portrait.webp" alt="Peter Law, Toronto real estate agent, on a downtown street with the CN Tower behind." width="1500" height="1887" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="proof-bar">
    <div class="wrap proof-grid">
      <a class="proof-item proof-link" href="https://www.airbnb.ca/users/show/130982023" target="_blank" rel="noopener"><div class="proof-num">400+</div><div class="proof-lbl">Airbnb guest reviews</div></a>
      <div class="proof-item"><div class="proof-num">EN · 中文</div><div class="proof-lbl">Bilingual service</div></div>
      <div class="proof-item"><div class="proof-num">RECO</div><div class="proof-lbl">Registered, Ontario</div></div>
      <a class="proof-item proof-link" href="https://www.homelifegolconda.com/" target="_blank" rel="noopener"><div class="proof-num">HomeLife</div><div class="proof-lbl">Golconda Realty Inc.</div></a>
    </div>
  </section>

  <section class="major">
    <div class="wrap">
      <div class="why-grid">
        <form class="quiz-form" method="POST" action="https://formspree.io/f/xnjrzgda">
          <div class="quiz-eyebrow">Quick rental survey</div>
          <h3 class="quiz-heading">What are you looking for?</h3>
          <p class="quiz-sub">Minimum 1 Year duration.</p>
          <div class="quiz-fields">
            <div class="quiz-field">
              <label for="quiz-beds">Bedrooms</label>
              <select id="quiz-beds" name="bedrooms" required>
                <option value="">Select…</option>
                <option>Studio</option>
                <option>1 BR</option>
                <option>1 BR + Den</option>
                <option>2 BR</option>
                <option>3 BR</option>
                <option>4+ BR</option>
              </select>
            </div>
            <div class="quiz-field">
              <label for="quiz-baths">Bathrooms</label>
              <select id="quiz-baths" name="bathrooms" required>
                <option value="">Select…</option>
                <option>1</option>
                <option>1.5</option>
                <option>2</option>
                <option>2.5</option>
                <option>3+</option>
              </select>
            </div>
            <div class="quiz-field">
              <label for="quiz-parking">Parking</label>
              <select id="quiz-parking" name="parking" required>
                <option value="">Select…</option>
                <option>Not needed</option>
                <option>1 spot</option>
                <option>2 spots</option>
                <option>3+ spots</option>
              </select>
            </div>
            <div class="quiz-field">
              <label for="quiz-budget">Budget / month</label>
              <select id="quiz-budget" name="budget" required>
                <option value="">Select…</option>
                <option>Under $2,000</option>
                <option>$2,000 – $2,500</option>
                <option>$2,500 – $3,000</option>
                <option>$3,000 – $3,500</option>
                <option>$3,500 – $4,500</option>
                <option>$4,500+</option>
              </select>
            </div>
            <div class="quiz-field">
              <label for="quiz-movein">Move-in date</label>
              <input id="quiz-movein" name="move_in_date" type="date" required>
            </div>
            <div class="quiz-field quiz-field-full">
              <label for="quiz-location">Location preference</label>
              <select id="quiz-location" name="location" required>
                <option value="">Select…</option>
                <option>Downtown core</option>
                <option>King West / Liberty Village</option>
                <option>Yonge & Bloor / Yorkville</option>
                <option>Waterfront / Harbourfront</option>
                <option>Yonge–Eglinton</option>
                <option>East Toronto (Leslieville, East York)</option>
                <option>Markham / GTA North</option>
                <option>Walking distance to Subway Station</option>
                <option>Walking distance to Union Subway Station</option>
                <option>Walking distance to UofT St. George</option>
                <option>Walking distance to Waterfront</option>
                <option>Open to suggestions</option>
              </select>
            </div>
            <div class="quiz-field quiz-field-full">
              <label for="quiz-email">Email (so I can send you matches)</label>
              <input id="quiz-email" name="email" type="email" required autocomplete="email" placeholder="your@email.com">
            </div>
          </div>
          <div class="hp-field" aria-hidden="true">
            <label for="quiz-gotcha">Don't fill this</label>
            <input id="quiz-gotcha" name="_gotcha" type="text" tabindex="-1" autocomplete="off">
          </div>
          <input type="hidden" name="_subject" value="New Quick Rental Survey">
          <input type="hidden" name="_next" value="https://www.realtorpeterlaw.com/contact/thanks">
          <button type="submit" class="btn-primary quiz-cta">
            Send my survey
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
        <div class="why-points">
          <div class="why-point"><div class="why-point-num">01</div><h3>Pre-approval before search</h3><p>We get your documents in order before we step into a single unit. In Toronto's market, you have hours to decide — not days. Preparation is what wins.</p></div>
          <div class="why-point"><div class="why-point-num">02</div><h3>Viewings</h3><p>Pick-up and Drop-off is included<sup>*</sup></p></div>
          <div class="why-point"><div class="why-point-num">03</div><h3>Concierge Service</h3><p>Registration Forms, Pre-Inspection, contractor referrals, Unit overview. The job doesn't end at the keys.</p></div>
          <p class="why-footnote"><sup>*</sup> Pick-up and Drop-off only available for Downtown Toronto and service area.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="major process">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">How working together works</div>
        <h2 class="section-h">From first call to keys in hand,<br>Timeline ~2 to 3 weeks or less.</h2>
      </div>
      <div class="process-steps">
        <div class="step"><div class="step-num">STEP 01</div><h3>15-min intro call</h3><p>Tell me what you need, where, and when. I'll tell you exactly what to expect and what to prepare.</p></div>
        <div class="step"><div class="step-num">STEP 02</div><h3>Get approval-ready</h3><p>Credit, employment, references, deposit. We package it so landlords say yes the same day.</p></div>
        <div class="step"><div class="step-num">STEP 03</div><h3>Tour the right ones</h3><p>I filter the market for fit, not just listings. You see 3–5 places worth your time, not 30.</p></div>
        <div class="step"><div class="step-num">STEP 04</div><h3>Sign, move, settle</h3><p>Lease reviewed line by line. Movers, utilities, building intro — handled.</p></div>
      </div>
    </div>
  </section>

  <section class="major testimonials">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">Recent Reviews</div>
        <h2 class="section-h">Real Torontonians, real wins.</h2>
      </div>
      <div class="test-grid">
        <div class="test-card"><p class="test-quote">"Moving to Toronto after many years away, the rental process was difficult — but Peter helped me navigate it and made the whole thing seamless and smooth. Definitely recommend."</p><div class="test-attr"><strong>Jethro</strong>Newcomer · Toronto rental · 2026</div></div>
        <div class="test-card"><p class="test-quote">"Peter took the time to understand our priorities and guided us every step of the way. His patience and calm made the process stress-free — even when decisions felt overwhelming."</p><div class="test-attr"><strong>Olu</strong>Family rental · 2025</div></div>
        <div class="test-card"><p class="test-quote">"Outstanding throughout my condo search and purchase. Responsive, strategic, patient, and genuinely had my best interests in mind every step of the way."</p><div class="test-attr"><strong>David</strong>Condo purchase · 2026</div></div>
      </div>
    </div>
  </section>

  <section class="major newsletter">
    <div class="wrap">
      <div class="newsletter-inner">
        <div class="section-eyebrow">Monthly Market Report</div>
        <h2 class="section-h">What's actually happening with Toronto Real Estate.</h2>
        <p class="section-lead">Information is important. Rental & Sales Report. Stay ahead by subscribing below.</p>
        <form class="newsletter-form" method="GET" action="https://peters-newsletter-469474.beehiiv.com/subscribe">
            <label for="newsletter-email" class="sr-only">Email address</label>
            <input id="newsletter-email" type="email" name="email" placeholder="your@email.com" required autocomplete="email" />
            <button type="submit" class="btn-primary">Subscribe
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </form>
        <p class="newsletter-trust">Unsubscribe anytime. Your email isn't shared with anyone.</p>
      </div>
    </div>
  </section>

  <CTASection />
  <Footer />
</BaseLayout>
