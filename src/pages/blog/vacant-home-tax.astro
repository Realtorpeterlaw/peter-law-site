const publishedDate = '2026-07-15';
const articleTitle = 'Vacant Home Tax';
const articleDescription = "A plain-English guide to Toronto's Vacant Home Tax. What it is, why it matters, how the City decides if your home is 'occupied' or 'vacant', the exemptions, and the penalties for missing the declaration.";
const articleUrl = 'https://www.realtorpeterlaw.com/blog/vacant-home-tax';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/about' },
  publisher: {
    '@type': 'Organization',
    name: 'Peter Law — Toronto Real Estate',
    logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' },
  },
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'Vacant Home Tax Toronto, VHT declaration deadline, Toronto vacant property tax, occupancy status declaration, principal residence exemption Toronto, vacant home tax exemptions, Toronto property tax lien, snowbirds vacant home tax, change of ownership vacant home tax',
};

const hreflangAlternates = [
  { hreflang: 'en-CA', href: 'https://www.realtorpeterlaw.com/blog/vacant-home-tax/' },
  { hreflang: 'zh-CN', href: 'https://www.realtorpeterlaw.com/chinese/blog/vacant-home-tax/' },
