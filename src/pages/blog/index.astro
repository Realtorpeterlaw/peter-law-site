---
<BaseLayout
  title="Toronto Real Estate Blog | Peter Law"
  description="Real talk on Toronto rentals, sales, financing, and Ontario real estate legislation. Plain-English explainers from a bilingual Toronto realtor. Updated regularly."
  bodyClass="blog-page"
>
  <TopBar />
  <Header active="blog" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Blog</div>
      <h1>Real talk on Toronto real estate.</h1>
      <p>Rumors, Trends, Markets, Finance, Policy, Immigration and staying&nbsp;ahead...</p>
      <div class="blog-search" role="search">
        <svg class="blog-search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.6"/><path d="M11 11l3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        <input id="blog-search-input" type="search" placeholder="Search articles…" aria-label="Search blog articles" autocomplete="off" />
      </div>
    </div>
  </section>

  <section class="major" style="padding-top: 32px;">
    <div class="wrap">
      <div class="blog-list">
        {posts.map((post) => (
          <article class="blog-card" data-search={`${post.title} ${post.eyebrow}`.toLowerCase()}>
            <a href={`/blog/${post.slug}`} class="blog-card-link" aria-label={`Read: ${post.title}`}>
              {post.iconKey && icons[post.iconKey] && (
                <div class="blog-card-icon" set:html={icons[post.iconKey]} />
              )}
              <div class="blog-card-text">
                <div class="blog-card-eyebrow">{post.eyebrow}</div>
                <h2 class="blog-card-title">{post.title}</h2>
                <div class="blog-card-meta">
                  <span>{post.readMin} min read</span>
                  <span class="blog-card-read">Read more
                    <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="blog-newsletter">
        <div class="eyebrow">Monthly Market Report</div>
        <h3>New articles, in your inbox.</h3>
        <p>Subscribe to the monthly newsletter and you'll get every new explainer the day it goes live. Free, no pitch.</p>
        <form class="newsletter-form" method="GET" action="https://peters-newsletter-469474.beehiiv.com/subscribe" style="margin-top:14px;max-width:520px;">
          <label for="blog-newsletter-email" class="sr-only">Email address</label>
          <input id="blog-newsletter-email" type="email" name="email" placeholder="your@email.com" required autocomplete="email" />
          <button type="submit" class="btn-primary">Subscribe
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
        <p style="font-size:12px;color:var(--ink-mute);margin-top:10px;">Unsubscribe anytime. Your email isn't shared.</p>
      </div>
    </div>
  </section>

  <p class="blog-no-results" id="blog-no-results" hidden>No articles match that search yet. Try a different word.</p>

  <CTASection heading="Got a question for an article?" lead="If there's a topic you've been Googling and can't find a straight answer to, send it over. I'm always looking for the next one to write." />
  <Footer />

  <script>
    (function() {
      const input = document.getElementById('blog-search-input');
      const cards = document.querySelectorAll('.blog-card');
      const noResults = document.getElementById('blog-no-results');
      if (!input || !cards.length) return;
      function filter() {
        const q = input.value.trim().toLowerCase();
        let visibleCount = 0;
        cards.forEach(function(card) {
          const text = card.getAttribute('data-search') || '';
          const match = !q || text.indexOf(q) !== -1;
          card.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });
        if (noResults) noResults.hidden = (q.length === 0 || visibleCount > 0);
      }
      input.addEventListener('input', filter);
    })();
  </script>
</BaseLayout>
