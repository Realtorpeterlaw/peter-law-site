export const prerender = true;

const publishedDate = '2026-07-15';
const articleTitle = 'HCRA: Illegal Building';
const articleDescription = "A plain-English guide to illegal building in Ontario. What HCRA is, what counts as an illegal builder, the four real risks to home buyers, how to check a builder before you sign, and how to report someone building or selling without a licence.";
const articleUrl = 'https://www.realtorpeterlaw.com/blog/hcra-illegal-building';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/about' },
  publisher: {
    '@type': 'Organization',
    name: 'Peter Law — Toronto Real Estate',
    logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' },
  },
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'HCRA Ontario, illegal building Ontario, Home Construction Regulatory Authority, unlicensed home builder Ontario, Tarion warranty, new home builder licence, Ontario Builder Directory, report illegal builder, new home consumer protection Ontario',
};
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Toronto Real Estate Blog`}
  description={articleDescription}
  bodyClass="guide-page article-page"
>
  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/blog" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>Blog</a> · Buyer Protection</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">In Ontario, anyone who builds or sells a brand-new home has to have a licence. When they don't, it's called illegal building. Here's what that means, why it matters if you're buying, and the free 30-second check that protects you.</p>
        <div class="article-byline">
          <span>By <a href="/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>July 15, 2026</time>
          <span class="dot">·</span>
          <span>7 min read</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>On this page</h4>
            <ul>
              <li><a href="#what">What HCRA is</a></li>
              <li><a href="#newhome">What "new home" means</a></li>
              <li><a href="#illegal">The 3 things that count as illegal building</a></li>
              <li><a href="#risks">The 4 real risks to buyers</a></li>
              <li><a href="#check">How to check your builder</a></li>
              <li><a href="#report">How to report illegal building</a></li>
              <li><a href="#action">What HCRA does about it</a></li>
              <li><a href="#mistakes">Common mistakes</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <p><strong>Quick answer:</strong> Ontario has a rule. Anyone who builds or sells a brand-new home needs a licence from the <strong>HCRA — the Home Construction Regulatory Authority</strong>. When a builder skips that licence, it's called illegal building. If you buy from an unlicensed builder, the house might not be safe, you probably won't get the <strong>Tarion warranty</strong> (Ontario's new-home warranty), and you have almost no legal protection when things go wrong. The fix takes 30 seconds: search the builder's name on the <strong>Ontario Builder Directory</strong> before you sign anything.</p>

            <div class="callout"><strong>Who this article is for:</strong> anyone buying or thinking about buying a brand-new home in Ontario — pre-construction condos, new detached houses, semis, townhouses, or any unit nobody has lived in yet. Newcomers especially: Ontario has a builder-licence system that many other places don't, and it exists to protect you.</div>

            <h2 id="what">What HCRA is</h2>
            <p>The <em>Home Construction Regulatory Authority</em> (HCRA) is the Ontario body that licenses everyone in the province who builds or sells brand-new homes. Think of it like a driver's licence, but for home builders. Before someone is allowed to build or sell a new home to the public, they have to prove to HCRA that they know what they're doing — business planning, project management, and Ontario's building code rules.</p>
            <p>HCRA also enforces a Code of Ethics that licensed builders must follow. If a builder does something dishonest, HCRA can take away their licence, fine them, or press charges.</p>

            <details class="b60-section-toggle" id="newhome">
              <summary class="b60-section-toggle-summary">What "new home" means</summary>
              <div class="b60-section-body">
                <p>Before we talk about illegal building, one thing to be clear about: what is a "new home"?</p>
                <p>The simple answer: <strong>a home nobody has ever lived in.</strong> If the last owner or tenant of a home was… no one, it's new. That includes:</p>
                <ul class="bullets">
                  <li>Pre-construction condos (bought from a floor plan before the building is up).</li>
                  <li>Freshly built detached houses, semi-detached houses, and townhouses.</li>
                  <li>Newly finished condo units that have never been occupied.</li>
                </ul>
                <p>Once someone has lived in the home — even for a day — it's considered <em>resale</em>, not new. Resale homes don't fall under HCRA's builder-licence rules. They're covered by other consumer protections instead.</p>
              </div>
            </details>

            <details class="b60-section-toggle" id="illegal">
              <summary class="b60-section-toggle-summary">The 3 things that count as illegal building</summary>
              <div class="b60-section-body">
                <p>HCRA groups illegal building into three specific things. Any one of them puts you at risk:</p>
                <ol class="bullets">
                  <li><strong>Building a new home without a builder's licence.</strong> The person or company hammering nails and pouring foundations is not registered with HCRA.</li>
                  <li><strong>Selling a new, unoccupied home without a licence.</strong> The person you're signing the purchase agreement with is not registered with HCRA — even if a different (licensed) company did the physical building.</li>
                  <li><strong>Building a new home that has not been enrolled with Tarion — or selling one that has not qualified for Tarion enrolment.</strong> <em>Tarion</em> is Ontario's new-home warranty program. It covers you for deposits, delayed closings, and problems with the house for up to 7 years. If the home isn't enrolled, that safety net doesn't exist.</li>
                </ol>
              </div>
            </details>

            <details class="b60-section-toggle" id="risks">
              <summary class="b60-section-toggle-summary">The 4 real risks to buyers</summary>
              <div class="b60-section-body">
                <p>Working with an unlicensed builder isn't just a paperwork problem. Here's what can actually go wrong:</p>
                <ul class="bullets">
                  <li><strong>Structural defects and poor workmanship.</strong> A licensed builder had to prove they know the Ontario Building Code. An unlicensed one didn't. The home might not meet code. Worst case, it might not be safe to live in.</li>
                  <li><strong>Liability issues.</strong> Licensed builders follow a Code of Ethics that HCRA enforces. Unlicensed ones follow no code. You could be dealing with someone with a history of bad conduct, and the legal recourse is much harder.</li>
                  <li><strong>Financial exposure.</strong> Licensed builders have to prove they carry insurance and are financially responsible. Unlicensed ones don't. If the builder goes bankrupt mid-construction — or just disappears — your deposit and your investment may be gone.</li>
                  <li><strong>No warranty protection.</strong> Because the home isn't enrolled with Tarion, you lose the deposit protection, delayed-occupancy compensation, and the 1-year, 2-year, and 7-year warranty coverage that legal new-home buyers get.</li>
                </ul>
                <div class="callout"><strong>The scariest part:</strong> most of these issues don't show up on move-in day. Structural problems can take years to appear. By then, the illegal builder may be long gone, and Tarion — the safety net Ontario built for exactly these situations — can't help you because the home was never enrolled.</div>
              </div>
            </details>

            <details class="b60-section-toggle" id="check">
              <summary class="b60-section-toggle-summary">How to check your builder — 30-second free lookup</summary>
              <div class="b60-section-body">
                <p>This is the single most important thing in this whole article. <strong>Before you sign any contract with a new-home builder, look them up on the Ontario Builder Directory.</strong></p>
                <p><strong>How to do it:</strong></p>
                <ol class="bullets">
                  <li>Go to the <a href="https://obd.hcraontario.ca/" target="_blank" rel="noopener noreferrer">Ontario Builder Directory</a>.</li>
                  <li>Type in the builder's or seller's exact company name (as it appears on the contract you're about to sign).</li>
                  <li>Check that they show up as <strong>licensed and active</strong> — not "revoked", "suspended", or "not found".</li>
                  <li>Read their recent history. HCRA lists disciplinary actions, complaints, and any conditions on their licence right on the profile.</li>
                </ol>
                <p>If the builder doesn't show up at all, or if their status is anything other than active, walk away. Don't sign, don't put down a deposit, don't wait for them to "sort it out". Contact HCRA to report it (see below).</p>
                <div class="callout"><strong>Extra tip:</strong> check both the <em>building</em> company and the <em>selling</em> company. Sometimes they're the same. Sometimes they're not. Both need to be licensed for the deal to be legal.</div>
              </div>
            </details>

            <details class="b60-section-toggle" id="report">
              <summary class="b60-section-toggle-summary">How to report illegal building</summary>
              <div class="b60-section-body">
                <p>If you suspect someone is building or selling a new home without a licence — whether you're a potential buyer, a neighbour who noticed something off, or a professional in the industry — HCRA wants to hear about it.</p>
                <p><strong>Fastest path:</strong> file an <a href="https://www.hcraontario.ca/complaints/illegal-building-complaint/" target="_blank" rel="noopener noreferrer">illegal building complaint form</a> on HCRA's website. You can also reach HCRA through their <a href="https://www.hcraontario.ca/contact-us/" target="_blank" rel="noopener noreferrer">contact page</a>.</p>
                <p>Include everything you have: the person or company's name, address of the property being built or sold, any contracts or marketing materials you've seen, and screenshots of listings if there are any. Complaints can be submitted anonymously.</p>
                <p><strong>Different problem — a licensed builder behaving badly?</strong> That's not "illegal building". It's a professional-conduct concern. Report those through HCRA's regular <a href="https://www.hcraontario.ca/complaints/" target="_blank" rel="noopener noreferrer">complaints page</a> instead.</p>
              </div>
            </details>

            <details class="b60-section-toggle" id="action">
              <summary class="b60-section-toggle-summary">What HCRA does about it</summary>
              <div class="b60-section-body">
                <p>HCRA takes illegal building seriously. Their Investigations team has been growing, and they use a full range of tools:</p>
                <ul class="bullets">
                  <li><strong>Charges.</strong> HCRA can lay formal charges against individuals and companies. Repeat offenders face bigger penalties.</li>
                  <li><strong>Administrative penalties (fines).</strong> Similar to a fine, but issued by HCRA directly without going to court.</li>
                  <li><strong>Returned funds.</strong> In some cases, HCRA has returned money to purchasers who were harmed by illegal builders.</li>
                  <li><strong>Voluntary compliance.</strong> Not every case ends in a penalty. HCRA also pushes unlicensed builders to get licensed and enrol their projects with Tarion — bringing them into the legal system rather than driving them further underground.</li>
                </ul>
                <p>HCRA also works with municipalities, city building officials, real estate professionals, and other regulators to catch illegal activity earlier.</p>
                <p>All of the disciplinary decisions HCRA has issued are publicly available on the <a href="https://obd.hcraontario.ca/" target="_blank" rel="noopener noreferrer">Ontario Builder Directory</a> — so a licensed builder with a bad track record is visible to any buyer who looks.</p>
              </div>
            </details>

            <details class="b60-section-toggle" id="mistakes">
              <summary class="b60-section-toggle-summary">Common mistakes I see</summary>
              <div class="b60-section-body">
                <ul class="bullets">
                  <li><strong>"The developer's a big name, so they must be licensed."</strong> Not always. Big developer names are usually fine, but the actual selling entity might be a numbered company that isn't the parent. Always look up the exact company name on your contract.</li>
                  <li><strong>"Once I've signed, I'm locked in."</strong> If you signed with an unlicensed builder, you may have grounds to void the deal. Talk to a real estate lawyer immediately — don't just accept it.</li>
                  <li><strong>"My builder said 'Tarion is expensive, we skipped it'."</strong> That's the definition of illegal building. Walk away. Report them.</li>
                  <li><strong>"It's just a small renovation, HCRA doesn't apply."</strong> True — HCRA is about brand-new homes. Renovations to an existing home are handled differently. But if the "renovation" is really tearing down 90% of a house and building fresh, the line gets blurry. When in doubt, ask a lawyer.</li>
                  <li><strong>"I checked once when I signed. I don't need to check again."</strong> A builder's licence can be suspended or revoked between when you sign and when the home closes. If closing is more than 6 months away, check again a month before your closing date.</li>
                </ul>
              </div>
            </details>

            <h2>Bottom line</h2>
            <p>The Ontario new-home industry has real safety nets — HCRA licensing, the Ontario Builder Directory, and Tarion warranty enrolment. All three exist so that the biggest purchase of most people's lives doesn't blow up in their face. But those safety nets only work if you use them. That's a 30-second free lookup on the Ontario Builder Directory before you sign. Don't skip it.</p>
            <p>If you're going into a new-build purchase and want a second set of eyes on your builder, contract, or Tarion enrolment status — <a href="/contact">send me a quick note</a> and I'll walk through it with you.</p>

            <p class="article-source"><strong>Primary source:</strong> Home Construction Regulatory Authority — <a href="https://www.hcraontario.ca/illegal-building/" target="_blank" rel="noopener noreferrer">Illegal New Home Building in Ontario: How to Report</a>. Verify the current builder licence status on the <a href="https://obd.hcraontario.ca/" target="_blank" rel="noopener noreferrer">Ontario Builder Directory</a> before signing any new-home purchase agreement.</p>
            <p class="article-disclaimer"><em>This article is general information and is not legal advice. If you believe you have signed with, paid, or moved into a home built by an unlicensed builder, contact HCRA and a real estate lawyer immediately.</em></p>

            <div class="seo-tags" aria-label="Keywords">
              <h4>Keywords</h4>
              <ul>
                <li>HCRA Ontario</li>
                <li>Illegal building Ontario</li>
                <li>Home Construction Regulatory Authority</li>
                <li>Unlicensed home builder</li>
                <li>Ontario Builder Directory</li>
                <li>Tarion warranty</li>
                <li>New home builder licence</li>
                <li>Report illegal builder</li>
                <li>New home buyer protection</li>
                <li>Pre-construction condo checks</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTASection
      title="Buying pre-construction or a brand-new home?"
      body="I check builder licence status, Tarion enrolment, and disclosure documents on every new-build purchase I represent. If you're weeks or months away from signing — send me the builder name and I'll do the check with you."
      ctaPrimary={{ href: '/contact', label: 'Talk to Peter' }}
      ctaSecondary={{ href: '/blog', label: 'More buyer guides' }}
    />
  </article>

  <Footer />
