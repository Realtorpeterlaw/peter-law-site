export const prerender = true;

const publishedDate = '2026-06-09';
const articleTitle = "2026: Canada's Foreign Buyer Ban";
const articleDescription = "A plain-English guide to Canada's Prohibition on the Purchase of Residential Property by Non-Canadians Act — who counts as a non-Canadian, what properties are covered, the work-permit and spousal exceptions, penalties, and what stays in effect through December 31, 2026.";
const articleUrl = 'https://www.realtorpeterlaw.com/blog/foreign-buyer-ban';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/about' },
  publisher: {
