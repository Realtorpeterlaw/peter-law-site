                <li>ARRCHI stream</li>
                <li>Toronto rent supply</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <CTASection
      title="Not sure how this affects your rental hunt?"
      body="I help newcomers, professionals, and families navigate the Toronto rental market — including tracking new RHSP-supported buildings as they come online. Send me your situation and I'll tell you what's realistic in your price range and neighbourhood."
      ctaPrimary={{ href: '/contact', label: 'Talk to Peter' }}
      ctaSecondary={{ href: '/blog', label: 'More Toronto guides' }}
