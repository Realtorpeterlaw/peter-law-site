---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection.astro';
import { developers } from '../../data/condo-developers.ts';
import type { Developer } from '../../data/condo-developers.ts';

export function getStaticPaths() {
  return developers.map((dev) => ({
    params: { slug: dev.slug },
    props: { developer: dev },
  }));
}

const { developer } = Astro.props as { developer: Developer };
---
<BaseLayout
  title={`${developer.name} — Toronto Condo Developer | Peter Law`}
  description={`${developer.name}: ${developer.summary} Profile, projects, and official website.`}
  bodyClass="condo-page guide-page"
>
  <TopBar />
  <Header active="condo" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow"><a href="/condo" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>Condo</a> · Developer profile</div>
      <h1>{developer.name}</h1>
      <p class="article-lead">{developer.summary}</p>
    </div>
  </section>

  <section class="major" style="padding-top:32px;">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side">
          <h4>Quick facts</h4>
          <ul class="condo-facts">
            {developer.headquarters && <li><span class="fact-label">Headquarters</span><span class="fact-value">{developer.headquarters}</span></li>}
            {developer.founded && <li><span class="fact-label">Founded</span><span class="fact-value">{developer.founded}</span></li>}
            {developer.website && <li><span class="fact-label">Official site</span><a href={developer.website} target="_blank" rel="noopener nofollow" class="fact-value">{developer.website.replace(/^https?:\/\//, '').replace(/\/$/, '')} ↗</a></li>}
          </ul>
        </aside>

        <div class="prose-body">
          <h2>About</h2>
          <p>{developer.summary}</p>

          <h2>Projects</h2>
          {developer.projects && developer.projects.length > 0 ? (
            <table class="condo-projects-table">
              <thead><tr><th>Project</th><th>Address</th><th>Year</th><th>Status</th></tr></thead>
              <tbody>
                {developer.projects.map((p) => (
                  <tr>
                    <td>{p.name}</td>
                    <td>{p.address || '—'}</td>
                    <td>{p.year || '—'}</td>
                    <td>{p.status || '—'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <div class="callout">
              <strong>Project list:</strong> a verified list of {developer.name}'s projects is best sourced from their official site. <a href={developer.website} target="_blank" rel="noopener nofollow" style="text-decoration:underline;text-underline-offset:3px;">Visit {developer.website && developer.website.replace(/^https?:\/\//, '').replace(/\/$/, '')} →</a><br/><br/>I keep this page updated with the projects most relevant to active Toronto buyers. If you're researching a specific {developer.name} building, send me the name and I'll share what I know.
            </div>
          )}

          <p class="legal-note">This profile is informational. Developer details and project lists change. Confirm specifics with the developer directly, your real estate lawyer, or me before relying on them for a purchase decision.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection heading={`Interested in a ${developer.name} project?`} lead={`Tell me which building, and I'll share what I know — floor plates, fees, recent resale activity. No pitch.`} />
  <Footer />
</BaseLayout>
