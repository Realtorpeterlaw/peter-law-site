---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/TopBar.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTASection from '../../components/CTASection.astro';
import { developers } from '../../data/condo-developers.ts';

export const prerender = true;
---
<BaseLayout
  title="Vote: Toronto's Most Trusted Condo Developer | Peter Law"
  description="Cast your vote for the Toronto-area condo developer you trust most. See live results from other Toronto buyers and renters."
  bodyClass="condo-page poll-page"
>
  <TopBar />
  <Header active="condo" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow"><a href="/condo" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>Condo</a> · Public Poll</div>
      <h1>Which Toronto condo developer do you trust most?</h1>
      <p>Pick one. See how Toronto buyers and renters answered. One vote per visitor.</p>
    </div>
  </section>

  <section class="major" style="padding-top: 32px;">
    <div class="wrap">
      <div id="poll-root" data-state="idle">

        <div id="poll-status" class="poll-status" hidden></div>

        <div id="poll-choices" class="poll-choices">
          {developers.map((dev) => (
            <button type="button" class="poll-choice" data-slug={dev.slug} aria-label={`Vote for ${dev.name}`}>
              <span class="poll-choice-name">{dev.name}</span>
              <span class="poll-choice-meta">{dev.headquarters || ''}</span>
            </button>
          ))}
        </div>

        <div id="poll-results" class="poll-results" hidden>
          <div class="poll-results-header">
            <h2>Live Results</h2>
            <span class="poll-results-total" id="poll-total">0 votes</span>
          </div>
          <div class="poll-results-list" id="poll-results-list"></div>
          <p class="poll-disclaimer">Informal poll. Not a market study. Results reflect site visitors only.</p>
        </div>

      </div>
    </div>
  </section>

  <CTASection heading="Have a strong opinion about a developer?" lead="If you've toured, lived in, or invested in a building by one of these developers, I want to hear what you actually thought. Send me a note — it informs how I advise future clients." />
  <Footer />

  <script define:vars={{ developers: developers.map((d) => ({ slug: d.slug, name: d.name })) }}>
    (function() {
      const root = document.getElementById('poll-root');
      const choicesEl = document.getElementById('poll-choices');
      const resultsEl = document.getElementById('poll-results');
      const resultsListEl = document.getElementById('poll-results-list');
      const totalEl = document.getElementById('poll-total');
      const statusEl = document.getElementById('poll-status');
      const buttons = Array.from(document.querySelectorAll('.poll-choice'));
      const nameBySlug = Object.fromEntries(developers.map((d) => [d.slug, d.name]));

      function setStatus(msg, kind) {
        if (!msg) { statusEl.hidden = true; statusEl.textContent = ''; return; }
        statusEl.hidden = false;
        statusEl.textContent = msg;
        statusEl.className = 'poll-status' + (kind ? ' poll-status-' + kind : '');
      }

      function showResults(data) {
        const tallies = data.results || {};
        const yourVote = data.your_vote;
        const total = Object.values(tallies).reduce((a, b) => a + (b || 0), 0);
        totalEl.textContent = total === 1 ? '1 vote' : (total.toLocaleString() + ' votes');

        const sorted = Object.entries(tallies)
          .map(([slug, count]) => ({ slug, name: nameBySlug[slug] || slug, count: count || 0 }))
          .sort((a, b) => b.count - a.count);

        const maxCount = sorted[0] ? sorted[0].count : 1;
        resultsListEl.innerHTML = sorted.map(function(row) {
          const pct = total > 0 ? Math.round((row.count / total) * 100) : 0;
          const widthPct = maxCount > 0 ? (row.count / maxCount) * 100 : 0;
          const isYours = row.slug === yourVote;
          return '<div class="poll-row' + (isYours ? ' poll-row-your' : '') + '">'
            + '<div class="poll-row-label">' + row.name + (isYours ? ' <span class="poll-row-badge">your vote</span>' : '') + '</div>'
            + '<div class="poll-row-bar-wrap"><div class="poll-row-bar" style="width:' + widthPct + '%"></div></div>'
            + '<div class="poll-row-count">' + row.count.toLocaleString() + ' (' + pct + '%)</div>'
            + '</div>';
        }).join('');

        choicesEl.hidden = true;
        resultsEl.hidden = false;
        root.setAttribute('data-state', 'voted');
      }

      async function loadExistingState() {
        try {
          const r = await fetch('/api/vote', { method: 'GET' });
          if (!r.ok) return;
          const data = await r.json();
          if (data.your_vote) {
            showResults(data);
          }
        } catch (e) { /* offline; continue with idle state */ }
      }

      buttons.forEach(function(btn) {
        btn.addEventListener('click', async function() {
          if (root.getAttribute('data-state') === 'voting') return;
          const slug = btn.getAttribute('data-slug');
          if (!slug) return;
          root.setAttribute('data-state', 'voting');
          buttons.forEach(function(b) { b.disabled = true; });
          btn.classList.add('poll-choice-selected');
          setStatus('Submitting your vote…', 'info');
          try {
            const r = await fetch('/api/vote', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ slug: slug }),
            });
            const data = await r.json();
            if (!r.ok) {
              setStatus(data.error || 'Couldn\'t submit your vote. Try again in a minute.', 'error');
              buttons.forEach(function(b) { b.disabled = false; });
              btn.classList.remove('poll-choice-selected');
              root.setAttribute('data-state', 'idle');
              return;
            }
            setStatus(data.already_voted ? 'You already voted. Here are the live results:' : 'Thanks for voting!', 'info');
            showResults(data);
          } catch (err) {
            setStatus('Network error. Try again in a moment.', 'error');
            buttons.forEach(function(b) { b.disabled = false; });
            btn.classList.remove('poll-choice-selected');
            root.setAttribute('data-state', 'idle');
          }
        });
      });

      loadExistingState();
    })();
  </script>
</BaseLayout>
