---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
const FORMSPREE_ENDPOINT = "https://formspree.io/f/xnjrzgda";
---
<BaseLayout
  title="Free Home Evaluation — What's Your Toronto Property Worth? | Peter Law"
  description="Get a free, no-obligation evaluation of your Toronto property's current market value. Detailed CMA delivered within 48 hours."
  bodyClass="calc-page"
>
  <TopBar />
  <Header active="sellers" ctaLabel="Or book a call" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Free home evaluation</div>
      <h1>What's your home actually worth today?</h1>
      <p>A detailed comparative market analysis from a Toronto realtor who knows your neighborhood. Free, no obligation, delivered within 48 hours.</p>
    </div>
  </section>

  <section class="major" style="padding-top:32px;">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side">
          <h4>On this page</h4>
          <ul>
            <li><a href="#what">What you get</a></li>
            <li><a href="#how">How it works</a></li>
            <li><a href="#why">Why use me</a></li>
            <li><a href="#form">Request your evaluation</a></li>
          </ul>
        </aside>
        <div class="prose-body">
          <h2 id="what">What you get</h2>
          <ul class="bullets">
            <li><strong>A detailed CMA (Comparative Market Analysis)</strong> — recent sales of comparable units within 1km, adjusted for size, condition, and amenities</li>
            <li><strong>A realistic price range</strong> — low, expected, and ambitious — based on current market activity</li>
            <li><strong>Recommendations to maximize value</strong> — what to fix, what to stage, what to leave alone</li>
            <li><strong>An honest timeline</strong> — how long similar properties have been taking to sell, broken down by price band</li>
          </ul>

          <h2 id="how">How it works</h2>
          <ol class="bullets" style="list-style: decimal;">
            <li>You fill out the form below with property details — takes ~3 minutes</li>
            <li>I pull TRREB sold-comp data and active listings in your area</li>
            <li>I do a quick drive-by or virtual walk-through (your choice) — usually within 24 hours</li>
            <li>You receive the written evaluation (PDF + email summary) within 48 hours of submitting</li>
          </ol>

          <h2 id="why">Why use me</h2>
          <p>I personally do every evaluation for properties in downtown Toronto, the waterfront, and the GTA. Going through Step A to Z with a tunnel vision.</p>

          <h2 id="form">Request your evaluation</h2>
          <div class="calc">
            <form method="POST" action={FORMSPREE_ENDPOINT}>
              <div class="calc-fields">
                <div class="calc-field">
                  <label for="fhe-name">Full name <span class="hint">*</span></label>
                  <input id="fhe-name" name="name" type="text" required autocomplete="name">
                </div>
                <div class="calc-field">
                  <label for="fhe-email">Email <span class="hint">*</span></label>
                  <input id="fhe-email" name="email" type="email" required autocomplete="email">
                </div>
                <div class="calc-field">
                  <label for="fhe-phone">Phone</label>
                  <input id="fhe-phone" name="phone" type="tel" autocomplete="tel">
                </div>
                <div class="calc-field">
                  <label for="fhe-type">Property type</label>
                  <select id="fhe-type" name="property_type">
                    <option>Condo</option>
                    <option>House — detached</option>
                    <option>House — semi-detached</option>
                    <option>Townhouse</option>
                    <option>Other</option>
                  </select>
                </div>
                <div class="calc-field calc-field-full">
                  <label for="fhe-address">Property address <span class="hint">*</span></label>
                  <input id="fhe-address" name="address" type="text" required placeholder="123 Main St, Toronto, ON">
                </div>
                <div class="calc-field">
                  <label for="fhe-beds">Bedrooms</label>
                  <input id="fhe-beds" name="bedrooms" type="number" min="0" max="10" step="1">
                </div>
                <div class="calc-field">
                  <label for="fhe-baths">Bathrooms</label>
                  <input id="fhe-baths" name="bathrooms" type="number" min="0" max="10" step="0.5">
                </div>
                <div class="calc-field">
                  <label for="fhe-sqft">Approximate square footage</label>
                  <input id="fhe-sqft" name="sqft" type="number" min="100" step="50" placeholder="e.g. 750">
                </div>
                <div class="calc-field">
                  <label for="fhe-timeline">Selling timeline</label>
                  <select id="fhe-timeline" name="timeline">
                    <option>Just curious</option>
                    <option>Considering in next 3-6 months</option>
                    <option>Ready in 1-3 months</option>
                    <option>Listing now / urgent</option>
                  </select>
                </div>
                <div class="calc-field calc-field-full">
                  <label for="fhe-notes">Anything I should know? <span class="hint">(recent reno, parking, view, etc.)</span></label>
                  <input id="fhe-notes" name="notes" type="text">
                </div>
                <div class="hp-field" aria-hidden="true">
                  <label for="fhe-gotcha">Don't fill this</label>
                  <input id="fhe-gotcha" name="_gotcha" type="text" tabindex="-1" autocomplete="off">
                </div>
                <input type="hidden" name="_subject" value="New Free Home Evaluation Request">
                <input type="hidden" name="_next" value="https://www.realtorpeterlaw.com/contact/thanks">
              </div>
              <button type="submit" class="btn-primary" style="margin-top: 24px;">
                Send my evaluation request
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
