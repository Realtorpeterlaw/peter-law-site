---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="About Peter Law — Toronto Real Estate" description="Peter Law: born and raised in downtown Toronto. Former Airbnb host with 400+ guest reviews. Sales Representative at HomeLife Golconda Realty Inc.">

  <TopBar />
  <Header active="about" ctaLabel="Book a call" />

  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <div class="eyebrow">About Peter</div>
        <h1 class="hero-h">Born and Raised, <em>Toronto-ian.</em></h1>
        <p class="hero-sub">A Downtown Torontonian, ex-Airbnb host, and full-time Real Estate Representative who will get you from Point A to B, to the finish line.</p>
        <div class="hero-ctas">
          <a href={BOOKING_URL} class="btn-primary">
            Let's talk
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
      <div><div class="hero-photo"><img src="/photos/peter-interior.webp" alt="Peter Law, black-and-white portrait — seated by a window with a coffee, downtown Toronto." width="1500" height="1887" loading="eager" /></div></div>
    </div>
  </section>

  <section class="major" style="padding-top:32px;">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side">
          <h4>About</h4>
          <ul>
            <li><a href="#story">The story</a></li>
            <li><a href="#credentials">Credentials</a></li>
            <li><a href="#brokerage">Brokerage</a></li>
          </ul>
        </aside>

        <div class="prose-body">
          <h2 id="story" style="font-size:42px;">The story</h2>
          <p>Born and raised in downtown Toronto. Canadian-born Chinese. Six (6) years, FULL-TIME in Toronto's Rental market. Started hosting on Airbnb, earned my Real Estate license, built a practice across Rentals and Sales. Hospitality work taught me something simple: <strong>people don't remember the listing photo. They remember whether they felt taken care of.</strong></p>

          <div class="airbnb-credentials">
            <a class="airbnb-card" href="https://www.airbnb.ca/users/show/130982023" target="_blank" rel="noopener" aria-label="View Peter Law's Airbnb host profile (opens in new tab)">
              <div class="airbnb-photo-wrap">
                <img src="/photos/peter-portrait.webp" alt="Peter, verified Airbnb host" />
                <span class="airbnb-verified" aria-hidden="true">✓</span>
              </div>
              <div class="airbnb-meta">
                <div class="airbnb-name">Peter</div>
                <div class="airbnb-role">Verified Airbnb host</div>
              </div>
              <div class="airbnb-stats">
                <div><span class="stat-num">402</span><span class="stat-lbl">Reviews</span></div>
                <div><span class="stat-num">4.65<span class="star">★</span></span><span class="stat-lbl">Rating</span></div>
                <div><span class="stat-num">4+</span><span class="stat-lbl">Years hosting</span></div>
              </div>
            </a>
          </div>

          <h2 id="credentials">Credentials</h2>
          <ul class="bullets">
            <li>Registered Sales Representative, Real Estate Council of Ontario (RECO), 6 Years</li>
            <li>Member, Toronto Regional Real Estate Board (TRREB), 6 Years</li>
            <li>Member, Canadian Real Estate Association (CREA), 6 Years</li>
            <li>4+ years hospitality experience as an Airbnb host (402 reviews · 4.65★ average)</li>
            <li>Fluent in English and 中文</li>
            <li>Pursuing Real Estate Broker License (pending)</li>
          </ul>

          <h2 id="brokerage">Brokerage</h2>
          <p><strong>HomeLife Golconda Realty Inc., Brokerage</strong><br>215 – 3601 HWY 7 East, Markham, Ontario, L3R 0M3<br>HomeLife is one of Canada's longest-established real estate brands, founded in Toronto in 1985. Golconda Realty is an independently owned and operated franchise serving the GTA.</p>

          <div class="callout"><strong>Public profile:</strong> <a href="https://www.realtor.ca/agent/2071856/peter-law-3601-hwy-7-215-markham-ontario-l3r0m3" style="text-decoration: underline; text-underline-offset: 3px;">View Peter's REALTOR.ca page</a> for current listings and verified credentials.</div>
        </div>
      </div>
    </div>
  </section>

  <CTASection heading="The fastest way to know if we're a fit." lead="A 15-minute call. We talk through your situation. You decide if you want to keep going." ctaTitle="Book a call" />
  <Footer />
</BaseLayout>
