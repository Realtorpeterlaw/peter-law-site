---
import RecentDeals from '../../components/RecentDeals.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChineseTopBar from '../../components/ChineseTopBar.astro';
import ChineseHeader from '../../components/ChineseHeader.astro';
import ChineseFooter from '../../components/ChineseFooter.astro';
import ChineseCTASection from '../../components/ChineseCTASection.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout
  title="Peter Law - 多伦多房地产"
  description="Peter Law | 多伦多双语房地产专家。协助租客在多伦多找到获批、可入住的家。从搜寻到拿钥匙的全程服务。致电 647-888-8472。"
  zh={true}
>

  <ChineseTopBar />
  <ChineseHeader />

  <section class="proof-bar">
    <div class="wrap proof-grid">
      <a class="proof-item proof-link" href="https://www.airbnb.ca/users/show/130982023" target="_blank" rel="noopener"><div class="proof-num">400+</div><div class="proof-lbl">Airbnb 客户好评</div></a>
      <div class="proof-item"><div class="proof-num"><a class="proof-num-link" href="/">EN · 中文</a></div><div class="proof-lbl">英文 <span class="nocase">l</span> 中文</div></div>
      <div class="proof-item"><div class="proof-num">RECO</div><div class="proof-lbl">安省注册</div></div>
      <a class="proof-item proof-link" href="https://www.homelifegolconda.com/" target="_blank" rel="noopener"><div class="proof-num">HomeLife</div><div class="proof-lbl">Golconda Realty Inc.</div></a>
    </div>
  </section>

  <section class="hero">
    <div class="wrap hero-grid">
      <div>
      <form id="rental-questionnaire" class="quiz-form" method="POST" action="https://formspree.io/f/xnjrzgda" style="scroll-margin-top:100px">
                <div class="quiz-eyebrow">租房问卷</div>
                <h3 class="quiz-heading">您在找什么样的房子?</h3>
                <p class="quiz-sub">(最短租期 1 年)</p>
                <div class="quiz-fields">
                  <div class="quiz-field">
                    <label for="quiz-beds">卧室*</label>
                    <select id="quiz-beds" name="bedrooms" required>
                      <option value="">请选择…</option>
                      <option>单间公寓 Studio</option>
                      <option>1 卧</option>
                      <option>1 卧 + 书房</option>
                      <option>2 卧</option>
                      <option>3 卧</option>
                      <option>4 卧或以上</option>
                    </select>
                  </div>
                  <div class="quiz-field">
                    <label for="quiz-baths">卫浴*</label>
                    <select id="quiz-baths" name="bathrooms" required>
                      <option value="">请选择…</option>
                      <option>1</option>
                      <option>1.5</option>
                      <option>2</option>
                      <option>2.5</option>
                      <option>3+</option>
                    </select>
                  </div>
                  <div class="quiz-field">
                    <label for="quiz-parking">停车位*</label>
                    <select id="quiz-parking" name="parking" required>
                      <option value="">请选择…</option>
                      <option>不需要</option>
                      <option>1 个</option>
                      <option>2 个</option>
                      <option>3 个或以上</option>
                    </select>
                  </div>
                  <div class="quiz-field">
                    <label for="quiz-budget">月预算*</label>
                    <select id="quiz-budget" name="budget" required>
                      <option value="">请选择…</option>
                      <option>$2,000 以下</option>
                      <option>$2,000 – $2,500</option>
                      <option>$2,500 – $3,000</option>
                      <option>$3,000 – $3,500</option>
                      <option>$3,500 – $4,500</option>
                      <option>$4,500 以上</option>
                    </select>
                  </div>
                  <div class="quiz-field">
                    <label for="quiz-movein">入住日期*</label>
                    <input id="quiz-movein" name="move_in_date" type="date" required>
                  </div>
                  <div class="quiz-field">
                    <label for="quiz-notice">已向房东发出 60 天通知*</label>
                    <select id="quiz-notice" name="landlord_notice_60_days" required>
                      <option value="">请选择…</option>
                      <option>是</option>
                      <option>否</option>
                      <option>不适用</option>
                    </select>
                  </div>
                  <div class="quiz-field quiz-field-full">
                    <label>偏好地区* <span class="quiz-hint">(可多选)</span></label>
                    <div class="quiz-checkboxes" data-checkbox-group="location">
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="多伦多市中心(Yonge &amp; Dundas 街)"> 多伦多市中心(Yonge &amp; Dundas 街)</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="King West / Liberty Village"> King West / Liberty Village</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="Yonge & Bloor / Yorkville"> Yonge & Bloor / Yorkville</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="湖滨 / Harbourfront"> 湖滨 / Harbourfront</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="Yonge–Eglinton"> Yonge–Eglinton</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="东多伦多 (Leslieville, East York)"> 东多伦多 (Leslieville, East York)</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="Markham / 大多伦多北"> Markham / 大多伦多北</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="步行距离地铁站"> 步行距离地铁站</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="步行距离 Union 地铁站"> 步行距离 Union 地铁站</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="步行距离多大 St. George 校区"> 步行距离多大 St. George 校区</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="步行距离湖滨"> 步行距离湖滨</label>
                      <label class="quiz-check"><input type="checkbox" name="location[]" value="欢迎建议"> 欢迎建议</label>
                    </div>
                  </div>
                  <div class="quiz-field quiz-field-full">
                    <label for="quiz-email">电子邮件*</label>
                    <input id="quiz-email" name="email" type="email" required autocomplete="email" placeholder="your@email.com">
                  </div>
                </div>
                <div class="hp-field" aria-hidden="true">
                  <label for="quiz-gotcha">请勿填写</label>
                  <input id="quiz-gotcha" name="_gotcha" type="text" tabindex="-1" autocomplete="off">
                </div>
                <input type="hidden" name="_subject" value="新租房问卷 (中文版)">
                <input type="hidden" name="_next" value="https://www.realtorpeterlaw.com/contact/thanks">
                <button type="submit" class="btn-primary quiz-cta">
                  发我房源
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </form>
      </div>
      <div><a href="/chinese/about" class="hero-photo-link" aria-label="关于 Peter Law — 了解更多"><div class="hero-photo"><img src="/photos/peter-portrait.webp" alt="Peter Law,多伦多双语房地产中介,身后是 CN 塔。" width="1500" height="1887" loading="eager" /></div></a></div>
    </div>
  </section>


  <section class="boc-widget" aria-label="加拿大银行利率与安大略省租金涨幅指导">
    <div class="wrap">
      <div class="boc-widget-grid">
        <div class="boc-cell">
          <span class="boc-cell-label">加拿大银行政策利率</span>
          <span class="boc-cell-value">2.25<span class="pct">%</span></span>
        </div>
        <div class="boc-divider" aria-hidden="true"></div>
        <div class="boc-cell">
          <span class="boc-cell-label">下次公告</span>
          <span class="boc-cell-value" style="font-size:21px;">2026 年 6 月 10 日</span>
        </div>
        <div class="boc-divider" aria-hidden="true"></div>
        <a class="boc-source" href="https://www.bankofcanada.ca/core-functions/monetary-policy/key-interest-rate/" target="_blank" rel="noopener">来源: bankofcanada.ca ↗</a>
        <hr class="boc-row-rule" aria-hidden="true" />
        <div class="boc-cell">
          <span class="boc-cell-label">安大略省租金涨幅 (2026)</span>
          <span class="boc-cell-value">2.1<span class="pct">%</span></span>
        </div>
        <div class="boc-divider" aria-hidden="true"></div>
        <div class="boc-cell">
          <span class="boc-cell-label">下次公告</span>
          <span class="boc-cell-value" style="font-size:21px;">2027 年 1 月 1 日</span>
        </div>
        <div class="boc-divider" aria-hidden="true"></div>
        <a class="boc-source" href="https://www.ontario.ca/page/residential-rent-increases" target="_blank" rel="noopener">来源: ontario.ca ↗</a>
      </div>
    </div>
  </section>

  <RecentDeals zh={true} />

  <section class="major newsletter">
    <div class="wrap">
      <div class="newsletter-inner">
        <div class="section-eyebrow">每月市场报告</div>
        <h2 class="section-h">多伦多房地产的真实情况。</h2>
        <p class="section-lead">信息很重要。租赁与销售月报。在下方订阅,保持领先。</p>
        <form class="newsletter-form" method="GET" action="https://peters-newsletter-469474.beehiiv.com/subscribe">
          <label for="newsletter-email" class="sr-only">电子邮件</label>
          <input id="newsletter-email" type="email" name="email" placeholder="your@email.com" required autocomplete="email" />
          <button type="submit" class="btn-primary">订阅
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
        <p class="newsletter-trust">随时取消订阅。您的电子邮件不会与任何人共享。</p>
      </div>
    </div>
  </section>

  <ChineseCTASection />
  <ChineseFooter />

  <script>
    document.querySelectorAll('form.quiz-form').forEach(function(form){
      form.addEventListener('submit', function(e){
        var cbs = form.querySelectorAll('input[name="location[]"]');
        if (cbs.length && ![].some.call(cbs, function(cb){ return cb.checked; })) {
          e.preventDefault();
          alert('请至少选择一个偏好地区。');
          cbs[0].focus();
        }
      });
    });
  </script>
</BaseLayout>

<style>
  /* Tighten homepage vertical rhythm — only affects this page */
  .hero { padding-bottom: 40px; }
  .boc-widget + section.major { padding-top: 56px; }
  @media (max-width: 900px) {
    .hero { padding-bottom: 28px; }
  }
  @media (max-width: 720px) {
    .boc-widget + section.major { padding-top: 40px; }
  }
</style>
