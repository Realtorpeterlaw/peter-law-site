---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChineseTopBar from '../../components/ChineseTopBar.astro';
import ChineseHeader from '../../components/ChineseHeader.astro';
import ChineseFooter from '../../components/ChineseFooter.astro';
import ChineseCTASection from '../../components/ChineseCTASection.astro';
import PropertySales from '../../components/PropertySales.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="销售记录 — Peter Law 多伦多房地产" description="Peter Law 在大多伦多地区近期完成的租赁与购房交易记录。" zh={true}>
  <ChineseTopBar />
  <ChineseHeader active="about" ctaLabel="预约通话" />

  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <div class="eyebrow"><a href="/chinese/about" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>关于</a> · 销售记录</div>
        <h1 class="hero-h">销售记录</h1>
      </div>
      <div>
        <div class="hero-photo">
          <img src="/photos/peter-portrait.webp" alt="Peter Law,多伦多房地产销售代表,身后是 CN 塔。" width="1500" height="1887" loading="eager" />
        </div>
        <div class="agent-byline">
          <div class="agent-name">Peter Law</div>
          <div class="agent-title">销售代表</div>
          <div class="agent-brokerage">Home Life Golconda Realty., Inc Brokerage.</div>
          <div class="agent-phones">
            <div><span class="lbl">直线:</span> <a href="tel:+16478888472">(647) 888 - 8472</a></div>
            <div><span class="lbl">办公室:</span> <a href="tel:+19058888819">(905) 888 - 8819</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <PropertySales zh={true} />

  <ChineseCTASection heading="在寻找下一个家?" lead="为这些客户达成签约的同一套流程,也会用在您身上。免费 15 分钟介绍通话,无任何义务。" ctaTitle="预约通话" />
  <ChineseFooter />
</BaseLayout>

<style>
  .hero-grid { align-items: start; }
  .hero-photo {
    max-width: 320px;
    margin-left: auto;
    margin-right: 0;
  }
  .agent-byline {
    margin-top: 22px;
    max-width: 320px;
    margin-left: auto;
    margin-right: 0;
    text-align: right;
  }
  @media (max-width: 1200px) {
    .hero-photo, .agent-byline { margin-right: 0; }
  }
  .agent-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 30px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .agent-title {
    font-size: 15px;
    color: var(--ink-soft);
    margin-top: 4px;
    letter-spacing: 0.01em;
  }
  .agent-brokerage {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    margin-top: 12px;
    letter-spacing: -0.005em;
    line-height: 1.25;
  }
  .agent-phones {
    margin-top: 14px;
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.7;
    font-variant-numeric: tabular-nums;
  }
  .agent-phones .lbl {
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
    font-weight: 600;
    margin-right: 4px;
  }
  .agent-phones a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .agent-phones a:hover { border-bottom-color: var(--ink-mute); }
  @media (max-width: 640px) {
    .agent-name { font-size: 26px; }
    .agent-brokerage { font-size: 19px; }
  }
</style>
