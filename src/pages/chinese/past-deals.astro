---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChineseTopBar from '../../components/ChineseTopBar.astro';
import ChineseHeader from '../../components/ChineseHeader.astro';
import ChineseFooter from '../../components/ChineseFooter.astro';
import ChineseCTASection from '../../components/ChineseCTASection.astro';
import RecentDealsArchive from '../../components/RecentDealsArchive.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="成交记录 — Peter Law 多伦多房地产" description="Peter Law 在大多伦多地区近期完成的租赁与购房交易记录。" zh={true}>
  <ChineseTopBar />
  <ChineseHeader active="about" ctaLabel="预约通话" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow"><a href="/chinese/about" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>关于</a> · 成交记录</div>
      <h1>销售记录</h1>
    </div>
  </section>

  <RecentDealsArchive zh={true} />

  <ChineseCTASection heading="在寻找下一个家?" lead="为这些客户达成签约的同一套流程,也会用在您身上。免费 15 分钟介绍通话,无任何义务。" ctaTitle="预约通话" />
  <ChineseFooter />
</BaseLayout>
