---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChineseTopBar from '../../components/ChineseTopBar.astro';
import ChineseHeader from '../../components/ChineseHeader.astro';
import ChineseFooter from '../../components/ChineseFooter.astro';

export const prerender = true;

const publishedDate = '2026-07-19';
const pageTitle = '免责声明';
const pageDescription = '关于 realtorpeterlaw.com 所发布信息(含市场数据、税务话题、政府项目、计算器、过往成交信息与第三方链接)的重要说明。';

const hreflangAlternates = [
  { hreflang: 'en-CA', href: 'https://www.realtorpeterlaw.com/disclaimer/' },
  { hreflang: 'zh-CN', href: 'https://www.realtorpeterlaw.com/chinese/disclaimer/' },
  { hreflang: 'fr-CA', href: 'https://www.realtorpeterlaw.com/french/disclaimer/' },
  { hreflang: 'x-default', href: 'https://www.realtorpeterlaw.com/disclaimer/' },
];
---
<BaseLayout
  title={`${pageTitle} | Peter Law — 多伦多房地产`}
  description={pageDescription}
  bodyClass="guide-page article-page"
  zh={true}
  hreflangAlternates={hreflangAlternates}
>
  <ChineseTopBar />
  <ChineseHeader active="" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow">法律 · 内容说明</div>
        <h1>{pageTitle}</h1>
        <p class="article-lead">本网站上的每一篇文章、计算器、过往成交记录与数据,都是为了帮您理解多伦多房地产 —— 而非取代律师、税务师、按揭经纪或房地产代表的意见。依赖此处任何内容前,请阅读以下说明。</p>
        <div class="article-byline">
          <span>最近更新:</span>
          <time datetime={publishedDate}>2026 年 7 月 19 日</time>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>本页目录</h4>
            <ul>
              <li><a href="#general">仅供一般参考</a></li>
              <li><a href="#no-advice">非专业意见</a></li>
              <li><a href="#accuracy">准确性与时效性</a></li>
              <li><a href="#market-data">市场数据、MLS®、MPAC 与 CMHC</a></li>
              <li><a href="#calculators">计算器与估算</a></li>
              <li><a href="#dollar-figures">文章中的具体金额</a></li>
              <li><a href="#past-deals">过往成交、地址与照片</a></li>
              <li><a href="#testimonials">客户评价、评分与主观表述</a></li>
              <li><a href="#airbnb">Airbnb 及以往民宿业绩</a></li>
              <li><a href="#no-relationship">不构成客户关系</a></li>
              <li><a href="#referrals">转介与联盟关系</a></li>
              <li><a href="#third-party">第三方内容</a></li>
              <li><a href="#external">外部链接</a></li>
              <li><a href="#contact">联系与更正</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <h2 id="general">仅供一般参考</h2>
            <p><strong>realtorpeterlaw.com</strong>(下称"本网站")所发布的一切内容 —— 包括博客、指南、表格、计算器、过往成交记录、所引用的数据与信息图 —— 仅供一般参考,旨在为您自行研究提供起点、帮助您知道该问什么问题。它无法替代针对您具体情况的专业意见。</p>

            <h2 id="no-advice">非专业意见</h2>
            <p>Peter Law 是安省注册的销售代表 —— 并非律师、税务师、按揭经纪、理财规划师、评估师或建筑承包商。本网站中涉及以下主题的内容:</p>
            <ul class="bullets">
              <li>税务(HST/GST 退税、土地转让税、资本利得、空置房屋税、首套房储蓄账户等);</li>
              <li>法律(租约、要约、房东/租客纠纷、Bill 60、HCRA 牌照、N 系列表格等);</li>
              <li>按揭与融资(利率、HELOC、反向按揭、可负担性、压力测试等);</li>
              <li>政府项目(FHSA、FTHB 退税、RHSP、OESP、外国买家禁令等);</li>
              <li>房屋估值(CMA、房屋评估、市场预测);</li>
            </ul>
            <p>应视为一般性教育,而非可直接照做的建议。作出决定前,请向相应的专业人士或负责的政府部门确认最新信息。指南中出现的指令性语言(如"您应该"、"您必须"、"房东必须")仅为一般规则的概述,并非针对您具体情形的指示。</p>

            <h2 id="accuracy">准确性与时效性</h2>
            <p>我们力求撰写准确的内容并注明出处。但房地产规则、税率、市场数据与政府项目变化频繁 —— 有时非常突然。发布时准确的内容,在您阅读时可能已经过时。请留意每篇文章顶部的"发布日期"或"最近更新",并核实其中的事实后再作依据。我们力求每年至少复核一次文章,但不对任何具体文章的更新频率作出承诺。</p>

            <h2 id="market-data">市场数据、MLS®、MPAC 与 CMHC 引用</h2>
            <p>本网站发布的市场统计、销售数据或物业信息,均来自可靠来源 —— 包括多伦多地区房地产协会(TRREB)、MLS® 数据、市政物业评估公司(MPAC)估值,以及加拿大按揭及房屋公司(CMHC)公开资料 —— 但不作保证。MLS® 与 TRREB 数据在发布后可能被更新或更正;MPAC 估值并非市场价;CMHC 保费表与资格规则也不时调整。</p>
            <p><strong>MLS®</strong>、<strong>Multiple Listing Service®</strong> 及相关图标由加拿大房地产协会(CREA)所有,用以标识 CREA 会员所提供的服务质量。<strong>REALTOR®</strong>、<strong>REALTORS®</strong> 及 REALTOR® 图标商标由 CREA 控制,用以标识 CREA 会员房地产专业人士。本网站中所有"MLS""realtor""realtors"字样,均指上述注册商标,在授权下使用。</p>

            <h2 id="calculators">计算器与估算</h2>
            <p>本网站上任何计算器或估算 —— 包括按揭付款计算器、可负担性计算器、结算成本估算器、土地转让税计算器与 CMHC 保费计算器 —— 均提供近似数字,仅供规划参考。实际数字取决于您的信用、贷款方、成交条件、物业细节以及我们无法看到的因素。底层参数(LTT/MLTT 分档、CMHC 保费表、压力测试合格利率、HST/GST 规则)可能在计算器未及时更新的情况下发生变化。请勿依赖计算器结果作出财务承诺;真实数字须由您的贷款方、律师与税务师确认。</p>

            <h2 id="dollar-figures">文章中的具体金额</h2>
            <p>当文章中出现具体金额 —— 如"最高退税 5 万元""大约节省 3,200 元""最高罚款 1 万元""每年省约 50 元" —— 这些数字仅为示例,基于文章"最近更新"日期时公开的税率或项目参数。您实际能获得的节省、退税、罚款或项目优惠,取决于您的资格、时点以及您采取行动时的项目规则。本网站不承诺任何具体金额结果适用于您。</p>

            <h2 id="past-deals">过往成交、地址与照片</h2>
            <p>本网站部分栏目 —— 如"近期"与"过往成交" —— 会展示 Peter 作为注册代表参与过的交易信息,通常包括交叉路口或地址、成交月份、成交价或租金、大致户型与简短评论。此类信息或来自公开可查的记录(如通过 TRREB / MLS® 系统按规发布的成交数据),或经当事客户明确同意后发布。</p>
            <p>本网站展示的物业照片,均在获得摄影师、卖家或经纪公司授权的前提下使用。我们不会明知未经授权而展示图片。</p>
            <p><strong>删除请求。</strong>如您是某笔过往交易的当事人,希望将您的信息或照片下架;或您认为本网站上的某张图片未经授权发布 —— 请<a href="/chinese/contact">联系我们</a>。我们将进行核实,如属实将及时下架。</p>

            <h2 id="testimonials">客户评价、评分与主观表述</h2>
            <p>本网站上任何客户评价、星级评分、成交摘要或对过往交易的引用,均已征得当事人同意,反映特定个人在特定情境下的经历。<strong>过往结果不能作为未来结果的保证。</strong>每一笔房地产交易都不同,结果取决于市场环境、时机、物业特性与谈判等诸多因素,难以完全复制。</p>
            <p>部分内容会使用简称或主观表述 —— 如"AAA 租客""AAA 位置""该栋最高成交""好租客""您会赢""最好"。这些均为 Peter 本人的评论与观点,并非信用评级、评估结果、承诺或可核实的市场排名。请勿将其视为客观事实。任何比较性或最高级表述("最高""最好""最大"),均基于发布时可知的数据,不保证其后仍然准确。</p>

            <h2 id="airbnb">Airbnb 及以往民宿业绩</h2>
            <p>本网站部分页面引用 Peter 以往作为 Airbnb 房东的业绩 —— 如"400+ Airbnb 好评"或某项星级评分。这些数字反映的是独立的民宿业务,仅供背景参考。它们不代表房地产服务的成果指标,也不应被视为对任何客户在房地产交易中所能获得结果的预测。</p>

            <h2 id="no-relationship">不构成客户关系</h2>
            <p>浏览本网站、通过联系表格发送信息、订阅新闻邮件或预约初步通话,均<strong>不</strong>构成客户关系、代理关系或任何信托义务。房地产客户关系仅在双方签署书面代表协议(《买家代表协议》《卖家代表协议》或 RECO 认可的其他代表协议)后才成立。阅读关于租约、N 表格或房东/租客法的指南,并不构成律师-委托人、持牌代理-客户或经纪-客户关系。</p>

            <h2 id="referrals">转介与联盟关系</h2>
            <p>本网站有时会链接至第三方服务提供商 —— 如互联网/公用事业供应商、租客背景核查服务(如 SingleKey)、按揭专业人士等 —— Peter 曾与其合作或将客户转介至该等机构。在部分情形下,Peter 可能因该等转介而收取转介费、抵扣或佣金。凡涉及转介关系,我们会尽量在链接附近注明。若您不确定某链接是否为转介性质,请在注册前询问我们。选择任何第三方服务,最终皆由您决定。</p>

            <h2 id="third-party">第三方内容</h2>
            <p>部分内容会引用、摘录或概述政府文件、行业协会指南与新闻报道。凡有相应来源,均会注明并链接。相关第三方的商标与版权仍属其各自所有人。</p>

            <h2 id="external">外部链接</h2>
            <p>本网站包含至外部网站(政府页面、新闻来源、行业资源、第三方服务)的链接,仅供方便查阅。我们不控制、不认可、也不对这些网站的内容、准确性或隐私做法承担责任。是否点击外部链接由您自行判断。</p>

            <h2 id="contact">联系与更正</h2>
            <p>对本网站内容有疑问,或发现某处需要更正、更新或删除?请<a href="/chinese/contact">联系 Peter</a>。我们宁愿修正错误,也不愿将其留在网站上。</p>
          </div>
        </div>
      </div>
    </section>
  </article>

  <ChineseFooter />
</BaseLayout>
