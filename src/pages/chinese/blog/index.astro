---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ChineseTopBar from '../../../components/ChineseTopBar.astro';
import ChineseHeader from '../../../components/ChineseHeader.astro';
import ChineseFooter from '../../../components/ChineseFooter.astro';
import ChineseCTASection from '../../../components/ChineseCTASection.astro';

const icons = {
  scroll: `<svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="18" y="14" width="44" height="52" fill="var(--bg-warm)" stroke="currentColor" stroke-width="2" rx="2"/><path d="M26 28 Q31 25 36 28 T46 28 T54 28" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="M26 38 Q31 35 36 38 T46 38 T54 38" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="M26 48 Q30 45 34 48 T42 48 T48 48" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/><path d="M26 58 Q31 55 36 58 T46 58 T52 58" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg>`,
  tou: `<svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><circle cx="40" cy="40" r="30" stroke="currentColor" stroke-width="2.4" fill="none"/><line x1="40" y1="14" x2="40" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="62" y1="40" x2="66" y2="40" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="40" y1="62" x2="40" y2="66" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="14" y1="40" x2="18" y2="40" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="40" y1="40" x2="30" y2="28" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/><line x1="40" y1="40" x2="54" y2="26" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="40" cy="40" r="2" fill="currentColor"/></svg>`,
  house: `<svg viewBox="0 0 80 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="20" y="36" width="40" height="30" fill="var(--bg-warm)" stroke="currentColor" stroke-width="2"/><path d="M14 38 L40 18 L66 38 Z" fill="var(--bg-warm)" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><rect x="30" y="50" width="9" height="16" fill="none" stroke="currentColor" stroke-width="1.5"/><text x="48" y="60" text-anchor="middle" font-family="Fraunces, Georgia, serif" font-size="18" font-weight="500" fill="currentColor">$</text></svg>`,
};

const posts = [
  {
    slug: 'time-of-use-tou',
    title: '电费大省:分时电价(Time of Use, TOU)',
    eyebrow: '家居小贴士 · 水电',
    date: '2026 年 6 月 3 日',
    readMin: 5,
    iconKey: 'tou',
  },
  {
    slug: 'bill-60-ontario',
    iconKey: 'scroll',
    title: '安省 Bill 60:租客与房东必须知道的事',
    eyebrow: '立法 · 2026',
    date: '2026 年 6 月 3 日',
    readMin: 8,
  },
  {
    slug: 'reverse-mortgage',
    iconKey: 'house',
    title: '反向房贷(Reverse Mortgage):是什么?',
    eyebrow: '长者买家 · 融资',
    date: '2026 年 6 月 3 日',
    readMin: 7,
  },
];
---
<BaseLayout
  title="多伦多房地产博客 | Peter Law"
  description="关于多伦多租赁、买卖、融资和安省房地产立法的真实解读。由双语多伦多中介撰写的通俗讲解,定期更新。"
  bodyClass="blog-page"
  zh={true}
>
  <ChineseTopBar />
  <ChineseHeader active="blog" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">博客</div>
      <h1>关于多伦多房地产的实话。</h1>
      <p>传言、趋势、市场、金融、政策、移民,以及保持领先……</p>
      <div class="blog-search" role="search">
        <svg class="blog-search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.6"/><path d="M11 11l3 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        <input id="blog-search-input" type="search" placeholder="搜索文章…" aria-label="搜索博客文章" autocomplete="off" />
      </div>
    </div>
  </section>

  <section class="major" style="padding-top: 32px;">
    <div class="wrap">
      <div class="blog-list">
        {posts.map((post) => (
          <article class="blog-card" data-search={`${post.title} ${post.eyebrow}`.toLowerCase()}>
            <a href={`/chinese/blog/${post.slug}`} class="blog-card-link" aria-label={`阅读:${post.title}`}>
              {post.iconKey && icons[post.iconKey] && (
                <div class="blog-card-icon" set:html={icons[post.iconKey]} />
              )}
              <div class="blog-card-text">
                <div class="blog-card-eyebrow">{post.eyebrow}</div>
                <h2 class="blog-card-title">{post.title}</h2>
                <div class="blog-card-meta">
                  <span>阅读 {post.readMin} 分钟</span>
                  <span class="blog-card-read">阅读全文
                    <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="blog-newsletter">
        <div class="eyebrow">每月市场报告</div>
        <h3>新文章,直接送到您邮箱。</h3>
        <p>订阅每月通讯,每一篇新文章上线当天就会送到您手上。免费,不推销。</p>
        <form class="newsletter-form" method="GET" action="https://peters-newsletter-469474.beehiiv.com/subscribe" style="margin-top:14px;max-width:520px;">
          <label for="blog-newsletter-email" class="sr-only">电子邮箱</label>
          <input id="blog-newsletter-email" type="email" name="email" placeholder="your@email.com" required autocomplete="email" />
          <button type="submit" class="btn-primary">订阅
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </form>
        <p style="font-size:12px;color:var(--ink-mute);margin-top:10px;">随时可取消订阅。邮箱不会分享给任何人。</p>
      </div>
    </div>
  </section>

  <p class="blog-no-results" id="blog-no-results" hidden>没有匹配的文章。换个关键词试试。</p>

  <ChineseCTASection heading="有想看的话题?" lead="如果您一直在 Google 上搜某个问题但找不到直接的答案,把题目发给我。我一直在找下一篇该写什么。" />
  <ChineseFooter />

  <script>
    (function() {
      const input = document.getElementById('blog-search-input');
      const cards = document.querySelectorAll('.blog-card');
      const noResults = document.getElementById('blog-no-results');
      if (!input || !cards.length) return;
      function filter() {
        const q = input.value.trim().toLowerCase();
        let visibleCount = 0;
        cards.forEach(function(card) {
          const text = card.getAttribute('data-search') || '';
          const match = !q || text.indexOf(q) !== -1;
          card.style.display = match ? '' : 'none';
          if (match) visibleCount++;
        });
        if (noResults) noResults.hidden = (q.length === 0 || visibleCount > 0);
      }
      input.addEventListener('input', filter);
    })();
  </script>
</BaseLayout>
