  {
    slug: 'bill-60-ontario',
    iconKey: 'scroll',
    title: '安省 Bill 60:租客与房东必须知道的事',
    eyebrow: '立法 · 2026',
    date: '2026 年 6 月 3 日',
    readMin: 8,
  },
  {
