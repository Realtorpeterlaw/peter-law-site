const posts = [
  {
    slug: 'vacant-home-tax',
    title: '空置房屋税(Vacant Home Tax)',
    eyebrow: '多伦多业主 · 税务',
    readMin: 8,
    iconKey: 'percent',
  },
  {
    slug: 'hcra-illegal-building',
    title: 'HCRA:非法建造',
    eyebrow: '买家保护 · 安省',
    readMin: 7,
    iconKey: 'warning',
  },
  {
    slug: 'rhsp',
    title: '租赁住房供应计划(RHSP)',
    eyebrow: '多伦多住房 · 政策',
    readMin: 8,
    iconKey: 'building',
  },
  {
    slug: 'oesp',
