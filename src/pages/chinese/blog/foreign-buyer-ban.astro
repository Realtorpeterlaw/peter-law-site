const publishedDate = '2026-06-09';
const articleTitle = '2026:加拿大外国买家禁令';
const articleDescription = '通俗解读加拿大《禁止非加拿大人购买住宅物业法》——谁算"非加拿大人"、哪些物业受限、工签和配偶豁免怎么运作、处罚有多重,以及为什么禁令延续至2026年12月31日。';
