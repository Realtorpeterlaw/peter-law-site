---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ChineseTopBar from '../../../components/ChineseTopBar.astro';
import ChineseHeader from '../../../components/ChineseHeader.astro';
import ChineseFooter from '../../../components/ChineseFooter.astro';
import ChineseCTASection from '../../../components/ChineseCTASection.astro';

const publishedDate = '2026-06-03';
const articleTitle = '安省 Bill 60:租客与房东必须知道的事';
const articleDescription = '通俗讲解安省 Bill 60 的五项租房规则变化,前后对比一目了然,以及作为租客或房东您该怎么做。';
const articleUrl = 'https://www.realtorpeterlaw.com/chinese/blog/bill-60-ontario';

const changes = [
  { n: 1, label: '欠租了?可补缴的时间变短了。', old: '原来房东向 LTB 申请前,您有 14 天补缴。', newR: '现在只有 7 天。', helps: '房东' },
  { n: 2, label: '房东要自住?不用再赔一个月租金了。', old: '若房东以自用(N12)让您搬走,需向您赔付一个月租金。', newR: '若房东提前 120 天通知,无需赔付。60 天的 N12 仍需赔付。', helps: '房东' },
  { n: 3, label: '一年期租约不再自动续约。', old: '固定租期结束后,租约自动转为按月续租。您可以一直住下去。', newR: '不再自动续约。房东可终止、提租、或要求签新租约。', helps: '房东' },
  { n: 4, label: '欠租听证中提出维修问题,要先押钱。', old: '在欠租听证中,租客可以免费把维修问题作为抗辩理由。', newR: '租客必须先把所欠租金的 50% 存入 LTB 信托账户,投诉才会被审理。', helps: '房东' },
  { n: 5, label: '上诉驱逐令的时间变短了。', old: '原来有 30 天上诉。', newR: '现在只有 15 天。', helps: '房东' },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  inLanguage: 'zh-CN',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/chinese/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — 多伦多房地产', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
};
---
<BaseLayout
  title={`${articleTitle} | Peter Law — 多伦多房地产博客`}
  description={articleDescription}
  bodyClass="guide-page article-page"
  zh={true}
>
  <ChineseTopBar />
  <ChineseHeader active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/chinese/blog" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>博客</a> · 立法</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">安省在 2025 年底通过了一部新法 — Bill 60。它改变了租房的规则。大部分变化对房东有利。租客时间更短、保护更少。本文用最简单的话讲清楚。</p>
        <div class="article-byline">
          <span>作者 <a href="/chinese/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026 年 6 月 3 日</time>
          <span class="dot">·</span>
          <span>阅读 6 分钟</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>本页内容</h4>
            <ul>
              <li><a href="#what">Bill 60 是什么</a></li>
              <li><a href="#diagram">新旧规则对照</a></li>
              <li><a href="#five">5 项变化详解</a></li>
              <li><a href="#status">目前是否生效</a></li>
              <li><a href="#tenants">如果您是租客</a></li>
              <li><a href="#landlords">如果您是房东</a></li>
              <li><a href="#why">为什么重要</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <h2 id="what">Bill 60 是什么?</h2>
            <p>Bill 60 的全名是 <em>Fighting Delays, Building Faster Act, 2025</em>(《加快建设、减少拖延法,2025》)。这是"综合性"法案 — 即一部法律同时修改其他多部法律。Bill 60 一次性修改了 16 部法律。</p>
            <p>政府声明的目标有两个:</p>
            <ul class="bullets">
              <li>加快新住房建设。</li>
              <li>加快房东与租客委员会(LTB)的处理速度。LTB 是处理租赁纠纷的机构。</li>
            </ul>
            <p>为此,Bill 60 缩短了时间线、移除了一些原本租客拥有的程序。大部分变化对房东有利。</p>

            <p><strong>一句话回答:</strong>Bill 60 是安省的一部新法。它修改了租房规则。对房东更便利、流程更快。对租客时间更紧、保护更少。法律于 2025 年 11 月 24 日通过。大部分条款仍在 Tribunals Ontario 分阶段实施 — 行动前请先核实。</p>

            <div class="b60-stats" aria-label="Bill 60 一图速览">
              <div class="b60-stat">
                <div class="b60-stat-num">7</div>
                <div class="b60-stat-cap">天:N4 欠租后可补缴的窗口 <span>(原为 14)</span></div>
              </div>
              <div class="b60-stat">
                <div class="b60-stat-num">15</div>
                <div class="b60-stat-cap">天:LTB 裁决上诉窗口 <span>(原为 30)</span></div>
              </div>
              <div class="b60-stat">
                <div class="b60-stat-num">50<span class="b60-stat-pct">%</span></div>
                <div class="b60-stat-cap">提出维修抗辩前需先存入的欠租比例</div>
              </div>
              <div class="b60-stat">
                <div class="b60-stat-num">120</div>
                <div class="b60-stat-cap">天:N12 达此通知期可免一个月赔付</div>
              </div>
            </div>

            <div class="callout"><strong>提醒:</strong>Bill 60 是安省过去十年间对租房法律最大的一次调整。一年前的规则今天未必仍成立。发出或回应任何通知前,请先咨询 LTB 或 paralegal。</div>

            <h2 id="diagram">新旧规则对照</h2>
            <p>共有 5 项变化。这里一目了然。</p>

            <div class="b60-intro">五项规则变了。四项削减租客时间或保护。一项免除了房东原本要付的补偿。下表一目了然,详细解释见下文。</div>

            <div class="b60-table-wrap">
              <table class="b60-table">
                <thead>
                  <tr><th>规则</th><th>Bill 60 之前</th><th>Bill 60 之后</th></tr>
                </thead>
                <tbody>
                  {changes.map((c) => (
                    <tr>
                      <td class="b60-rule">{c.label}</td>
                      <td class="b60-before">{c.old}</td>
                      <td class="b60-after">{c.newR}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <h2 id="five">5 项变化详解</h2>

            <details class="b60-change">
              <summary class="b60-change-summary">1. 欠租了?可以补缴的时间变短了。</summary>
              <div class="b60-change-body">
                <p>如果您没付租金,房东会向您发出一份叫 N4 的表格。它要求您补齐租金,或者搬走。</p>
              <p>原来:有 14 天。现在:只有 7 天。</p>
              <p>该怎么做:设置租金自动扣款。可补缴的时间只有原来一半。一次忘记缴费,驱逐倒计时就启动了。</p>
              </div>
            </details>

            <details class="b60-change">
              <summary class="b60-change-summary">2. "我要自用"的驱逐对房东更省钱了。</summary>
              <div class="b60-change-body">
                <p>N12 通知是:房东本人(或买家、或近亲属)想自己住进这套房子。房东要给您书面通知,让您搬走。</p>
              <p>原来:房东必须赔付您一个月租金作为搬家补偿,或者提供另一套同等条件的住房。</p>
              <p>现在:如果房东提前 120 天通知(4 个月),无需任何赔付。60 天的 N12 仍然需要赔付一个月。</p>
              <p>该怎么做:收到 N12,不要默认它是真的。假 N12 是最常见的房东骗局。Paralegal 审一份大约 $200 到 $500 — 远低于丢掉房子的代价。一旦在 LTB 被认定虚假,房东最高可处 $50,000 罚款。</p>
              </div>
            </details>

            <details class="b60-change">
              <summary class="b60-change-summary">3. 租约不再自动续约。</summary>
              <div class="b60-change-body">
                <p>这是对租客打击最大的一项。</p>
              <p>大多数租客签的是一年租约。原来:一年到期后,租约会自动转为按月续租。您可以一直住,房东每年只能按安省涨幅指导线提租。</p>
              <p>现在:这个自动续约没有了。固定租期结束时,房东可以选择下一步 — 让您搬走、提租重签、或重新谈条件。</p>
              <p>该怎么做:不要等。租约结束前 2 到 3 个月就和房东谈。问对方打算怎么处理。任何新约定都要书面化再签字。</p>
              </div>
            </details>

            <details class="b60-change">
              <summary class="b60-change-summary">4. 在欠租听证中投诉维修问题,先要押钱。</summary>
              <div class="b60-change-body">
                <p>常见情况:租客欠了租。房东把他告到 LTB。听证上,租客说:"房子有问题,我不应该全额付租。" 这往往会拖延流程。</p>
              <p>原来:租客可以免费把维修问题作为抗辩。</p>
              <p>现在:租客必须先把所欠租金的 50% 存入 LTB 信托账户,投诉才会被审理。</p>
              <p>该怎么做:如果您确有维修问题,实时存证。给房东发文字请求(邮件或短信)。拍带日期的照片。不要等到听证才开始收集。</p>
              </div>
            </details>

            <details class="b60-change">
              <summary class="b60-change-summary">5. 上诉驱逐令的时间变短了。</summary>
              <div class="b60-change-body">
                <p>如果 LTB 判您败诉,您有一段时间可以上诉。</p>
              <p>原来:30 天。现在:15 天。</p>
              <p>该怎么做:收到不利裁决的当周内就找 paralegal。不要拖。</p>
              </div>
            </details>

            <h2 id="status">Bill 60 目前生效了吗?</h2>
            <p>Bill 60 于 2025 年 11 月 24 日通过。但"通过"不等于"生效"。Tribunals Ontario 要先更新表格、培训和系统,各项变化才能正式启动。</p>
            <p>截至 2026 年中,部分租赁条款仍在分阶段实施中。这就是为什么行动前要核实。</p>
            <div class="callout"><strong>采取行动前:</strong>如果您是房东,准备用 7 天 N4 或不赔付的 120 天 N12,请先向 LTB 核实该条款是否已生效。发错通知,整个案件可能作废。租客也一样 — 收到看起来奇怪或仓促的通知,先咨询,不要默认它有效。</div>

            <h2 id="tenants">如果您是多伦多的租客</h2>
            <ul class="bullets">
              <li><strong>开启租金自动扣款。</strong>7 天 N4 太短。一次忘记缴费就可能引发驱逐流程。</li>
              <li><strong>租约到期前就和房东谈。</strong>提前 2 到 3 个月开始。不要默认旧的权利仍然适用。</li>
              <li><strong>保存维修证据。</strong>所有请求都用邮件或短信。带日期的照片要留。日后可能用得上。</li>
              <li><strong>N12 不一定是真的。</strong>收到就找 paralegal。常见审阅费 $200 到 $500。</li>
              <li><strong>LTB 判您败诉,立刻行动。</strong>15 天很短。</li>
            </ul>

            <h2 id="landlords">如果您是多伦多的房东</h2>
            <ul class="bullets">
              <li><strong>不要急着用新规则。</strong>Bill 60 不是每一项都已生效。引用尚未生效的条款,案件可能作废。</li>
              <li><strong>当作明天就要上 LTB 一样存档。</strong>维修记录、租客往来、房屋状况报告 — 全部保留。</li>
              <li><strong>慎用固定期限的新灵活性。</strong>过激的续约条款会破坏租客关系,也会为下一个选举周期里法律向另一端摆动埋下伏笔。</li>
              <li><strong>120 天无赔付 N12 只在情况真实时才值得用。</strong>恶意 N12 在 LTB 现在动辄罚款 5 万以上。</li>
            </ul>

            <h2 id="why">为什么重要</h2>
            <p>Bill 60 是安省过去十年间最偏向房东的一部租房立法。政府的判断是:更宽松的驱逐规则会让更多房东把空置房屋投入出租市场,从而增加供应。</p>
            <p>批评者认为,这部法律削弱了租客保护,却没有解决更深层的问题 — 租金过高。</p>
            <p>两边的说法都各有道理。对您今天最重要的是,搞清楚自己正在参与的游戏规则。</p>

            <p class="legal-note">本文仅供信息参考,不构成法律意见。Bill 60 内容复杂,仍在分阶段实施。具体情况请咨询在安省律师公会注册的 paralegal、联系 LTB,或前往社区法律诊所。本文参考资料:Tribunals Ontario 实施指引、Canadian Centre for Housing Rights、Globe and Mail 对该法的报道、OntarioLandlord.ca 实施追踪。我是注册房地产销售代表,不是律师。</p>

            <div class="seo-tags" aria-label="关键词">
              <h4>关键词</h4>
              <ul>
                <li>安省 Bill 60</li>
                <li>加快建设减少拖延法</li>
                <li>安省驱逐规则 2026</li>
                <li>N12 补偿 Bill 60</li>
                <li>N4 7天通知 安省</li>
                <li>固定期限租约 安省</li>
                <li>LTB 上诉 15 天</li>
                <li>住宅租赁法 2026</li>
                <li>多伦多 房东租客法律</li>
                <li>Bill 60 租客权利</li>
              </ul>
            </div>
</div>
        </div>
      </div>
    </section>
  </article>

  <ChineseCTASection heading="对 Bill 60 有问题?" lead="刚收到通知的租客,或想搞清楚目前哪些规则已生效的房东 — 把您手上的资料发给我。我能讲清的部分我会讲清,需要更深入的我会推荐我信任的 paralegal。" />
  <ChineseFooter />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
</BaseLayout>

<style>
  .b60-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; margin: 24px 0 28px; border: 1px solid var(--rule); border-radius: 6px; overflow: hidden; background: var(--bg-warm); }
  .b60-stat { padding: 22px 16px; text-align: center; border-right: 1px solid var(--rule); display: flex; flex-direction: column; align-items: center; justify-content: flex-start; gap: 10px; }
  .b60-stat:last-child { border-right: none; }
  .b60-stat-num { font-family: 'Fraunces', Georgia, serif; font-weight: 400; font-size: 44px; line-height: 1; color: var(--ink); letter-spacing: -0.02em; }
  .b60-stat-pct { font-size: 28px; color: var(--ink-soft); margin-left: 1px; }
  .b60-stat-cap { font-size: 12px; line-height: 1.45; color: var(--ink-soft); max-width: 200px; }
  .b60-stat-cap span { color: var(--ink-mute); }
  @media (max-width: 720px) {
    .b60-stats { grid-template-columns: 1fr 1fr; }
    .b60-stat { border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
    .b60-stat:nth-child(2) { border-right: none; }
    .b60-stat:nth-child(3), .b60-stat:nth-child(4) { border-bottom: none; }
    .b60-stat-num { font-size: 36px; }
  }
  @media (max-width: 420px) {
    .b60-stats { grid-template-columns: 1fr; }
    .b60-stat { border-right: none; border-bottom: 1px solid var(--rule); }
    .b60-stat:last-child { border-bottom: none; }
  }
  .b60-intro { background: var(--bg-warm); border-left: 3px solid var(--ink); padding: 18px 22px; margin: 24px 0 28px; border-radius: 4px; font-size: 14.5px; line-height: 1.65; color: var(--ink-soft); }
  .b60-intro strong { color: var(--ink); }
  .b60-table-wrap { overflow-x: auto; margin: 0 0 32px; border: 1px solid var(--rule); border-radius: 6px; }
  .b60-table { width: 100%; border-collapse: collapse; font-size: 14px; min-width: 600px; }
  .b60-table thead th { background: var(--ink); color: var(--surface); padding: 14px 16px; text-align: left; font-weight: 500; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; }
  .b60-table tbody td { padding: 16px; vertical-align: top; border-top: 1px solid var(--rule); line-height: 1.55; }
  .b60-table tbody tr:nth-child(even) td { background: var(--bg-warm); }
  .b60-table .b60-rule { font-weight: 600; color: var(--ink); width: 26%; font-size: 14px; }
  .b60-table .b60-before { color: var(--ink-soft); width: 37%; }
  .b60-table .b60-after { color: var(--ink); font-weight: 600; width: 37%; }
  @media (max-width: 600px) {
    .b60-table-wrap { border-radius: 4px; }
    .b60-table thead th { font-size: 11px; padding: 12px 14px; }
    .b60-table tbody td { padding: 14px; font-size: 13.5px; }
  }
</style>
