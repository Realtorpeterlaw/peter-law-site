---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
---
<BaseLayout
  title="Home Affordability Calculator | Peter Law"
  description="How much house can you afford? Calculate the maximum purchase price you qualify for based on income, debts, and Canadian lending rules (GDS/TDS + stress test)."
  bodyClass="calc-page"
>
  <TopBar />
  <Header active="buyers" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Affordability calculator</div>
      <h1>How much can you actually afford?</h1>
      <p>Estimates your maximum purchase price using Canadian lending rules — GDS/TDS ratios and the federal mortgage stress test.</p>
    </div>
  </section>

  <section class="major" style="padding-top: 32px;">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side">
          <h4>Buyer resources</h4>
          <ul>
            <li><a href="/buyer-guide">Buyer Guide</a></li>
            <li><a href="/payment-calculator">Mortgage Calculator</a></li>
            <li><a href="/affordability-calculator">Affordability Calculator</a></li>
            <li><a href="/land-transfer-tax">Land Transfer Tax</a></li>
            <li><a href="/closing-costs">Closing Costs</a></li>
          </ul>
        </aside>
        <div class="prose-body">
          <div class="calc">
            <div class="calc-fields">
              <div class="calc-field">
                <label for="af-income">Annual household income <span class="hint">(gross)</span></label>
                <div class="input-prefix" data-prefix="$"><input id="af-income" type="number" value="120000" min="0" step="1000"></div>
              </div>
              <div class="calc-field">
                <label for="af-debt">Monthly debt payments <span class="hint">(car, student, credit cards)</span></label>
                <div class="input-prefix" data-prefix="$"><input id="af-debt" type="number" value="500" min="0" step="50"></div>
              </div>
              <div class="calc-field">
                <label for="af-down">Down payment available</label>
                <div class="input-prefix" data-prefix="$"><input id="af-down" type="number" value="100000" min="0" step="1000"></div>
              </div>
              <div class="calc-field">
                <label for="af-rate">Mortgage rate <span class="hint">(% per year)</span></label>
                <input id="af-rate" type="number" value="5.0" min="0" max="20" step="0.01">
              </div>
              <div class="calc-field">
                <label for="af-amort">Amortization <span class="hint">(years)</span></label>
                <select id="af-amort">
                  <option value="25" selected>25 years</option>
                  <option value="30">30 years</option>
                  <option value="20">20 years</option>
                </select>
              </div>
              <div class="calc-field">
                <label for="af-tax">Annual property tax <span class="hint">(rough estimate)</span></label>
                <div class="input-prefix" data-prefix="$"><input id="af-tax" type="number" value="4500" min="0" step="100"></div>
              </div>
              <div class="calc-field">
                <label for="af-heat">Monthly heating <span class="hint">(rough estimate)</span></label>
                <div class="input-prefix" data-prefix="$"><input id="af-heat" type="number" value="150" min="0" step="10"></div>
              </div>
              <div class="calc-field">
                <label for="af-condo">Monthly condo fee <span class="hint">(if applicable)</span></label>
                <div class="input-prefix" data-prefix="$"><input id="af-condo" type="number" value="0" min="0" step="50"></div>
              </div>
            </div>

            <div class="calc-result">
              <div class="calc-result-main">
                <span class="label">Maximum purchase price</span>
                <span id="af-max">$0</span>
              </div>
              <div class="calc-result-breakdown">
                <div class="row"><span>Max mortgage you'd qualify for</span><strong id="af-mortgage">$0</strong></div>
                <div class="row"><span>Down payment</span><strong id="af-dp">$0</strong></div>
                <div class="row"><span>Stress-tested at</span><strong id="af-stress">5.25%</strong></div>
                <div class="row"><span>Estimated monthly payment</span><strong id="af-payment">$0</strong></div>
                <div class="row"><span>GDS ratio used</span><strong>39%</strong></div>
                <div class="row"><span>TDS ratio used</span><strong>44%</strong></div>
              </div>
            </div>
            <p class="calc-disclaimer">For illustrative purposes only. Federal stress test rule applies the greater of (contract rate + 2%) or 5.25%. Lenders use slightly different qualifying ratios; the actual maximum a lender will approve varies. Does not include CMHC insurance premiums. Consult a licensed mortgage professional.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection heading="Translation: what does this mean for you?" lead="Numbers on a calculator are one thing. Knowing what's actually available in your price range — and which neighborhoods make sense — is what I do. Let's talk." />
  <Footer />

  <script>
    function fmtCAD(n) {
      if (!isFinite(n) || isNaN(n) || n < 0) return '$0';
      return n.toLocaleString('en-CA', { style: 'currency', currency: 'CAD', maximumFractionDigits: 0 });
    }
    function calcCanadianPayment(principal, annualRatePct, amortYears, paymentsPerYear) {
      if (principal <= 0 || annualRatePct < 0 || amortYears <= 0) return 0;
      const semiAnnualRate = annualRatePct / 200;
      const periodicRate = Math.pow(1 + semiAnnualRate, 2 / paymentsPerYear) - 1;
      const n = amortYears * paymentsPerYear;
      if (periodicRate === 0) return principal / n;
      return principal * periodicRate / (1 - Math.pow(1 + periodicRate, -n));
    }
    function update() {
      const income = parseFloat(document.getElementById('af-income').value) || 0;
      const monthlyDebt = parseFloat(document.getElementById('af-debt').value) || 0;
      const down = parseFloat(document.getElementById('af-down').value) || 0;
      const rate = parseFloat(document.getElementById('af-rate').value) || 0;
      const amort = parseFloat(document.getElementById('af-amort').value) || 25;
      const annualTax = parseFloat(document.getElementById('af-tax').value) || 0;
      const monthlyHeat = parseFloat(document.getElementById('af-heat').value) || 0;
      const monthlyCondo = parseFloat(document.getElementById('af-condo').value) || 0;

      const stressRate = Math.max(rate + 2, 5.25);
      document.getElementById('af-stress').textContent = stressRate.toFixed(2) + '%';

      const monthlyIncome = income / 12;
      const monthlyTax = annualTax / 12;
      const housingCostsExclMortgage = monthlyTax + monthlyHeat + monthlyCondo * 0.5; // CMHC counts 50% of condo fee
      const gdsMaxMonthly = monthlyIncome * 0.39 - housingCostsExclMortgage;
      const tdsMaxMonthly = monthlyIncome * 0.44 - housingCostsExclMortgage - monthlyDebt;
      const maxMonthlyMortgagePayment = Math.max(0, Math.min(gdsMaxMonthly, tdsMaxMonthly));

      // Reverse-engineer max mortgage principal from max monthly payment at stress rate
      const semiAnnualRate = stressRate / 200;
      const periodicRate = Math.pow(1 + semiAnnualRate, 1 / 6) - 1;
      const n = amort * 12;
      let maxMortgage = 0;
      if (periodicRate > 0 && maxMonthlyMortgagePayment > 0) {
        maxMortgage = maxMonthlyMortgagePayment * (1 - Math.pow(1 + periodicRate, -n)) / periodicRate;
      } else if (maxMonthlyMortgagePayment > 0) {
        maxMortgage = maxMonthlyMortgagePayment * n;
      }

      const maxPrice = maxMortgage + down;
      const actualPayment = calcCanadianPayment(maxMortgage, rate, amort, 12);
      document.getElementById('af-max').textContent = fmtCAD(maxPrice);
      document.getElementById('af-mortgage').textContent = fmtCAD(maxMortgage);
      document.getElementById('af-dp').textContent = fmtCAD(down);
      document.getElementById('af-payment').textContent = fmtCAD(actualPayment) + ' / mo';
    }
    document.querySelectorAll('#af-income,#af-debt,#af-down,#af-rate,#af-amort,#af-tax,#af-heat,#af-condo').forEach(el => {
      el.addEventListener('input', update);
      el.addEventListener('change', update);
    });
    update();
  </script>
</BaseLayout>
