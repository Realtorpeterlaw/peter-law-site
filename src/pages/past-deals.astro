---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import PropertySales from '../components/PropertySales.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="Sale History — Peter Law Toronto Real Estate" description="A running record of recent rentals and sales closed by Peter Law across the Greater Toronto Area.">
  <TopBar />
  <Header active="about" ctaLabel="Book a call" />

  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <div class="eyebrow"><a href="/about" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>About</a> · Past Deals</div>
        <h1 class="hero-h">Sale History</h1>
      </div>
      <div>
        <div class="hero-photo">
          <img src="/photos/peter-portrait.webp" alt="Peter Law, Toronto real estate sales representative, with the CN Tower behind him." width="1500" height="1887" loading="eager" />
        </div>
        <div class="agent-byline">
          <div class="agent-name">Peter Law</div>
          <div class="agent-title">Sales Representative</div>
          <div class="agent-brokerage">Home Life Golconda Realty., Inc Brokerage.</div>
          <div class="agent-phones">
            <div><span class="lbl">DIRECT:</span> <a href="tel:+16478888472">(647) 888 - 8472</a></div>
            <div><span class="lbl">OFFICE:</span> <a href="tel:+19058888819">(905) 888 - 8819</a></div>
            <div><a href="mailto:Admin@RealtorPeterLaw.com">Admin@RealtorPeterLaw.com</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <PropertySales />

  <CTASection heading="Looking for your next place?" lead="The same playbook that closed these deals is the one I'll use for yours. Fifteen-minute intro call, no obligation." ctaTitle="Book a call" />
  <Footer />
</BaseLayout>

<style>
  .hero { padding-bottom: 16px; }
  .hero-grid { align-items: start; }
  .hero-photo {
    max-width: 320px;
    margin-left: auto;
    margin-right: 0;
  }
  .agent-byline {
    margin-top: 22px;
    max-width: 320px;
    margin-left: auto;
    margin-right: 0;
    text-align: right;
  }
  @media (max-width: 1200px) {
    .hero-photo, .agent-byline { margin-right: 0; }
  }
  .agent-name {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 30px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .agent-title {
    font-size: 15px;
    color: var(--ink-soft);
    margin-top: 4px;
    letter-spacing: 0.01em;
  }
  .agent-brokerage {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--ink);
    margin-top: 12px;
    letter-spacing: -0.005em;
    line-height: 1.25;
  }
  .agent-phones {
    margin-top: 14px;
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.7;
    font-variant-numeric: tabular-nums;
  }
  .agent-phones .lbl {
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
    font-weight: 600;
    margin-right: 4px;
  }
  .agent-phones a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .agent-phones a:hover { border-bottom-color: var(--ink-mute); }
  @media (max-width: 640px) {
    .agent-name { font-size: 26px; }
    .agent-brokerage { font-size: 19px; }
  }
</style>
