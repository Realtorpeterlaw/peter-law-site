---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import RecentDealsArchive from '../components/RecentDealsArchive.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="Sale History — Peter Law Toronto Real Estate" description="A running record of recent rentals and sales closed by Peter Law across the Greater Toronto Area.">
  <TopBar />
  <Header active="about" ctaLabel="Book a call" />

  <section class="past-hero">
    <div class="wrap past-hero-grid">
      <div class="past-hero-photo">
        <img src="/photos/peter-portrait.webp" alt="Peter Law, Toronto real estate sales representative, with the CN Tower behind him." width="1500" height="1887" loading="eager" />
      </div>
      <div class="past-hero-text">
        <div class="eyebrow"><a href="/about" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>About</a> · Past Deals</div>
        <h1>Sale History</h1>
      </div>
    </div>
  </section>

  <RecentDealsArchive />

  <CTASection heading="Looking for your next place?" lead="The same playbook that closed these deals is the one I'll use for yours. Fifteen-minute intro call, no obligation." ctaTitle="Book a call" />
  <Footer />
</BaseLayout>

<style>
  .past-hero { padding: 56px 0 56px; }
  .past-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 56px;
    align-items: center;
  }
  .past-hero-photo {
    aspect-ratio: 4 / 5;
    background: var(--bg-warm);
    border-radius: 4px;
    overflow: hidden;
    max-width: 440px;
  }
  .past-hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .past-hero-text .eyebrow { margin-bottom: 22px; }
  .past-hero-text h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: clamp(40px, 5vw, 60px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    margin: 0;
    color: var(--ink);
  }
  @media (max-width: 900px) {
    .past-hero { padding: 36px 0 36px; }
    .past-hero-grid { grid-template-columns: 1fr; gap: 28px; }
    .past-hero-photo { max-width: 320px; }
  }
</style>
