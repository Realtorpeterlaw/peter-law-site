---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const FORMSPREE_ENDPOINT = "https://formspree.io/f/xnjrzgda";
---
<BaseLayout
  title="Home Insurance Quote — Toronto | Peter Law"
  description="Get a home insurance quote from a trusted broker. Fill the form, your details go to a licensed insurance partner who'll come back with options."
  bodyClass="calc-page"
>
  <TopBar />
  <Header active="sales" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Home insurance quote</div>
      <h1>Get a home insurance quote.</h1>
      <p>I work with a licensed insurance broker who handles home and condo policies for my clients. Fill the form — they'll come back to you with options within 1-2 business days.</p>
    </div>
  </section>

  <section class="major" style="padding-top: 32px;">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side">
          <h4>Tools</h4>
          <ul>
            <li><a href="/payment-calculator">Payment</a></li>
            <li><a href="/affordability-calculator">Affordability</a></li>
            <li><a href="/land-transfer-tax-calculator">Land Transfer Tax</a></li>
            <li><a href="/cmhc-insurance-calculator">CMHC Insurance</a></li>
            <li><a href="/home-insurance-quoter">Home Insurance</a></li>
          </ul>
        </aside>
        <div class="prose-body">
          <h2 style="margin-top:0;">How this works</h2>
          <p>I'm not licensed to sell insurance — I'm a real estate sales representative. What I can do is connect you with a licensed broker I trust, who handles home insurance for many of my clients.</p>
          <p>Fill the form below. Your details go to me and the broker. The broker reaches out within 1-2 business days with quotes from multiple insurers. No obligation to buy.</p>

          <div class="calc">
            <form method="POST" action={FORMSPREE_ENDPOINT}>
              <div class="calc-fields">
                <div class="calc-field">
                  <label for="hi-name">Full name <span class="hint">*</span></label>
                  <input id="hi-name" name="name" type="text" required autocomplete="name">
                </div>
                <div class="calc-field">
                  <label for="hi-email">Email <span class="hint">*</span></label>
                  <input id="hi-email" name="email" type="email" required autocomplete="email">
                </div>
                <div class="calc-field">
                  <label for="hi-phone">Phone <span class="hint">*</span></label>
                  <input id="hi-phone" name="phone" type="tel" required autocomplete="tel">
                </div>
                <div class="calc-field">
                  <label for="hi-type">Property type</label>
                  <select id="hi-type" name="property_type">
                    <option>Condo</option>
                    <option>House — detached</option>
                    <option>House — semi-detached</option>
                    <option>Townhouse</option>
                    <option>Rental unit (landlord policy)</option>
                  </select>
                </div>
                <div class="calc-field calc-field-full">
                  <label for="hi-address">Property address <span class="hint">*</span></label>
                  <input id="hi-address" name="address" type="text" required placeholder="123 Main St, Toronto, ON">
                </div>
                <div class="calc-field">
                  <label for="hi-year">Year built <span class="hint">(approximate)</span></label>
                  <input id="hi-year" name="year_built" type="number" min="1800" max="2030" placeholder="e.g. 2015">
                </div>
                <div class="calc-field">
                  <label for="hi-sqft">Square footage</label>
                  <input id="hi-sqft" name="sqft" type="number" min="100" step="50" placeholder="e.g. 900">
                </div>
                <div class="calc-field">
                  <label for="hi-when">When do you need coverage?</label>
                  <select id="hi-when" name="when">
                    <option>ASAP — closing soon</option>
                    <option>Within 30 days</option>
                    <option>Within 1-3 months</option>
                    <option>Just shopping around</option>
                  </select>
                </div>
                <div class="calc-field">
                  <label for="hi-current">Currently insured?</label>
                  <select id="hi-current" name="currently_insured">
                    <option>No / first time</option>
                    <option>Yes, looking for better rate</option>
                    <option>Yes, switching insurers</option>
                  </select>
                </div>
                <div class="calc-field calc-field-full">
                  <label for="hi-notes">Anything the broker should know? <span class="hint">(previous claims, special items, etc.)</span></label>
                  <input id="hi-notes" name="notes" type="text">
                </div>
                <div class="hp-field" aria-hidden="true">
                  <label for="hi-gotcha">Don't fill this</label>
                  <input id="hi-gotcha" name="_gotcha" type="text" tabindex="-1" autocomplete="off">
                </div>
                <input type="hidden" name="_subject" value="New Home Insurance Quote Request">
                <input type="hidden" name="_next" value="https://www.realtorpeterlaw.com/contact/thanks">
              </div>
              <button type="submit" class="btn-primary" style="margin-top: 24px;">
                Request my quote
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </button>
              <p class="calc-disclaimer">Your details are shared with my preferred insurance broker for the purpose of providing a quote. No obligation. You're free to use any broker you prefer; this is just a referral.</p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
