---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/SpanishTopBar.astro';
import LHeader from '../../components/SpanishHeader.astro';
import LFooter from '../../components/SpanishFooter.astro';
import LCTA from '../../components/SpanishCTASection.astro';
export const prerender = true;
---
<BaseLayout title="Impuesto de transferencia \u2014 Ontario + Toronto | Peter Law" description="Calcula tus impuestos de transferencia inmobiliaria (LTT) provincial y municipal. Reembolso para primeros compradores incluido." lang="es" bodyClass="es">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Compradores · Impuesto de transferencia</div><h1>Impuesto de transferencia</h1><p>Toda compra inmobiliaria en Ontario está sujeta al impuesto de transferencia provincial. Los compradores en Toronto también pagan el municipal (MLTT). Los primeros compradores reciben un reembolso parcial.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="calc">
    <div class="calc-fields">
      <div class="calc-field calc-field-full"><label for="ltt-price">Precio de compra</label><div class="input-prefix"><input type="number" id="ltt-price" value="900000" min="0" step="5000" /></div></div>
      <div class="calc-field"><label for="ltt-toronto">Ubicación</label><select id="ltt-toronto"><option value="yes" selected>Ciudad de Toronto</option><option value="no">Resto de Ontario</option></select></div>
      <div class="calc-field"><label for="ltt-fthb">¿Primer comprador?</label><select id="ltt-fthb"><option value="yes" selected>Sí</option><option value="no">No</option></select></div>
    </div>
    <div class="calc-result">
      <div class="calc-result-main"><span class="label">Total a pagar</span><span id="ltt-total">$0</span></div>
      <div class="calc-result-breakdown">
        <div class="row"><span>LTT Ontario</span><strong id="ltt-ont">$0</strong></div>
        <div class="row" id="ltt-mltt-row"><span>LTT Toronto</span><strong id="ltt-mltt">$0</strong></div>
        <div class="row" id="ltt-rebate-row" style="display:none;"><span>Reembolso primer comprador</span><strong id="ltt-rebate">−$0</strong></div>
      </div>
    </div>
    <p class="calc-disclaimer">Para orientación. Se usan tasas 2026. Confirma con tu abogado los números finales.</p>
  </div></div></section>
  <LCTA />
  <LFooter />
  <script is:inline>
    (function(){
      function fmt(n){return (n||0).toLocaleString('en-CA',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function ontLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000)t+=(p-2000000)*.025;return t;}
      function torMLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000){const lx=[[3000000,.025],[4000000,.035],[5000000,.045],[10000000,.055],[20000000,.065]];let l=2000000;for(const[u,r]of lx){if(p>l){const x=Math.min(p,u)-l;if(x>0)t+=x*r;}l=u;}if(p>20000000)t+=(p-20000000)*.075;}return t;}
      function c(){const p=parseFloat(document.getElementById('ltt-price').value)||0;const isTo=document.getElementById('ltt-toronto').value==='yes';const fthb=document.getElementById('ltt-fthb').value==='yes';const o=ontLTT(p);const m=isTo?torMLTT(p):0;let re=0;if(fthb){re=Math.min(o,4000);if(isTo)re+=Math.min(m,4475);}const t=Math.max(0,o+m-re);document.getElementById('ltt-total').textContent=fmt(t);document.getElementById('ltt-ont').textContent=fmt(o);document.getElementById('ltt-mltt').textContent=fmt(m);document.getElementById('ltt-mltt-row').style.display=isTo?'':'none';if(re>0){document.getElementById('ltt-rebate-row').style.display='';document.getElementById('ltt-rebate').textContent='−'+fmt(re);}else{document.getElementById('ltt-rebate-row').style.display='none';}}
      ['ltt-price','ltt-toronto','ltt-fthb'].forEach(id=>{const el=document.getElementById(id);el.addEventListener('input',c);el.addEventListener('change',c);});c();
    })();
  </script>
</BaseLayout>
