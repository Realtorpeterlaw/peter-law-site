---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/SpanishTopBar.astro';
import LHeader from '../../components/SpanishHeader.astro';
import LFooter from '../../components/SpanishFooter.astro';
import LCTA from '../../components/SpanishCTASection.astro';
---
<BaseLayout title="Calculadora hipotecaria | Peter Law" description="Calcula tu pago hipotecario mensual. Reglas canadienses: composici\u00f3n semestral, tasas CMHC, prueba de estr\u00e9s federal." lang="es" bodyClass="es calc-page">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Calculadora hipotecaria</div><h1>Tu pago hipotecario mensual.</h1><p>Composición semestral canadiense + prueba de estrés federal incluidos.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="calc">
    <div class="calc-fields">
      <div class="calc-field"><label for="p-price">Precio de compra</label><div class="input-prefix"><input type="number" id="p-price" value="800000" min="0" step="5000" /></div></div>
      <div class="calc-field"><label for="p-down">Enganche</label><div class="input-prefix"><input type="number" id="p-down" value="80000" min="0" step="1000" /></div></div>
      <div class="calc-field"><label for="p-rate">Tasa (%)</label><div class="input-suffix"><input type="number" id="p-rate" value="5.0" min="0" step="0.05" /></div></div>
      <div class="calc-field"><label for="p-amort">Amortización (años)</label><input type="number" id="p-amort" value="25" min="5" max="35" step="1" /></div>
      <div class="calc-field"><label for="p-freq">Frecuencia</label><select id="p-freq"><option value="12" selected>Mensual</option><option value="26">Quincenal</option><option value="52">Semanal</option></select></div>
    </div>
    <div class="calc-result">
      <div class="calc-result-main"><span class="label">Pago</span><span id="p-monthly">$0</span></div>
      <div class="calc-result-breakdown">
        <div class="row"><span>Hipoteca total</span><strong id="p-mortgage">$0</strong></div>
        <div class="row"><span>CMHC</span><strong id="p-cmhc">$0</strong></div>
        <div class="row"><span>Pago con prueba de estrés</span><strong id="p-stress">$0</strong></div>
      </div>
    </div>
    <p class="calc-disclaimer">Solo con fines orientativos. Consulta con un corredor hipotecario para las cifras finales.</p>
  </div></div></section>
  <LCTA />
  <LFooter />
  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('es-MX',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function pRate(r,n){const s=r/200;return Math.pow(1+s,2/n)-1;}
      function pay(p,r,y,f){if(p<=0||y<=0)return 0;const rr=pRate(r,f);const n=y*f;if(rr===0)return p/n;return p*rr/(1-Math.pow(1+rr,-n));}
      function cmhcR(l){if(l>95)return null;if(l>90)return .04;if(l>85)return .031;if(l>80)return .028;return 0;}
      function c(){
        const p=parseFloat(document.getElementById('p-price').value)||0;
        const d=parseFloat(document.getElementById('p-down').value)||0;
        const r=parseFloat(document.getElementById('p-rate').value)||0;
        const y=parseInt(document.getElementById('p-amort').value,10)||25;
        const f=parseInt(document.getElementById('p-freq').value,10)||12;
        const bl=Math.max(0,p-d);
        const ltv=p>0?(p-d)/p*100:0;
        const cr=cmhcR(ltv);
        const cp=(cr!==null&&cr>0)?bl*cr:0;
        const tm=bl+cp;
        const m=pay(tm,r,y,f);
        const sr=Math.max(r+2,5.25);
        const sp=pay(tm,sr,y,f);
        document.getElementById('p-monthly').textContent=fmt(m);
        document.getElementById('p-mortgage').textContent=fmt(tm);
        document.getElementById('p-cmhc').textContent=fmt(cp);
        document.getElementById('p-stress').textContent=fmt(sp);
      }
      ['p-price','p-down','p-rate','p-amort','p-freq'].forEach(id=>{const el=document.getElementById(id);el.addEventListener('input',c);el.addEventListener('change',c);});c();
    })();
  </script>
</BaseLayout>
