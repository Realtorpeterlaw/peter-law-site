---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangTopBar from '../../components/SpanishTopBar.astro';
import LangHeader from '../../components/SpanishHeader.astro';
import LangFooter from '../../components/SpanishFooter.astro';
import LangCTA from '../../components/SpanishCTASection.astro';
---
<BaseLayout title="Para propietarios \u2014 Peter Law \u00b7 Alquiler en Toronto" description="\u00bfAlquilas tu propiedad en Toronto? C\u00f3mo encuentro un inquilino AAA." lang="es" bodyClass="es">
  <LangTopBar />
  <LangHeader active="rental" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Alquiler · Propietarios</div>
      <h1>Alquila más rápido. Con el inquilino correcto.</h1>
      <p>Velocidad y exhaustividad ganan los anuncios.</p>
    </div>
  </section>

  <section class="major">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side"><h4>—</h4><ul>
          <li><a href="#pricing">Precio</a></li>
          <li><a href="#staging">Comercialización</a></li>
          <li><a href="#screening">Selección</a></li>
          <li><a href="#lease">El contrato</a></li>
        </ul></aside>
        <div class="prose-body">
          <h2 id="pricing">Precio</h2>
          <p>Muy bajo dejas dinero. Muy alto se estanca 6 semanas.</p>
          <h2 id="staging">Comercialización</h2>
          <p>Fotografía profesional, distribución en TRREB / MLS® / Realtor.ca.</p>
          <h2 id="screening">Selección</h2>
          <p>Reviso cada solicitud: empleo, crédito, propietario anterior.</p>
          <h2 id="lease">El contrato</h2>
          <p>Contrato estándar de Ontario (Formulario 2229E).</p>
        </div>
      </div>
    </div>
  </section>

  <LangCTA heading="\u00bfListo para alquilar?" lead="Env\u00eda la direcci\u00f3n. Respondo en 24 horas con precio y plan." />
  <LangFooter />
</BaseLayout>
