---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/SpanishTopBar.astro';
import Header from '../../../components/SpanishHeader.astro';
import Footer from '../../../components/SpanishFooter.astro';

export const prerender = true;

const publishedDate = '2026-07-14';
const articleTitle = 'Rental Housing Supply Program (RHSP) — Toronto';
const articleDescription = 'Guia en lenguaje claro del Rental Housing Supply Program (RHSP) de la Ciudad de Toronto. Que es, quien puede solicitar, los cinco flujos de financiacion, y que significa para los inquilinos de Toronto.';
const articleUrl = 'https://www.realtorpeterlaw.com/spanish/blog/rhsp';
const enUrl = 'https://www.realtorpeterlaw.com/blog/rhsp';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/spanish/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Bienes Raices en Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'es',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'RHSP Toronto, programa alquiler accesible Toronto, vivienda accesible Toronto, subsidio construccion alquiler, programa municipal vivienda',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/rhsp/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/rhsp/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/rhsp/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/rhsp/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/rhsp/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/rhsp/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/rhsp/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Bienes Raices en Toronto`}
  description={articleDescription}
  lang="es"
  bodyClass="es guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/spanish/blog" class="back-link">Blog</a> · Inquilinos en Toronto</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Toronto ayuda a los constructores a levantar mas vivienda en alquiler. Algunas quedan a renta accesible hasta 40 anos, otras son apartamentos al precio de mercado. Aqui de que trata el programa, quien puede participar, y como impacta a los inquilinos.</p>
        <div class="article-byline">
          <span>Por <a href="/spanish/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-07-14</time>
          <span class="dot">·</span>
          <span>5 min de lectura</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>En esta pagina</h4>
            <ul>
              <li><a href="#what">Que es?</a></li>
              <li><a href="#streams">Los cinco flujos</a></li>
              <li><a href="#who">Quien puede solicitar</a></li>
              <li><a href="#affordable">Renta accesible</a></li>
              <li><a href="#impact">Que cambia para usted</a></li>
              <li><a href="#read-full">Leer la guia completa en ingles →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Organismo</span><span class="qf-val">Ciudad de Toronto</span></div>
              <div class="qf-row"><span class="qf-label">Meta</span><span class="qf-val">Nueva vivienda en alquiler a 10 anos</span></div>
              <div class="qf-row"><span class="qf-label">Flujos</span><span class="qf-val">5 lineas de financiacion</span></div>
              <div class="qf-row"><span class="qf-label">Accesibilidad</span><span class="qf-val">Algunas unidades a renta accesible hasta 40 anos</span></div>
              <div class="qf-row"><span class="qf-label">Quien solicita</span><span class="qf-val">Constructores y arrendadores — no inquilinos directamente</span></div>
            </div>


            <h2 id="what">Que es?</h2>
            <p>El RHSP es un programa municipal que otorga a los constructores de vivienda en alquiler en Toronto <strong>subsidios, prestamos blandos, alivio fiscal y terrenos</strong>. Meta: sumar miles de unidades de alquiler en los proximos 10 anos, con parte fijada como <strong>renta accesible</strong>.</p>

            <h2 id="streams">Los cinco flujos</h2>
            <p>El programa se divide en cinco: nuevo alquiler accesible, alquiler a precio de mercado, preservacion de alquiler existente, vivienda con apoyo (supportive), y reactivacion de terrenos publicos.</p>

            <h2 id="who">Quien puede solicitar</h2>
            <p>Solicitan <strong>constructores, desarrolladores y arrendadores</strong> — no los inquilinos directamente. Usted, como inquilino, se beneficia cuando un proyecto aprobado se completa cerca de su barrio.</p>

            <h2 id="affordable">Renta accesible</h2>
            <p>Las unidades accesibles se topan segun estandares municipales (a menudo 80 % de la renta mediana del mercado) y se mantienen asi <strong>hasta 40 anos</strong>. Eso distingue al programa de un simple incentivo a construir.</p>

            <h2 id="impact">Que cambia para usted</h2>
            <p>Mas oferta, sobre todo en zonas nuevas, y un stock creciente de renta accesible protegida. No es una bajada inmediata de precios, sino estabilizacion en el tiempo.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version larga de esta guia (cifras, casos especiales, procedimiento) esta en ingles:</p>
              <a class="btn-primary" href={enUrl}>Leer la guia completa en ingles →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
