---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/SpanishTopBar.astro';
import Header from '../../../components/SpanishHeader.astro';
import Footer from '../../../components/SpanishFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-03';
const articleTitle = 'Time-of-Use (TOU) — como bajar la factura de luz';
const articleDescription = 'Guia sencilla del tarifa Time-of-Use (TOU) en Ontario: los tres precios, cuando aplica cada uno, y 7 acciones faciles para bajar la factura sin cambiar tu estilo de vida.';
const articleUrl = 'https://www.realtorpeterlaw.com/spanish/blog/time-of-use-tou';
const enUrl = 'https://www.realtorpeterlaw.com/blog/time-of-use-tou';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/spanish/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Bienes Raices en Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'es',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'Time of Use Ontario, TOU electricidad Ontario, tarifa electricidad Ontario, horas off-peak, ULO Ontario, bajar factura luz Toronto',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/time-of-use-tou/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/time-of-use-tou/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/time-of-use-tou/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/time-of-use-tou/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/time-of-use-tou/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/time-of-use-tou/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/time-of-use-tou/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Bienes Raices en Toronto`}
  description={articleDescription}
  lang="es"
  bodyClass="es guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/spanish/blog" class="back-link">Blog</a> · Factura de electricidad</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Tu factura de luz tiene tres precios. Si usas la energia a la hora correcta, pagas mucho menos. Aqui como funciona, en palabras simples.</p>
        <div class="article-byline">
          <span>Por <a href="/spanish/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-03</time>
          <span class="dot">·</span>
          <span>4 min de lectura</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>En esta pagina</h4>
            <ul>
              <li><a href="#prices">Los tres precios</a></li>
              <li><a href="#when">Cuando aplica cada uno</a></li>
              <li><a href="#tips">7 acciones faciles</a></li>
              <li><a href="#ulo">Tarifa ULO</a></li>
              <li><a href="#savings">Ahorro real</a></li>
              <li><a href="#read-full">Leer la guia completa en ingles →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Sistema</span><span class="qf-val">Time-of-Use (TOU) en Ontario</span></div>
              <div class="qf-row"><span class="qf-label">Precios</span><span class="qf-val">3 (Off-peak, Mid-peak, On-peak)</span></div>
              <div class="qf-row"><span class="qf-label">Mas barato</span><span class="qf-val">Off-peak — noche y fines de semana</span></div>
              <div class="qf-row"><span class="qf-label">Mas caro</span><span class="qf-val">On-peak — manana y tarde entre semana</span></div>
              <div class="qf-row"><span class="qf-label">Alternativa</span><span class="qf-val">ULO — aun mas barato de noche</span></div>
            </div>


            <h2 id="prices">Los tres precios</h2>
            <p><strong>Off-peak</strong>: el mas barato, en general de 19:00 a 7:00 entre semana y todo el fin de semana. <strong>Mid-peak</strong>: mitad del dia entre semana. <strong>On-peak</strong>: manana (aprox. 7-11) y tarde (aprox. 17-19) entre semana.</p>

            <h2 id="when">Cuando aplica cada uno</h2>
            <p>Los horarios cambian ligeramente segun estacion, pero la logica es la misma: <strong>electrodomesticos que consumen mucho</strong> (lavavajillas, secadora, lavadora) en off-peak — se ahorra sin cambiar nada mas.</p>

            <h2 id="tips">7 acciones faciles</h2>
            <p>1) Programar el lavavajillas despues de las 19:00. 2) Lavado y secado en fin de semana. 3) Cargar auto electrico de noche. 4) Cocinar en tandas el domingo. 5) Termostato programable. 6) Desenchufar aparatos que no se usan. 7) Revisar fugas de aire en ventanas.</p>

            <h2 id="ulo">Tarifa ULO</h2>
            <p><strong>Ultra-Low Overnight (ULO)</strong> ofrece un precio aun mas bajo de noche (23:00-7:00) — ideal para duenos de vehiculo electrico o hogares con bomba de calor.</p>

            <h2 id="savings">Ahorro real</h2>
            <p>Un hogar promedio puede ahorrar <strong>10-20 %</strong> solo moviendo el uso de aparatos grandes al horario off-peak — sin sacrificar comodidad.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version larga de esta guia (cifras, casos especiales, procedimiento) esta en ingles:</p>
              <a class="btn-primary" href={enUrl}>Leer la guia completa en ingles →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
