---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/SpanishTopBar.astro';
import Header from '../../../components/SpanishHeader.astro';
import Footer from '../../../components/SpanishFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-03';
const articleTitle = 'Bill 60 (Ontario): lo que inquilinos y arrendadores DEBEN saber';
const articleDescription = 'Guia en lenguaje claro del Bill 60 de Ontario: cinco cambios en las reglas de alquiler, comparacion antes/despues, y que hacer segun sea inquilino o arrendador.';
const articleUrl = 'https://www.realtorpeterlaw.com/spanish/blog/bill-60-ontario';
const enUrl = 'https://www.realtorpeterlaw.com/blog/bill-60-ontario';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/spanish/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Bienes Raices en Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'es',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'Bill 60 Ontario, cambios alquiler Ontario 2025, RTA Ontario, desalojo Ontario, reposesion uso personal Ontario, derechos inquilino arrendador Ontario',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/bill-60-ontario/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/bill-60-ontario/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/bill-60-ontario/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/bill-60-ontario/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/bill-60-ontario/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/bill-60-ontario/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/bill-60-ontario/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Bienes Raices en Toronto`}
  description={articleDescription}
  lang="es"
  bodyClass="es guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/spanish/blog" class="back-link">Blog</a> · Inquilinos y arrendadores</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Ontario aprobo a fines de 2025 el Bill 60. Cambia las reglas de alquiler. La mayoria de los cambios favorecen a los arrendadores; los inquilinos tienen menos tiempo y menos poder. Aqui lo que cambio, en palabras claras.</p>
        <div class="article-byline">
          <span>Por <a href="/spanish/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-03</time>
          <span class="dot">·</span>
          <span>5 min de lectura</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>En esta pagina</h4>
            <ul>
              <li><a href="#what">Que cambia</a></li>
              <li><a href="#changes">Cinco cambios clave</a></li>
              <li><a href="#tenants">Si es inquilino</a></li>
              <li><a href="#landlords">Si es arrendador</a></li>
              <li><a href="#action">Que hacer ahora</a></li>
              <li><a href="#read-full">Leer la guia completa en ingles →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Ley</span><span class="qf-val">Bill 60 Ontario</span></div>
              <div class="qf-row"><span class="qf-label">Vigencia</span><span class="qf-val">Fines de 2025</span></div>
              <div class="qf-row"><span class="qf-label">Alcance</span><span class="qf-val">Regimen de alquiler residencial (RTA)</span></div>
              <div class="qf-row"><span class="qf-label">Efecto general</span><span class="qf-val">Refuerza posicion del arrendador</span></div>
              <div class="qf-row"><span class="qf-label">Cinco cambios</span><span class="qf-val">Plazos mas cortos + tramite mas agil</span></div>
            </div>


            <h2 id="what">Que cambia</h2>
            <p>El Bill 60 modifica varios <strong>plazos y procedimientos</strong> de la Residential Tenancies Act (RTA). <strong>Acorta</strong> plazos para inquilinos y <strong>agiliza</strong> ciertos tramites para arrendadores — especialmente en la reposesion para uso personal y desalojo por falta de pago.</p>

            <h2 id="changes">Cinco cambios clave</h2>
            <p>Plazos de impugnacion mas cortos para inquilinos; tramite mas agil para retomar por uso personal; sanciones aumentadas para reposesion de mala fe; reglas mas claras sobre subidas por encima del limite legal; y calendario revisado de audiencias del LTB.</p>

            <h2 id="tenants">Si es inquilino</h2>
            <p>Anote cada fecha. Nunca deje sin respuesta un aviso N-form. Una reposesion por uso personal debe ser <strong>de buena fe</strong>; si no, puede reclamar danos. Consulte una clinica juridica comunitaria si recibe un N12 o N13.</p>

            <h2 id="landlords">Si es arrendador</h2>
            <p>El tramite es mas rapido, pero las <strong>sanciones por reposesion de mala fe subieron</strong>. Documente rigurosamente cualquier reposesion para uso personal y verifique que el proximo ocupante sea realmente un familiar y viva ahi al menos un ano.</p>

            <h2 id="action">Que hacer ahora</h2>
            <p>Inquilinos: conserve contrato, recibos y avisos, y siga cada etapa. Arrendadores: actualice plantillas de aviso, informe al administrador y respete las nuevas reglas al pie de la letra.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version larga de esta guia (cifras, casos especiales, procedimiento) esta en ingles:</p>
              <a class="btn-primary" href={enUrl}>Leer la guia completa en ingles →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
