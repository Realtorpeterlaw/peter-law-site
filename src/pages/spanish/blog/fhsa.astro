---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/SpanishTopBar.astro';
import Header from '../../../components/SpanishHeader.astro';
import Footer from '../../../components/SpanishFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-09';
const articleTitle = 'Cuenta de Ahorro para Primera Vivienda (FHSA)';
const articleDescription = 'Guia clara del FHSA de Canada: aportes deducibles (como RRSP) y retiros libres de impuestos (como TFSA). $8,000/ano, $40,000 de por vida, y como combinarlo con el HBP.';
const articleUrl = 'https://www.realtorpeterlaw.com/spanish/blog/fhsa';
const enUrl = 'https://www.realtorpeterlaw.com/blog/fhsa';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/spanish/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Bienes Raices en Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'es',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'FHSA Canada, cuenta primer comprador, ahorro primer comprador Canada, HBP FHSA combinar, enganche primera vivienda Canada',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/fhsa/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/fhsa/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/fhsa/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/fhsa/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/fhsa/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/fhsa/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/fhsa/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Bienes Raices en Toronto`}
  description={articleDescription}
  lang="es"
  bodyClass="es guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/spanish/blog" class="back-link">Blog</a> · Primeros compradores</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">El FHSA es la mejor herramienta de ahorro que jamas han tenido los primeros compradores en Canada. Deducible al entrar, libre de impuestos al salir. Aqui como funciona, quien califica, y como combinarlo con el HBP para el mayor enganche posible.</p>
        <div class="article-byline">
          <span>Por <a href="/spanish/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-09</time>
          <span class="dot">·</span>
          <span>5 min de lectura</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>En esta pagina</h4>
            <ul>
              <li><a href="#what">Que es</a></li>
              <li><a href="#who">Quien califica</a></li>
              <li><a href="#limits">Limites</a></li>
              <li><a href="#stack">Combinar con HBP</a></li>
              <li><a href="#watch">Cuidados</a></li>
              <li><a href="#read-full">Leer la guia completa en ingles →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Aporte anual</span><span class="qf-val">$8,000</span></div>
              <div class="qf-row"><span class="qf-label">Tope de por vida</span><span class="qf-val">$40,000</span></div>
              <div class="qf-row"><span class="qf-label">Entrada</span><span class="qf-val">Deducible (como RRSP)</span></div>
              <div class="qf-row"><span class="qf-label">Salida</span><span class="qf-val">Libre de impuestos (como TFSA)</span></div>
              <div class="qf-row"><span class="qf-label">Combinable</span><span class="qf-val">Con el HBP — hasta ~$60,000 sumados</span></div>
            </div>


            <h2 id="what">Que es</h2>
            <p>El FHSA es una <strong>cuenta registrada federal</strong> exclusiva para primeros compradores. Combina <strong>lo mejor del RRSP y del TFSA</strong>: aportes deducibles al entrar y retiros totalmente libres de impuestos al salir — siempre que compre una residencia principal calificada.</p>

            <h2 id="who">Quien califica</h2>
            <p>Debe ser <strong>residente canadiense</strong>, entre 18 y 71 anos, y ni usted ni su conyuge deben haber sido dueno de una residencia principal en los <strong>ultimos 4 anos</strong>.</p>

            <h2 id="limits">Limites</h2>
            <p><strong>$8,000 al ano</strong>, tope de por vida <strong>$40,000</strong>. Los cupos no usados se arrastran (hasta un ano de arrastre). La cuenta puede permanecer abierta hasta 15 anos.</p>

            <h2 id="stack">Combinar con HBP</h2>
            <p>FHSA y HBP se pueden usar <strong>a la vez</strong>. Maximo aproximado por comprador: $60,000; por pareja: $120,000. Es la base para el enganche mas grande posible.</p>

            <h2 id="watch">Cuidados</h2>
            <p>Si el dinero no se usa para una compra, puede transferirse <strong>libre de impuestos</strong> a un RRSP o RRIF; retirarlo directamente lo vuelve gravado. Abra la cuenta pronto para empezar a acumular cupo.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version larga de esta guia (cifras, casos especiales, procedimiento) esta en ingles:</p>
              <a class="btn-primary" href={enUrl}>Leer la guia completa en ingles →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
