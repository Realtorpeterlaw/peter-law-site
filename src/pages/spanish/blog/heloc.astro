---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/SpanishTopBar.astro';
import Header from '../../../components/SpanishHeader.astro';
import Footer from '../../../components/SpanishFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-07';
const articleTitle = 'HELOC (linea de credito sobre la vivienda) — Canada';
const articleDescription = 'Guia clara del HELOC en Canada: como funciona, quien califica, cuanto puede pedir prestado (regla 65 %/80 %), tasas reales, y comparacion con hipoteca inversa y refinanciamiento.';
const articleUrl = 'https://www.realtorpeterlaw.com/spanish/blog/heloc';
const enUrl = 'https://www.realtorpeterlaw.com/blog/heloc';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/spanish/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Bienes Raices en Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'es',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'HELOC Canada, linea credito hipotecaria, regla 65 80 por ciento, capital vivienda, refinanciamiento vs HELOC, Toronto HELOC',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/heloc/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/heloc/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/heloc/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/heloc/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/heloc/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/heloc/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/heloc/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Bienes Raices en Toronto`}
  description={articleDescription}
  lang="es"
  bodyClass="es guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/spanish/blog" class="back-link">Blog</a> · Financiamiento para propietarios</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Guia en lenguaje claro del HELOC en Canada: como funciona, quien califica, cuanto cuesta en realidad, y como decidir si es la forma correcta de aprovechar el valor de tu vivienda.</p>
        <div class="article-byline">
          <span>Por <a href="/spanish/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-07</time>
          <span class="dot">·</span>
          <span>5 min de lectura</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>En esta pagina</h4>
            <ul>
              <li><a href="#what">Que es</a></li>
              <li><a href="#limits">Cuanto puedes pedir</a></li>
              <li><a href="#who">Quien califica</a></li>
              <li><a href="#cost">Costo real</a></li>
              <li><a href="#vs">HELOC vs otras opciones</a></li>
              <li><a href="#read-full">Leer la guia completa en ingles →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Tipo</span><span class="qf-val">Linea de credito rotatoria con garantia hipotecaria</span></div>
              <div class="qf-row"><span class="qf-label">Limite HELOC solo</span><span class="qf-val">Hasta 65 % del valor tasado</span></div>
              <div class="qf-row"><span class="qf-label">Limite combinado (HELOC + hipoteca)</span><span class="qf-val">Hasta 80 %</span></div>
              <div class="qf-row"><span class="qf-label">Interes</span><span class="qf-val">Variable, basado en tasa prima</span></div>
              <div class="qf-row"><span class="qf-label">Pago</span><span class="qf-val">Solo intereses posible, capital flexible</span></div>
            </div>


            <h2 id="what">Que es</h2>
            <p>Un HELOC es una <strong>linea de credito rotatoria garantizada</strong> por el capital acumulado de tu casa. Retiras lo que necesitas, cuando lo necesitas, hasta el limite aprobado. La tasa suele ser <strong>variable</strong> y sigue la tasa prima del banco.</p>

            <h2 id="limits">Cuanto puedes pedir</h2>
            <p>Regla estandar: HELOC solo, hasta el <strong>65 % del valor tasado</strong>. HELOC + hipoteca combinados, hasta el <strong>80 %</strong> del valor.</p>

            <h2 id="who">Quien califica</h2>
            <p>Necesitas ingreso estable, buen historial de credito y suficiente capital acumulado. El banco pide <strong>tasacion oficial</strong> y aplica el <strong>stress test</strong> igual que para una hipoteca.</p>

            <h2 id="cost">Costo real</h2>
            <p>Tasa variable — atento a subidas. Muchos pagan solo intereses y dejan el capital, lo que sale caro a largo plazo. Revisa comisiones de apertura, cuotas anuales y penalizaciones al cerrar.</p>

            <h2 id="vs">HELOC vs otras opciones</h2>
            <p><strong>HELOC</strong>: flexibilidad maxima, tasa variable, ideal para remodelacion por etapas. <strong>Refinanciamiento</strong>: tasa fija posible, mejor si necesitas todo de golpe. <strong>Hipoteca inversa</strong>: solo 55+, sin pagos mensuales obligatorios.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version larga de esta guia (cifras, casos especiales, procedimiento) esta en ingles:</p>
              <a class="btn-primary" href={enUrl}>Leer la guia completa en ingles →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
