---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/SpanishTopBar.astro';
import Header from '../../../components/SpanishHeader.astro';
import Footer from '../../../components/SpanishFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-09';
const articleTitle = 'OESP — reduzca casi a la mitad su factura de luz';
const articleDescription = 'Guia clara del Ontario Electricity Support Program (OESP): quien califica, los montos mensuales ($35-$113), y como combinar con LEAP y OER para que un hogar pequeno reduzca la factura casi a la mitad.';
const articleUrl = 'https://www.realtorpeterlaw.com/spanish/blog/oesp';
const enUrl = 'https://www.realtorpeterlaw.com/blog/oesp';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/spanish/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Bienes Raices en Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'es',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'OESP Ontario, ayuda electricidad Ontario, credito factura luz Ontario, LEAP Ontario, OER Ontario rebate electricidad',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/oesp/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/oesp/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/oesp/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/oesp/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/oesp/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/oesp/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/oesp/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Bienes Raices en Toronto`}
  description={articleDescription}
  lang="es"
  bodyClass="es guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/spanish/blog" class="back-link">Blog</a> · Ayuda factura de luz</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">OESP es probablemente el programa de alivio de facturas mas subutilizado en Ontario. Los hogares elegibles reciben un credito mensual directo de <strong>$35 a $113</strong> en su factura de electricidad — para muchos hogares pequenos es casi la mitad del monto.</p>
        <div class="article-byline">
          <span>Por <a href="/spanish/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-09</time>
          <span class="dot">·</span>
          <span>4 min de lectura</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>En esta pagina</h4>
            <ul>
              <li><a href="#what">Que es</a></li>
              <li><a href="#who">Quien califica</a></li>
              <li><a href="#amount">Monto del credito</a></li>
              <li><a href="#stack">Combinar con otras ayudas</a></li>
              <li><a href="#apply">Como solicitar</a></li>
              <li><a href="#read-full">Leer la guia completa en ingles →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Programa</span><span class="qf-val">OESP — Ontario Electricity Support Program</span></div>
              <div class="qf-row"><span class="qf-label">Tipo de ayuda</span><span class="qf-val">Credito mensual directo en la factura</span></div>
              <div class="qf-row"><span class="qf-label">Monto</span><span class="qf-val">$35 a $113 mensuales</span></div>
              <div class="qf-row"><span class="qf-label">Elegibilidad</span><span class="qf-val">Ingreso del hogar + tamano del hogar</span></div>
              <div class="qf-row"><span class="qf-label">Combinable</span><span class="qf-val">Con LEAP + Ontario Electricity Rebate (OER)</span></div>
            </div>


            <h2 id="what">Que es</h2>
            <p>OESP es un <strong>credito mensual</strong> aplicado automaticamente en su factura de electricidad. No hay que devolverlo. Lo financia la provincia y se mantiene mientras cumpla las condiciones.</p>

            <h2 id="who">Quien califica</h2>
            <p>La elegibilidad depende del <strong>ingreso del hogar</strong> y del <strong>tamano del hogar</strong>. Hogares mas grandes o de menor ingreso reciben mayor credito. La solicitud se hace en ontarioelectricitysupport.ca.</p>

            <h2 id="amount">Monto del credito</h2>
            <p>Desde <strong>$35 al mes</strong> (nivel basico) hasta <strong>$113 al mes</strong> para familias grandes u hogares con calefaccion electrica.</p>

            <h2 id="stack">Combinar con otras ayudas</h2>
            <p>OESP se suma con <strong>LEAP</strong> (ayuda de emergencia puntual para atrasos) y con <strong>OER</strong> (Ontario Electricity Rebate), que ya reduce la factura varios puntos porcentuales. Combinando las tres, un hogar pequeno puede ver su factura casi a la mitad.</p>

            <h2 id="apply">Como solicitar</h2>
            <p>Formulario en linea + comprobante de ingresos (T4, Notice of Assessment). Aprobado, el credito aparece automatico en las siguientes facturas. Hay que renovar periodicamente.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version larga de esta guia (cifras, casos especiales, procedimiento) esta en ingles:</p>
              <a class="btn-primary" href={enUrl}>Leer la guia completa en ingles →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
