---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TopBar from '../../../components/SpanishTopBar.astro';
import Header from '../../../components/SpanishHeader.astro';
import Footer from '../../../components/SpanishFooter.astro';

export const prerender = true;

const publishedDate = '2026-06-03';
const articleTitle = 'Hipoteca inversa (Reverse Mortgage) — Canada';
const articleDescription = 'Guia clara de la hipoteca inversa en Canada: como funciona, quien califica (55+), cuanto puede pedir, tasas, cargos, y los verdaderos compromisos antes de firmar. Edicion propietarios de Toronto.';
const articleUrl = 'https://www.realtorpeterlaw.com/spanish/blog/reverse-mortgage';
const enUrl = 'https://www.realtorpeterlaw.com/blog/reverse-mortgage';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: articleTitle,
  description: articleDescription,
  author: { '@type': 'Person', name: 'Peter Law', url: 'https://www.realtorpeterlaw.com/spanish/about' },
  publisher: { '@type': 'Organization', name: 'Peter Law — Bienes Raices en Toronto', logo: { '@type': 'ImageObject', url: 'https://www.realtorpeterlaw.com/favicon.svg' } },
  inLanguage: 'es',
  datePublished: publishedDate,
  dateModified: publishedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  keywords: 'hipoteca inversa Canada, 55 anos propietario, valor vivienda retiro, hipoteca jubilados Canada, costo hipoteca inversa',
  translationOfWork: { '@type': 'Article', '@id': enUrl },
};

const hreflangAlternates = [
    { hreflang: "en-CA", href: "https://www.realtorpeterlaw.com/blog/reverse-mortgage/" },
    { hreflang: "zh-CN", href: "https://www.realtorpeterlaw.com/chinese/blog/reverse-mortgage/" },
    { hreflang: "fr-CA", href: "https://www.realtorpeterlaw.com/french/blog/reverse-mortgage/" },
    { hreflang: "ko",    href: "https://www.realtorpeterlaw.com/korean/blog/reverse-mortgage/" },
    { hreflang: "ru",    href: "https://www.realtorpeterlaw.com/russian/blog/reverse-mortgage/" },
    { hreflang: "es",    href: "https://www.realtorpeterlaw.com/spanish/blog/reverse-mortgage/" },
    { hreflang: "x-default", href: "https://www.realtorpeterlaw.com/blog/reverse-mortgage/" },
  ];
---
<BaseLayout
  title={`${articleTitle} | Peter Law — Bienes Raices en Toronto`}
  description={articleDescription}
  lang="es"
  bodyClass="es guide-page article-page"
  hreflangAlternates={hreflangAlternates}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <TopBar />
  <Header active="blog" />

  <article>
    <section class="page-hero">
      <div class="wrap">
        <div class="eyebrow"><a href="/spanish/blog" class="back-link">Blog</a> · Propietarios 55+</div>
        <h1>{articleTitle}</h1>
        <p class="article-lead">Analisis en lenguaje claro para propietarios canadienses de 55 anos o mas: como funciona realmente la hipoteca inversa, cuanto cuesta, y los compromisos que el banco no siempre detalla antes de firmar.</p>
        <div class="article-byline">
          <span>Por <a href="/spanish/about">Peter Law</a></span>
          <span class="dot">·</span>
          <time datetime={publishedDate}>2026-06-03</time>
          <span class="dot">·</span>
          <span>5 min de lectura</span>
        </div>
      </div>
    </section>

    <section class="major" style="padding-top:32px;">
      <div class="wrap">
        <div class="prose-grid">
          <aside class="prose-side">
            <h4>En esta pagina</h4>
            <ul>
              <li><a href="#what">Que es</a></li>
              <li><a href="#who">Quien califica</a></li>
              <li><a href="#how-much">Cuanto puede pedir</a></li>
              <li><a href="#cost">Costo real</a></li>
              <li><a href="#tradeoff">Compromisos reales</a></li>
              <li><a href="#read-full">Leer la guia completa en ingles →</a></li>
            </ul>
          </aside>

          <div class="prose-body">
            <div class="qf-card">
              <div class="qf-row"><span class="qf-label">Edad minima</span><span class="qf-val">55 anos (todos los propietarios inscritos)</span></div>
              <div class="qf-row"><span class="qf-label">Tipo de vivienda</span><span class="qf-val">Residencia principal</span></div>
              <div class="qf-row"><span class="qf-label">Prestamo maximo</span><span class="qf-val">Usualmente 55 % del valor</span></div>
              <div class="qf-row"><span class="qf-label">Pago mensual</span><span class="qf-val">Ninguno mientras viva alli</span></div>
              <div class="qf-row"><span class="qf-label">Interes</span><span class="qf-val">Fijo o variable, mayor que una hipoteca estandar</span></div>
            </div>


            <h2 id="what">Que es</h2>
            <p>La hipoteca inversa permite, con 55 anos o mas, pedir prestado contra el valor de tu casa <strong>sin pagos mensuales obligatorios</strong>. Los intereses se acumulan sobre el saldo y el prestamo se paga al vender, mudarse o fallecer.</p>

            <h2 id="who">Quien califica</h2>
            <p>Usted y <strong>todos los propietarios inscritos</strong> deben tener <strong>55 anos o mas</strong>. La casa debe ser su <strong>residencia principal</strong>. No hay verificacion de ingresos ni credito — accesible para muchos jubilados.</p>

            <h2 id="how-much">Cuanto puede pedir</h2>
            <p>Generalmente hasta el <strong>55 % del valor tasado</strong>, segun edad y tipo de propiedad. <strong>A mayor edad</strong>, mayor monto (porque el plazo esperado del prestamo es mas corto).</p>

            <h2 id="cost">Costo real</h2>
            <p>La tasa es <strong>mas alta que una hipoteca estandar</strong> y los intereses se acumulan. En 15-20 anos puede consumir gran parte del patrimonio. Sumar tasacion, honorarios legales y apertura.</p>

            <h2 id="tradeoff">Compromisos reales</h2>
            <p>+ Sin pagos mensuales, dinero libre de impuestos, permanece en su casa. − Reduce mucho la herencia, mas cara que un HELOC, penalizaciones fuertes por cierre anticipado. Consulte siempre a un <strong>asesor independiente</strong> antes de firmar.</p>

            <div id="read-full" class="read-full-cta">
              <p>La version larga de esta guia (cifras, casos especiales, procedimiento) esta en ingles:</p>
              <a class="btn-primary" href={enUrl}>Leer la guia completa en ingles →</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />
</BaseLayout>

<style>
  .qf-card { background: #fff; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; padding: 18px 20px; margin: 0 0 28px; display: grid; gap: 10px; }
  .qf-row { display: grid; grid-template-columns: 42% 1fr; gap: 14px; align-items: baseline; padding-bottom: 8px; border-bottom: 1px dashed #eee; }
  .qf-row:last-child { border-bottom: 0; padding-bottom: 0; }
  .qf-label { color: #666; font-size: 0.9rem; }
  .qf-val { color: #1a1a1a; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta { margin-top: 36px; padding: 22px; background: #f8f5ef; border: 1px solid var(--line, #e6e2dc); border-radius: 14px; text-align: center; }
  .read-full-cta p { margin: 0 0 12px; color: #333; }
  .read-full-cta .btn-primary { display: inline-block; background: #b8845b; color: #fff; padding: 12px 24px; border-radius: 999px; text-decoration: none; font-weight: 600; font-size: 0.95rem; }
  .read-full-cta .btn-primary:hover { background: #a06d47; }
</style>
