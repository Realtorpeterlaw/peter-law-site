---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpanishTopBar from '../../components/SpanishTopBar.astro';
import SpanishHeader from '../../components/SpanishHeader.astro';
import SpanishFooter from '../../components/SpanishFooter.astro';
import SpanishCTASection from '../../components/SpanishCTASection.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="Sobre Peter Law — Inmobiliaria Toronto" description="Peter Law: nacido y criado en el centro de Toronto. Ex-anfitrión de Airbnb. Representante de Ventas en HomeLife Golconda Realty Inc." lang="es" bodyClass="es">

  <SpanishTopBar />
  <SpanishHeader active="about" ctaLabel="Reservar llamada" />

  <section class="hero"><div class="wrap hero-grid">
    <div>
      <div class="eyebrow">Sobre Peter</div>
      <h1 class="hero-h">Nacido y criado, <em>Torontino.</em></h1>
      <p class="hero-sub">Torontino del centro, ex-anfitrión de Airbnb, agente inmobiliario a tiempo completo — te acompaño del punto A al punto B, hasta la línea de meta.</p>
      <div class="hero-ctas"><a href={BOOKING_URL} class="btn-primary">Hablemos<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a></div>
    </div>
    <div><div class="hero-photo"><img src="/photos/peter-interior.webp" alt="Peter Law, retrato en blanco y negro en el centro de Toronto." width="1500" height="1887" loading="eager" /></div></div>
  </div></section>

  <section class="major" style="padding-top:32px;"><div class="wrap"><div class="prose-grid">
    <aside class="prose-side"><h4>Acerca</h4><ul><li><a href="#story">Mi historia</a></li><li><a href="#credentials">Credenciales</a></li><li><a href="#brokerage">Mi corretaje</a></li></ul></aside>
    <div class="prose-body">
      <h2 id="story">Mi historia</h2>
      <p>Nacido y criado en el centro de Toronto. Chino nacido en Canadá. Seis (6) años, a TIEMPO COMPLETO en el mercado de alquiler de Toronto. Empecé alojando en Airbnb, obtuve mi licencia inmobiliaria y construí una práctica que cubre alquileres y ventas. El trabajo de hospitalidad me enseñó algo simple: <strong>la gente no recuerda la foto del anuncio. Recuerda si se sintió cuidada.</strong></p>
      <h2 id="credentials">Credenciales</h2>
      <p>Sales Representative registrado en el <strong>Real Estate Council of Ontario (RECO)</strong>. Miembro de TRREB, OREA, CREA. Bilingüe (inglés / chino).</p>
      <h2 id="brokerage">Mi corretaje</h2>
      <p><strong>HomeLife Golconda Realty Inc., Brokerage</strong> — 215 – 3601 HWY 7 East, Markham, ON L3R 0M3.</p>
    </div>
  </div></div></section>

  <SpanishCTASection />
  <SpanishFooter />
</BaseLayout>
