---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/SpanishTopBar.astro';
import LHeader from '../../components/SpanishHeader.astro';
import LFooter from '../../components/SpanishFooter.astro';
import LCTA from '../../components/SpanishCTASection.astro';
export const prerender = true;
---
<BaseLayout title="Calculadora de COMPRA \u2014 hipoteca, LTT, CMHC, costos de cierre | Peter Law" description="Una p\u00e1gina. Ingresa tus ingresos, el precio de la casa y tu ahorro. Ve tu pago mensual, impuestos de transferencia, seguro hipotecario, costos de cierre." lang="es" bodyClass="es">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Calculadora de COMPRA</div><h1>Generador de cálculos simple y fácil</h1><p>Contacta a PETER para más información sobre COMPRA y FINANCIAMIENTO. Puede recomendarse un corredor hipotecario.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="ac-shell">
    <div class="ac-inputs">
      <div class="ac-input-group"><label>1. ¿Cuánto ganas al año? <span class="hint">Antes de impuestos.</span></label><div class="input-prefix"><input type="number" id="ac-income" value="250000" min="0" step="1000" /></div></div>
      <div class="ac-input-group"><label>2. Precio de compra ACEPTADO <span class="hint">Condominio, casa adosada o casa.</span></label><div class="input-prefix"><input type="number" id="ac-price" value="1000000" min="0" step="5000" /></div></div>
      <div class="ac-input-group"><label>3. Enganche <span class="hint">Idealmente 20-25% del precio de compra.</span></label><div class="input-prefix"><input type="number" id="ac-savings" value="100000" min="0" step="1000" /></div></div>
      <div class="ac-input-group ac-checkbox-group"><label class="ac-checkbox"><input type="checkbox" id="ac-fthb" checked /><span class="ac-checkbox-text">Soy comprador primerizo <span class="hint">Obtiene un reembolso de impuesto de transferencia.</span></span></label></div>
      <div class="ac-input-group"><label>4. Tipo de propiedad <span class="hint">Determina los costos mensuales aplicables.</span></label><select id="ac-proptype"><option value="freehold" selected>Propiedad libre (Casa)</option><option value="freehold-hoa">Propiedad libre con HOA</option><option value="condo">Condominio</option></select></div>
      <div class="ac-input-group" id="ac-tax-row"><label>5. Impuesto predial <span class="hint">Por mes. Déjalo vacío para auto-estimar al 0.7% del precio/año.</span></label><div class="input-prefix"><input type="number" id="ac-proptax" value="" min="0" step="5" placeholder="e.g. 400" /></div></div>
      <div class="ac-input-group" id="ac-fee-row" style="display:none;"><label id="ac-fee-label">6. Cuota HOA <span class="hint">Por mes. Pregunta antes de firmar — algunos incluyen calefacción, agua o electricidad.</span></label><div class="input-prefix"><input type="number" id="ac-fee" value="" min="0" step="5" placeholder="e.g. 150" /></div></div>
      <details class="ac-more"><summary>Más opciones</summary><div class="ac-more-body">
        <div class="ac-input-group"><label>Tasa hipotecaria <span class="hint">5% es normal en 2026.</span></label><div class="input-suffix"><input type="number" id="ac-rate" value="5.0" min="0" step="0.05" /></div></div>
        <div class="ac-input-group"><label>Amortización</label><select id="ac-amort"><option value="20">20</option><option value="25" selected>25</option><option value="30">30</option></select></div>
        <div class="ac-input-group"><label>¿Dónde está la propiedad?</label><select id="ac-location"><option value="toronto" selected>Ciudad de Toronto</option><option value="ontario">Resto de Ontario</option></select></div>
      </div></details>
    </div>
    <div class="ac-results">
      <div class="ac-headline">
        <div class="ac-headline-item"><div class="ac-headline-label">Tu pago mensual</div><div class="ac-headline-value" id="ac-monthly">$0</div><div class="ac-headline-sub">Solo hipoteca. Ver desglose para costo mensual total.</div></div>
        <div class="ac-headline-item"><div class="ac-headline-label">Efectivo necesario al cierre</div><div class="ac-headline-value" id="ac-cash">$0</div><div class="ac-headline-sub">Enganche + impuestos de transferencia + abogado + ajustes.</div></div>
      </div>
      <div class="ac-verdict" id="ac-verdict"><span class="ac-verdict-dot"></span><div><div class="ac-verdict-title" id="ac-verdict-title">Ingresa tus números arriba.</div><div class="ac-verdict-sub" id="ac-verdict-sub">El banco revisa qué parte de tus ingresos va a vivienda. Menos del 32% es seguro. Más del 39% y el banco probablemente rechaza.</div></div></div>
      <h3 class="ac-section-h">A dónde va el dinero</h3>
      <div class="ac-breakdown">
        <div class="ac-row"><span>Enganche</span><strong id="ac-down">$0</strong></div>
        <div class="ac-row"><span>Hipoteca total</span><strong id="ac-mortgage">$0</strong></div>
        <div class="ac-row"><span>CMHC / seguro predeterminado <em class="ac-note" id="ac-cmhc-note"></em></span><strong id="ac-cmhc">$0</strong></div>
        <div class="ac-row"><span>Impuesto de transferencia Ontario</span><strong id="ac-ltt-on">$0</strong></div>
        <div class="ac-row" id="ac-ltt-mltt-row"><span>Impuesto de transferencia Toronto</span><strong id="ac-ltt-mltt">$0</strong></div>
        <div class="ac-row" id="ac-ltt-rebate-row" style="display:none;"><span>Reembolso primer comprador</span><strong id="ac-ltt-rebate">−$0</strong></div>
        <div class="ac-row" id="ac-mo-taxrow"><span>Impuesto predial mensual estimado</span><strong id="ac-mo-tax">$0</strong></div>
        <div class="ac-row" id="ac-mo-feerow" style="display:none;"><span id="ac-mo-feelbl">Cuota HOA mensual</span><strong id="ac-mo-fee">$0</strong></div>
        <div class="ac-row"><span>Legal + título + ajustes <em class="ac-note">aproximado</em></span><strong id="ac-legal">$0</strong></div>
        <div class="ac-row ac-row-total"><span>Efectivo total aproximado al cierre</span><strong id="ac-total-cash">~$0</strong></div>
      </div>
      <p class="calc-disclaimer">Cifras indicativas. Ver el <a href="/disclaimer#calculators">Aviso legal</a>.</p>
    </div>
  </div></div></section>
  <LCTA heading="\u00bfQuieres que te acompa\u00f1e con n\u00fameros reales?" lead="Trae tus ingresos y el barrio que te interesa. 15 min por tel\u00e9fono y sabr\u00e1s exactamente qu\u00e9 rango de precios te conviene." />
  <LFooter />

  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('en-CA',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function pRate(r,n){const s=r/200;return Math.pow(1+s,2/n)-1;}
      function mPay(p,r,y){if(p<=0||y<=0)return 0;const rr=pRate(r,12),n=y*12;if(rr===0)return p/n;return p*rr/(1-Math.pow(1+rr,-n));}
      function cmhc(l){if(l>95)return null;if(l>90)return .04;if(l>85)return .031;if(l>80)return .028;return 0;}
      function minDp(p){if(p>1500000)return p*.2;if(p<=500000)return p*.05;return 500000*.05+(p-500000)*.1;}
      function ontLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000)t+=(p-2000000)*.025;return t;}
      function torMLTT(p){if(p<=0)return 0;let t=0;const b=[[55000,.005],[250000,.01],[400000,.015],[2000000,.02]];let lo=0;for(const[u,r]of b){if(p>lo){const x=Math.min(p,u)-lo;if(x>0)t+=x*r;}lo=u;}if(p>2000000){const lx=[[3000000,.025],[4000000,.035],[5000000,.045],[10000000,.055],[20000000,.065]];let l=2000000;for(const[u,r]of lx){if(p>l){const x=Math.min(p,u)-l;if(x>0)t+=x*r;}l=u;}if(p>20000000)t+=(p-20000000)*.075;}return t;}
      const FT_ONT=4000,FT_TOR=4475;
      const $=id=>document.getElementById(id);
      ['ac-income','ac-price','ac-savings','ac-rate','ac-amort','ac-location','ac-fthb','ac-proptype','ac-proptax','ac-fee'].forEach(id=>{const el=$(id);if(!el)return;el.addEventListener('input',calc);el.addEventListener('change',calc);});
      function calc(){
        const inc=Math.max(0,parseFloat($('ac-income').value)||0);const p=Math.max(0,parseFloat($('ac-price').value)||0);
        const s=Math.max(0,parseFloat($('ac-savings').value)||0);const r=Math.max(0,parseFloat($('ac-rate').value)||0);
        const am=parseInt($('ac-amort').value,10)||25;const loc=$('ac-location').value;const fthb=$('ac-fthb').checked;
        const pt=$('ac-proptype').value;const ptx=parseFloat($('ac-proptax').value);const fee=parseFloat($('ac-fee').value);
        const fr=$('ac-fee-row'),fl=$('ac-fee-label');
        if(pt==='freehold')fr.style.display='none';
        else if(pt==='freehold-hoa'){fr.style.display='';fl.innerHTML="6. Cuota HOA"+' <span class="hint">'+"Por mes. Pregunta antes de firmar \u2014 algunos incluyen calefacci\u00f3n, agua o electricidad."+'</span>';}
        else{fr.style.display='';fl.innerHTML="6. Cuota de mantenimiento"+' <span class="hint">'+"Por mes. Pregunta antes de firmar \u2014 algunos incluyen calefacci\u00f3n, agua o electricidad."+'</span>';}
        const mDp=minDp(p),ds=Math.min(s,p),sh=Math.max(0,mDp-ds),ad=ds;
        const ltv=p>0?(p-ad)/p*100:0,pr=cmhc(ltv);const bl=Math.max(0,p-ad);
        const cp=(pr!==null&&pr>0)?bl*pr:0;const tm=bl+cp,m=mPay(tm,r,am);
        const ot=ontLTT(p),mt=loc==='toronto'?torMLTT(p):0;
        let re=0;if(fthb){re=Math.min(ot,FT_ONT);if(loc==='toronto')re+=Math.min(mt,FT_TOR);}
        const tl=Math.max(0,ot+mt-re),le=2500,ctc=ad+tl+le;
        const sr=Math.max(r+2,5.25),sp=mPay(tm,sr,am);
        const mi=inc/12,ptm=(isFinite(ptx)&&ptx>=0)?ptx:(p*.007/12);
        const of=(isFinite(fee)&&fee>=0&&pt!=='freehold')?fee:0;
        const hm=pt==='condo'?0:150;const gds=mi>0?(sp+ptm+of+hm)/mi*100:0;
        $('ac-monthly').textContent=fmt(m);$('ac-cash').textContent=fmt(ctc);
        $('ac-down').textContent=fmt(ad);$('ac-mortgage').textContent=fmt(tm);$('ac-cmhc').textContent=fmt(cp);
        $('ac-cmhc-note').textContent=pr===null?"(no permitido \u2014 necesitas 5% m\u00e1s)":pr===0?"(enganche 20%+ \u2014 no requiere seguro)":"({pct}% del pr\u00e9stamo)".replace('{pct}',(pr*100).toFixed(2));
        $('ac-ltt-on').textContent=fmt(ot);$('ac-ltt-mltt').textContent=fmt(mt);$('ac-ltt-mltt-row').style.display=loc==='toronto'?'':'none';
        if(re>0){$('ac-ltt-rebate-row').style.display='';$('ac-ltt-rebate').textContent='−'+fmt(re);}else{$('ac-ltt-rebate-row').style.display='none';}
        $('ac-mo-tax').textContent=fmt(ptm)+'/mes';
        const frb=$('ac-mo-feerow');if(pt==='freehold')frb.style.display='none';else{frb.style.display='';$('ac-mo-feelbl').textContent=pt==='condo'?"Cuota de mantenimiento mensual":Cuota HOA mensual;$('ac-mo-fee').textContent=fmt(of)+'/mes';}
        $('ac-legal').textContent=fmt(le);$('ac-total-cash').textContent='~'+fmt(ctc);
        let vt,vs,vc;
        if(inc<=0||p<=0){vt=Ingresa tus números arriba.;vs=El banco revisa qué parte de tus ingresos va a vivienda. Menos del 32% es seguro. Más del 39% y el banco probablemente rechaza.;vc='ac-verdict-neutral';}
        else if(pr===null){vt="Necesitas m\u00e1s ahorros para este precio.";vs="El enganche m\u00ednimo para una casa de 1.5M+ $ es 20%. Est\u00e1s por debajo. Ahorra m\u00e1s o apunta a un precio m\u00e1s bajo.";vc='ac-verdict-red';}
        else if(sh>0){vt="Enganche insuficiente.";vs="Se necesita {mDp}. Faltan {sh}. El banco no puede aprobar.".replace('{mDp}',fmt(mDp)).replace('{sh}',fmt(sh));vc='ac-verdict-red';}
        else if(gds>39){vt="El banco probablemente no aprobar\u00e1.";vs="Al {gds}%, la vivienda consume demasiado. Prueba un precio menor o m\u00e1s enganche.".replace('{gds}',gds.toFixed(1));vc='ac-verdict-red';}
        else if(gds>32){vt="Ajustado. Posible pero lo sentir\u00e1s.";vs="Al {gds}%, est\u00e1s dentro del l\u00edmite estricto del banco (39%) pero sobre la zona c\u00f3moda (32%).".replace('{gds}',gds.toFixed(1));vc='ac-verdict-yellow';}
        else{vt="Puedes permit\u00edrtelo.";vs="Al {gds}%, la vivienda est\u00e1 c\u00f3modamente en la zona segura.".replace('{gds}',gds.toFixed(1));vc='ac-verdict-green';}
        const v=$('ac-verdict');v.classList.remove('ac-verdict-neutral','ac-verdict-green','ac-verdict-yellow','ac-verdict-red');v.classList.add(vc);
        $('ac-verdict-title').textContent=vt;$('ac-verdict-sub').textContent=vs;
      }
      calc();
    })();
  </script>
</BaseLayout>
