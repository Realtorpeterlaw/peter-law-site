---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LangTopBar from '../../components/SpanishTopBar.astro';
import LangHeader from '../../components/SpanishHeader.astro';
import LangFooter from '../../components/SpanishFooter.astro';
import LangCTA from '../../components/SpanishCTASection.astro';
---
<BaseLayout title="Para inquilinos \u2014 Peter Law \u00b7 Alquiler en Toronto" description="\u00bfBuscas alquilar en Toronto? C\u00f3mo te ayudo a ser aprobado r\u00e1pidamente." lang="es" bodyClass="es">
  <LangTopBar />
  <LangHeader active="rental" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Alquiler · Inquilinos</div>
      <h1>Alquiler en Toronto — aprobado rápido, mudanza suave.</h1>
      <p>El mercado de alquiler de Toronto se mueve rápido. Un día de duda y la unidad se fue.</p>
    </div>
  </section>

  <section class="major">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side"><h4>—</h4><ul>
          <li><a href="#search">La búsqueda</a></li>
          <li><a href="#application">La solicitud</a></li>
          <li><a href="#negotiation">La negociación</a></li>
          <li><a href="#moveIn">La mudanza</a></li>
        </ul></aside>
        <div class="prose-body">
          <h2 id="search">La búsqueda</h2>
          <p>Cada día una lista corta según tus criterios reales.</p>
          <h2 id="application">La solicitud</h2>
          <p>Un expediente débil falla. Uno fuerte — carta de empleo, crédito, referencia — pasa.</p>
          <h2 id="negotiation">La negociación</h2>
          <p>En el precio y también en las inclusiones (calefacción, agua, internet).</p>
          <h2 id="moveIn">La mudanza</h2>
          <p>Coordino firma, inspección, transferencia de servicios.</p>
        </div>
      </div>
    </div>
  </section>

  <LangCTA heading="\u00bfListo para empezar tu b\u00fasqueda?" lead="Env\u00eda tus criterios. Respondo en 24 horas con 5-8 unidades." />
  <LangFooter />
</BaseLayout>
