---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/SpanishTopBar.astro';
import LHeader from '../../components/SpanishHeader.astro';
import LFooter from '../../components/SpanishFooter.astro';
import LCTA from '../../components/SpanishCTASection.astro';
---
<BaseLayout title="Calculadora de seguro CMHC | Peter Law" description="Estima tu prima de seguro hipotecario CMHC en segundos. Reglas canadienses: enganche m\u00ednimo, tasas basadas en LTV, tope asegurable de $1.5M." lang="es" bodyClass="es calc-page">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Calculadora CMHC</div><h1>¿Cuánto costará tu seguro hipotecario?</h1><p>Si tu enganche es menor al 20%, pagarás seguro CMHC. La prima se agrega a tu hipoteca.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="calc">
    <div class="calc-fields">
      <div class="calc-field calc-field-full"><label for="cm-price">Precio de compra</label><div class="input-prefix"><input type="number" id="cm-price" value="800000" min="0" step="5000" /></div></div>
      <div class="calc-field"><label for="cm-down">Enganche</label><div class="input-prefix"><input type="number" id="cm-down" value="80000" min="0" step="1000" /></div></div>
      <div class="calc-field"><label for="cm-down-pct">Enganche (%)</label><div class="input-suffix"><input type="number" id="cm-down-pct" value="10" min="0" max="100" step="0.5" /></div></div>
    </div>
    <div class="calc-result">
      <div class="calc-result-main"><span class="label">Prima CMHC</span><span id="cm-premium">$0</span></div>
      <div class="calc-result-breakdown">
        <div class="row"><span>Ratio préstamo/valor (LTV)</span><strong id="cm-ltv">0%</strong></div>
        <div class="row"><span>Saldo hipotecario base</span><strong id="cm-loan">$0</strong></div>
        <div class="row"><span>Hipoteca total (con prima)</span><strong id="cm-total">$0</strong></div>
      </div>
    </div>
    <p class="calc-disclaimer">Solo estimación. Basado en tasas CMHC estándar 2026 para viviendas ocupadas por el propietario bajo $1.5M. Consulta a tu corredor hipotecario.</p>
  </div></div></section>
  <LCTA />
  <LFooter />
  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('es-MX',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function cmhcR(l){if(l>95)return null;if(l>90)return .04;if(l>85)return .031;if(l>80)return .028;return 0;}
      let editing=null;
      function c(){
        const p=parseFloat(document.getElementById('cm-price').value)||0;
        let d=parseFloat(document.getElementById('cm-down').value)||0;
        let pct=parseFloat(document.getElementById('cm-down-pct').value)||0;
        if(editing==='pct'){d=p*pct/100;document.getElementById('cm-down').value=d.toFixed(0);}
        else if(editing==='dollar'){pct=p>0?d/p*100:0;document.getElementById('cm-down-pct').value=pct.toFixed(2);}
        else{pct=p>0?d/p*100:0;document.getElementById('cm-down-pct').value=pct.toFixed(2);}
        const ltv=p>0?(p-d)/p*100:0;
        const bl=Math.max(0,p-d);
        const rate=cmhcR(ltv);
        const premium=(rate!==null&&rate>0)?bl*rate:0;
        document.getElementById('cm-premium').textContent=fmt(premium);
        document.getElementById('cm-ltv').textContent=ltv.toFixed(1)+'%';
        document.getElementById('cm-loan').textContent=fmt(bl);
        document.getElementById('cm-total').textContent=fmt(bl+premium);
      }
      document.getElementById('cm-price').addEventListener('input',()=>{editing='price';c();editing=null;});
      document.getElementById('cm-down').addEventListener('input',()=>{editing='dollar';c();editing=null;});
      document.getElementById('cm-down-pct').addEventListener('input',()=>{editing='pct';c();editing=null;});
      c();
    })();
  </script>
</BaseLayout>
