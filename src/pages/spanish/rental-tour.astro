---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/SpanishTopBar.astro';
import LHeader from '../../components/SpanishHeader.astro';
import LFooter from '../../components/SpanishFooter.astro';
import LCTA from '../../components/SpanishCTASection.astro';
const TIKTOK_PROFILE = "https://www.tiktok.com/@rentwithpeter";
const tours = [
  { id: "7642839542482930964", title: "9 Clegg Rd", tag: "Markham Downtown · 1 bed + den" },
  { id: "7643443700663848212", title: "Liberty Village", tag: "Downtown · utilities included" },
  { id: "7642835431985335573", title: "Danforth · East York", tag: "$2,100/mo · 1 bedroom" },
  { id: "7638804681673690389", title: "Move-in ready condo", tag: "Tranquil setting" },
  { id: "7638803774139829524", title: "2-storey unit", tag: "East & west views" },
  { id: "7638803030602779924", title: "Sizable 1 bed + den", tag: "Unobstructed view" },
  { id: "7641439020634967317", title: "Markham condos", tag: "Boutique-style" },
  { id: "7638802160574106900", title: "Brand-new 1 bed + den", tag: "Never lived in" },
  { id: "7638801525833239828", title: "Waterfront condo", tag: "Lake views" },
  { id: "7638800822398160148", title: "Junior 1BR", tag: "Waterfront · Lakeshore" },
  { id: "7638799683430763797", title: "Yonge & Bloor", tag: "Furnished 2 bed/2 bath · Aug 1" },
  { id: "7635749462324841748", title: "Lake Shore condo", tag: "2 bedroom" },
];
---
<BaseLayout title="Recorridos de alquiler \u2014 Videos de propiedades en Toronto | Peter Law" description="Recorre alquileres del centro de Toronto antes de reservar. Actualizado semanalmente desde el TikTok de Peter." lang="es" bodyClass="es tour-page">
  <LTopBar />
  <LHeader active="rental" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Recorridos de alquiler</div><h1>Conoce cada habitación antes de abrir la puerta.</h1><p>Videos rápidos de alquileres de Toronto que visité este mes. Toca una unidad para preguntar. Nuevos videos añadidos diariamente en <a href={TIKTOK_PROFILE} target="_blank" rel="noopener" style="text-decoration: underline; text-underline-offset: 3px;">@rentwithpeter</a>.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="tour-grid">
    {tours.map((t) => (
      <div class="tour-card">
        <div class="tour-embed">
          <button class="tour-play-btn" type="button" data-video-id={t.id} aria-label={`Reproducir recorrido: ${t.title}`}>
            <span class="tour-play-icon" aria-hidden="true"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M7 5l12 7-12 7V5z" fill="currentColor"/></svg></span>
            <span class="tour-play-hint">Reproducir recorrido</span>
          </button>
        </div>
        <div class="tour-meta">
          <div class="tour-title">{t.title}</div>
          <div class="tour-tag">{t.tag}</div>
          <a href={`/contact?subject=Inquiry%20about%20${encodeURIComponent(t.title)}`} class="tour-cta">Preguntar sobre este<svg width="12" height="12" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    ))}
  </div>
  <div class="tour-bottom">
    <a href={TIKTOK_PROFILE} target="_blank" rel="noopener" class="btn-primary">Ver todos los recorridos en TikTok<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
    <p class="tour-disclosure">Solo con fines de marketing y educativos. Disponibilidad, precios y requisitos pueden cambiar.</p>
  </div>
  </div></section>
  <LCTA heading="\u00bfVes alguna que te guste?" lead="La mayor\u00eda de estas unidades se alquilan en d\u00edas. Dime cu\u00e1l te llam\u00f3 la atenci\u00f3n y verifico disponibilidad." />
  <LFooter />
  <script is:inline>
    document.addEventListener('click', function(e){
      const btn = e.target.closest('.tour-play-btn'); if (!btn) return;
      const wrap = btn.parentElement; const videoId = btn.dataset.videoId;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.tiktok.com/player/v1/${videoId}?autoplay=1`;
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.style.cssText = 'width:100%;height:100%;border:0;';
      wrap.innerHTML = ''; wrap.appendChild(iframe);
    });
  </script>
</BaseLayout>
