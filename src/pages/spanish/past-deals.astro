---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/SpanishTopBar.astro';
import LHeader from '../../components/SpanishHeader.astro';
import LFooter from '../../components/SpanishFooter.astro';
import LCTA from '../../components/SpanishCTASection.astro';
import PropertySales from '../../components/PropertySales.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="Historial de ventas \u2014 Peter Law Inmobiliaria Toronto" description="Un registro de alquileres y ventas recientes cerrados por Peter Law en el Gran Toronto." lang="es" bodyClass="es">
  <LTopBar />
  <LHeader active="about" ctaLabel="Reservar llamada" />

  <section class="hero">
    <div class="wrap hero-grid">
      <div>
        <div class="eyebrow"><a href="/spanish/about" class="back-link"><svg width="11" height="11" viewBox="0 0 14 14" fill="none" style="vertical-align:-1px;margin-right:5px;" aria-hidden="true"><path d="M13 7H1M6 12L1 7l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>Acerca</a> · Historial de ventas</div>
        <h1 class="hero-h">Historial de ventas</h1>
        <p class="sale-history-lead">El historial incluye representación de propietarios, compradores, inquilinos, o en algunos casos, una combinación.</p>
        <p class="sale-history-disc"><em>Los precios, direcciones y roles de representación reflejan la información al momento de cada transacción, obtenida de registros públicos MLS® / TRREB y/o compartida con consentimiento del cliente. Las identidades de clientes son confidenciales. Los resultados pasados no garantizan resultados futuros. Ver <a href='/disclaimer#past-deals'>Aviso legal</a>.</em></p>
      </div>
      <div>
        <div class="hero-photo">
          <img src="/photos/peter-cn-tower.jpg" alt="Peter Law, representante de ventas inmobiliarias de Toronto, con la torre CN atr\u00e1s." width="1500" height="1887" loading="eager" />
        </div>
        <div class="agent-byline">
          <div class="agent-name">Peter Law</div>
          <div class="agent-title">Sales Representative</div>
          <div class="agent-brokerage">Home Life Golconda Realty., Inc Brokerage.</div>
          <div class="agent-phones">
            <div><span class="lbl">DIRECTO:</span> <a href="tel:+16478888472">(647) 888 - 8472</a></div>
            <div><span class="lbl">OFICINA:</span> <a href="tel:+19058888819">(905) 888 - 8819</a></div>
            <div><a href="mailto:Admin@RealtorPeterLaw.com">Admin@RealtorPeterLaw.com</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <PropertySales />

  <LCTA />
  <LFooter />
</BaseLayout>
