---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/SpanishTopBar.astro';
import LHeader from '../../components/SpanishHeader.astro';
import LFooter from '../../components/SpanishFooter.astro';
import LCTA from '../../components/SpanishCTASection.astro';
---
<BaseLayout title="Calculadora de asequibilidad | Peter Law" description="\u00bfCu\u00e1nto puedes permitirte? Calcula el precio m\u00e1ximo de compra seg\u00fan las reglas canadienses (GDS/TDS + prueba de estr\u00e9s)." lang="es" bodyClass="es calc-page">
  <LTopBar />
  <LHeader active="buyers" />
  <section class="page-hero"><div class="wrap"><div class="eyebrow">Calculadora de asequibilidad</div><h1>¿Cuánto puedes permitirte realmente?</h1><p>Estima tu precio máximo de compra usando reglas canadienses — ratios GDS/TDS y prueba de estrés hipotecaria federal.</p></div></section>
  <section class="major" style="padding-top:24px;"><div class="wrap"><div class="calc">
    <div class="calc-fields">
      <div class="calc-field"><label for="af-income">Ingresos anuales del hogar</label><div class="input-prefix"><input type="number" id="af-income" value="120000" min="0" step="1000" /></div></div>
      <div class="calc-field"><label for="af-debt">Pagos mensuales de deuda</label><div class="input-prefix"><input type="number" id="af-debt" value="500" min="0" step="50" /></div></div>
      <div class="calc-field"><label for="af-down">Enganche</label><div class="input-prefix"><input type="number" id="af-down" value="100000" min="0" step="5000" /></div></div>
      <div class="calc-field"><label for="af-rate">Tasa hipotecaria</label><div class="input-suffix"><input type="number" id="af-rate" value="5.0" min="0" step="0.05" /></div></div>
      <div class="calc-field"><label for="af-amort">Amortización (años)</label><input type="number" id="af-amort" value="25" min="5" max="35" /></div>
    </div>
    <div class="calc-result">
      <div class="calc-result-main"><span class="label">Precio máximo</span><span id="af-max">$0</span></div>
      <div class="calc-result-breakdown">
        <div class="row"><span>Basado en GDS 32%</span><strong id="af-gds">$0</strong></div>
        <div class="row"><span>Basado en TDS 40%</span><strong id="af-tds">$0</strong></div>
        <div class="row"><em>El menor de los dos es tu límite</em></div>
      </div>
    </div>
    <p class="calc-disclaimer">Solo estimación. Basado en ratios GDS/TDS estándar y prueba de estrés. Consulta un corredor hipotecario para la aprobación real.</p>
  </div></div></section>
  <LCTA />
  <LFooter />
  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('es-MX',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      function pRate(r,n){const s=r/200;return Math.pow(1+s,2/n)-1;}
      function maxPrincipal(pmt,r,y){const rr=pRate(r,12),n=y*12;if(rr===0)return pmt*n;return pmt*(1-Math.pow(1+rr,-n))/rr;}
      function c(){
        const inc=parseFloat(document.getElementById('af-income').value)||0;
        const debt=parseFloat(document.getElementById('af-debt').value)||0;
        const dn=parseFloat(document.getElementById('af-down').value)||0;
        const r=parseFloat(document.getElementById('af-rate').value)||0;
        const y=parseInt(document.getElementById('af-amort').value,10)||25;
        const sr=Math.max(r+2,5.25);
        // Stress test at higher rate for qualifying
        const mi=inc/12;
        const gdsAvail=mi*.32; const tdsAvail=mi*.40-debt;
        // Assume $250/mo tax + $150/mo heat + $75/mo condo
        const otherHousing=475;
        const gdsPmt=Math.max(0,gdsAvail-otherHousing);
        const tdsPmt=Math.max(0,tdsAvail-otherHousing);
        const gdsMax=maxPrincipal(gdsPmt,sr,y)+dn;
        const tdsMax=maxPrincipal(tdsPmt,sr,y)+dn;
        const maxP=Math.min(gdsMax,tdsMax);
        document.getElementById('af-max').textContent=fmt(maxP);
        document.getElementById('af-gds').textContent=fmt(gdsMax);
        document.getElementById('af-tds').textContent=fmt(tdsMax);
      }
      ['af-income','af-debt','af-down','af-rate','af-amort'].forEach(id=>{const el=document.getElementById(id);el.addEventListener('input',c);el.addEventListener('change',c);});c();
    })();
  </script>
</BaseLayout>
