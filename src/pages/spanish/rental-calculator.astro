---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LTopBar from '../../components/SpanishTopBar.astro';
import LHeader from '../../components/SpanishHeader.astro';
import LFooter from '../../components/SpanishFooter.astro';
import LCTA from '../../components/SpanishCTASection.astro';
export const prerender = true;
---
<BaseLayout title="Calculadora de asequibilidad de alquiler | Peter Law" description="Ingresa tus ingresos y gastos mensuales. Ve al instante si el alquiler est\u00e1 en la zona segura, ajustada o demasiado alta." lang="es" bodyClass="es">
  <LTopBar />
  <LHeader active="rental" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Calculadora de alquiler</div>
      <h1>Asequibilidad del alquiler</h1>
      <p>Ingresa las variables abajo.</p>
    </div>
  </section>

  <section class="major" style="padding-top:24px;">
    <div class="wrap">
      <div class="ac-shell">
        <div class="ac-inputs">
          <div class="ac-input-group"><label>1. ¿Cuánto ganas al mes? <span class="hint">Antes de impuestos.</span></label><div class="input-prefix"><input type="number" id="rc-income" value="6500" min="0" step="100" /></div></div>
          <div class="ac-input-group"><label>2. Costo mensual del alquiler</label><div class="input-prefix"><input type="number" id="rc-rent" value="2200" min="0" step="50" /></div></div>
          <div class="ac-section-h ac-inline-h">Gastos mensuales</div>
          <div class="ac-input-group"><label>3. Internet <span class="hint">Costo aproximado de internet, $55 a $100 por mes.</span></label><div class="input-prefix"><input type="number" id="rc-internet" value="80" min="0" step="5" /></div></div>
          <div class="ac-input-group"><label>4. Seguro de responsabilidad del inquilino <span class="hint">$15 a $30 por mes.</span></label><div class="input-prefix"><input type="number" id="rc-insurance" value="22" min="0" step="1" /></div></div>
          <div class="ac-input-group"><label>5. Servicios públicos <span class="hint">Costo aproximado, $60 a $100 por mes.*</span></label><div class="input-prefix"><input type="number" id="rc-utilities" value="100" min="0" step="5" /></div></div>
          <p class="rc-hint-note">*Cada condominio o apartamento es diferente PERO todas las unidades del edificio comparten el mismo proveedor de servicios públicos.<br /><br />Algunos edificios incluyen calefacción, agua y, en raros casos, internet o todos los servicios públicos. Consulta con tu agente inmobiliario.</p>
        </div>
        <div class="ac-results">
          <div class="rc-meter-card">
            <div class="rc-meter-head"><div class="rc-meter-title">Vivienda como % de tus ingresos</div><div class="rc-meter-pct"><span id="rc-meter-pct">0%</span></div></div>
            <div class="rc-meter-bar" aria-hidden="true"><div class="rc-meter-fill" id="rc-meter-fill" style="width:0%"></div><div class="rc-meter-tick" style="left:30%"><span class="rc-meter-tick-label" style="left:50%;">30%</span></div><div class="rc-meter-tick" style="left:40%"><span class="rc-meter-tick-label" style="left:50%;">40%</span></div></div>
            <div class="rc-meter-tiers"><span class="tier-safe">Zona segura</span><span class="tier-tight">Ajustado</span><span class="tier-over">Demasiado alto</span></div>
          </div>
          <div class="ac-headline">
            <div class="ac-headline-item"><div class="ac-headline-label">Vivienda mensual total</div><div class="ac-headline-value" id="rc-out-total">$0</div><div class="ac-headline-sub">Alquiler + internet + seguro + servicios públicos.</div></div>
            <div class="ac-headline-item"><div class="ac-headline-label">Sobrante después de vivienda</div><div class="ac-headline-value" id="rc-leftover">$0</div><div class="ac-headline-sub">Por mes, para todo lo demás.</div></div>
          </div>
          <div class="rc-verdict" id="rc-verdict"><div class="rc-verdict-icon" id="rc-verdict-icon" aria-hidden="true"></div><div class="rc-verdict-body"><div class="rc-verdict-title" id="rc-verdict-title">Ingresa tus números arriba.</div><div class="rc-verdict-sub" id="rc-verdict-sub">Menos del 30% de los ingresos en vivienda es la zona segura. Entre 30% y 40% es ajustado. Más de 40% y la mayoría de propietarios te rechazará.</div></div></div>
          <h3 class="ac-section-h">A dónde va el dinero</h3>
          <div class="ac-breakdown">
            <div class="ac-row"><span>Alquiler</span><strong id="rc-out-rent">$0</strong></div>
            <div class="ac-row"><span>Internet</span><strong id="rc-out-internet">$0</strong></div>
            <div class="ac-row"><span>Seguro de responsabilidad</span><strong id="rc-out-insurance">$0</strong></div>
            <div class="ac-row"><span>Servicios públicos</span><strong id="rc-out-utilities">$0</strong></div>
            <div class="ac-row ac-row-total"><span>Vivienda mensual total</span><strong id="rc-out-total-2">$0</strong></div>
          </div>
          <p class="calc-disclaimer">Cifras indicativas. La mayoría de propietarios de Toronto usan 30-33% de ingresos brutos mensuales como umbral. Ver el <a href="/disclaimer#calculators">Aviso legal</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <LCTA heading="\u00bfNo est\u00e1s seguro si un anuncio te conviene?" lead="Env\u00edame la direcci\u00f3n y tu ingreso \u2014 te dir\u00e9 honestamente si el propietario aprobar\u00e1 y si el precio es justo." />
  <LFooter />

  <script is:inline>
    (function(){
      function fmt(n){if(!isFinite(n)||isNaN(n))return'$0';return n.toLocaleString('en-CA',{style:'currency',currency:'CAD',maximumFractionDigits:0});}
      const IC='<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg"><circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="4"/><path d="M18 33 L28 43 L46 23" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      const IW='<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg"><circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="4"/><line x1="32" y1="18" x2="32" y2="36" stroke="currentColor" stroke-width="6" stroke-linecap="round"/><circle cx="32" cy="46" r="3.6" fill="currentColor"/></svg>';
      const IX='<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg"><circle cx="32" cy="32" r="30" fill="none" stroke="currentColor" stroke-width="4"/><line x1="20" y1="20" x2="44" y2="44" stroke="currentColor" stroke-width="6" stroke-linecap="round"/><line x1="44" y1="20" x2="20" y2="44" stroke="currentColor" stroke-width="6" stroke-linecap="round"/></svg>';
      const $=id=>document.getElementById(id);
      ['rc-income','rc-rent','rc-internet','rc-insurance','rc-utilities'].forEach(id=>{const el=$(id); if(!el)return; el.addEventListener('input',calc); el.addEventListener('change',calc);});
      function calc(){
        const inc=Math.max(0,parseFloat($('rc-income').value)||0);
        const r=Math.max(0,parseFloat($('rc-rent').value)||0);
        const i=Math.max(0,parseFloat($('rc-internet').value)||0);
        const ins=Math.max(0,parseFloat($('rc-insurance').value)||0);
        const u=Math.max(0,parseFloat($('rc-utilities').value)||0);
        const tot=r+i+ins+u; const pct=inc>0?tot/inc*100:0; const lo=inc-tot;
        const cl=Math.max(0,Math.min(100,pct));
        const f=$('rc-meter-fill'); f.style.width=cl.toFixed(1)+'%'; f.classList.remove('tier-yellow','tier-red');
        if(pct>40)f.classList.add('tier-red'); else if(pct>30)f.classList.add('tier-yellow');
        $('rc-meter-pct').textContent=pct.toFixed(1)+'%';
        $('rc-out-total').textContent=fmt(tot); $('rc-out-total-2').textContent=fmt(tot); $('rc-leftover').textContent=fmt(lo);
        $('rc-out-rent').textContent=fmt(r); $('rc-out-internet').textContent=fmt(i); $('rc-out-insurance').textContent=fmt(ins); $('rc-out-utilities').textContent=fmt(u);
        const v=$('rc-verdict'), ie=$('rc-verdict-icon'); let t,su,cls,ic;
        if(inc<=0||r<=0){t="Ingresa tus n\u00fameros arriba."; su="Menos del 30% de los ingresos en vivienda es la zona segura. Entre 30% y 40% es ajustado. M\u00e1s de 40% y la mayor\u00eda de propietarios te rechazar\u00e1."; cls='rc-verdict-neutral'; ic='';}
        else if(pct<=30){t="S\u00ed \u2014 puedes pagar este alquiler."; su=("Vivienda al {pct}% de tus ingresos \u2014 dentro de la zona segura. Los propietarios aprueban estas solicitudes rutinariamente.").replace('{pct}',pct.toFixed(1)); cls='rc-verdict-green'; ic=IC;}
        else if(pct<=40){t="Ajustado. Posible pero lo sentir\u00e1s."; su=("Vivienda al {pct}% de tus ingresos \u2014 por encima de la l\u00ednea de comodidad del 30% pero a\u00fan alcanzable. El propietario puede pedir aval o meses por adelantado.").replace('{pct}',pct.toFixed(1)); cls='rc-verdict-yellow'; ic=IW;}
        else{t="Posible, pero habla con tu agente."; su=("Vivienda al {pct}% de tus ingresos \u2014 la mayor\u00eda de propietarios rechazar\u00e1. Excepciones: aval, meses adelantados, contrato corporativo, cr\u00e9dito excelente. Habla con un agente antes de aplicar.").replace('{pct}',pct.toFixed(1)); cls='rc-verdict-red'; ic=IX;}
        v.classList.remove('rc-verdict-neutral','rc-verdict-green','rc-verdict-yellow','rc-verdict-red'); v.classList.add(cls);
        ie.innerHTML=ic; $('rc-verdict-title').textContent=t; $('rc-verdict-sub').textContent=su;
      }
      calc();
    })();
  </script>
</BaseLayout>
