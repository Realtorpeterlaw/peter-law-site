---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';

const hreflangAlternates = [
  { hreflang: 'en-CA', href: 'https://www.realtorpeterlaw.com/land-transfer-tax/' },
  { hreflang: 'zh-CN', href: 'https://www.realtorpeterlaw.com/chinese/land-transfer-tax/' },
  { hreflang: 'fr-CA', href: 'https://www.realtorpeterlaw.com/french/land-transfer-tax/' },
  { hreflang: 'x-default', href: 'https://www.realtorpeterlaw.com/land-transfer-tax/' },
];
---
<BaseLayout
  title="Land Transfer Tax in Ontario — Buyer Guide | Peter Law"
  description="What Land Transfer Tax is, how it's calculated in Ontario, the additional Toronto MLTT, and the first-time homebuyer rebate."
  bodyClass="guide-page"
  hreflangAlternates={hreflangAlternates}
>
  <TopBar />
  <Header active="buyers" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Sales resource</div>
      <h1>Land Transfer Tax in Ontario.</h1>
      <p>What it is, how it's calculated, who pays it, and how the first-time homebuyer rebate works.</p>
    </div>
  </section>

  <section class="major" style="padding-top: 32px;">
    <div class="wrap">
      <div class="prose-grid">
        <aside class="prose-side">
          <h4>On this page</h4>
          <ul>
            <li><a href="#what">What it is</a></li>
            <li><a href="#provincial">Ontario LTT brackets</a></li>
            <li><a href="#toronto">Toronto MLTT (additional)</a></li>
            <li><a href="#rebate">First-time buyer rebate</a></li>
            <li><a href="#nrst">Non-Resident Speculation Tax</a></li>
            <li><a href="#when">When you pay</a></li>
            <li><a href="#calculator">Calculator</a></li>
          </ul>
        </aside>
        <div class="prose-body">
          <h2 id="what">What Land Transfer Tax is</h2>
          <p>Land Transfer Tax (LTT) is a one-time tax paid by the buyer when a property changes hands. It's calculated as a percentage of the purchase price using a bracketed/marginal rate system, similar to income tax.</p>
          <p>If you're buying in Toronto specifically, you pay both <strong>provincial LTT</strong> (collected by the Ontario government) AND <strong>Toronto Municipal LTT (MLTT)</strong> on top — essentially double LTT.</p>

          <h2 id="provincial">Ontario LTT brackets</h2>
          <p>The provincial rates apply everywhere in Ontario:</p>
          <ul class="bullets">
            <li><strong>0.5%</strong> on the first $55,000</li>
            <li><strong>1.0%</strong> on $55,001 to $250,000</li>
            <li><strong>1.5%</strong> on $250,001 to $400,000</li>
            <li><strong>2.0%</strong> on $400,001 to $2,000,000</li>
            <li><strong>2.5%</strong> on amounts above $2,000,000 <em>(single family residences only)</em></li>
          </ul>

                    <details class="b60-section-toggle" id="toronto">
            <summary class="b60-section-toggle-summary">Toronto MLTT (additional)</summary>
            <div class="b60-section-body">
  <p>If the property is within the City of Toronto, you also pay the Municipal Land Transfer Tax. The brackets mirror the Ontario LTT brackets, plus additional luxury tiers introduced in 2024 for properties above $3 million.</p>
            <div class="callout"><strong>Practical example:</strong> Buying a $900,000 condo in downtown Toronto, your total LTT is roughly $27,950 ($13,950 provincial + $13,950 municipal), before any rebate.</div>
            </div>
          </details>

<h2 id="rebate">First-time homebuyer rebate</h2>
          <p>Both Ontario and Toronto offer rebates for first-time buyers:</p>
          <ul class="bullets">
            <li><strong>Ontario:</strong> up to <strong>$4,000</strong> off your provincial LTT</li>
            <li><strong>Toronto:</strong> up to <strong>$4,475</strong> off your municipal LTT</li>
            <li>You qualify if you're 18+, a Canadian citizen or PR, have never owned a home anywhere in the world (and neither has your spouse during your marriage), and will occupy the home as your primary residence within 9 months</li>
          </ul>

                    <details class="b60-section-toggle" id="nrst">
            <summary class="b60-section-toggle-summary">Non-Resident Speculation Tax (NRST)</summary>
            <div class="b60-section-body">
  <p>If you're not a Canadian citizen or permanent resident, an additional <strong>25%</strong> tax applies on the purchase price in Ontario. Some exemptions exist (international students, foreign nationals working in Ontario, refugees). Always consult a real estate lawyer before purchasing as a non-resident.</p>
            </div>
          </details>

<details class="b60-section-toggle" id="when">
            <summary class="b60-section-toggle-summary">When and how you pay</summary>
            <div class="b60-section-body">
  <p>LTT is paid at <strong>closing</strong>, through your real estate lawyer. It's not a separate cheque you write to the government — it's part of the closing costs the lawyer collects from you and remits to the relevant tax authorities.</p>
            <p>Plan for LTT as part of your "closing costs" along with legal fees, title insurance, and adjustments. For a Toronto purchase, total closing costs typically run 2-4% of the purchase price.</p>
            </div>
          </details>

<h2 id="calculator">Calculate your LTT</h2>
          <p>Enter your purchase price and a few details. Results update as you type.</p>
          <div class="calc">
            <div class="calc-fields">
              <div class="calc-field">
                <label for="ltt-price">Purchase price</label>
                <div class="input-prefix" data-prefix="$"><input id="ltt-price" type="number" value="900000" min="0" step="1000"></div>
              </div>
              <div class="calc-field">
                <label for="ltt-toronto">Property is in City of Toronto?</label>
                <select id="ltt-toronto">
                  <option value="yes" selected>Yes — Toronto (both LTTs apply)</option>
                  <option value="no">No — elsewhere in Ontario</option>
                </select>
              </div>
              <div class="calc-field">
                <label for="ltt-firsttime">First-time homebuyer?</label>
                <select id="ltt-firsttime">
                  <option value="no" selected>No</option>
                  <option value="yes">Yes (rebate applies)</option>
                </select>
              </div>
              <div class="calc-field">
                <label for="ltt-type">Property type</label>
                <select id="ltt-type">
                  <option value="single" selected>Single-family residence (1 or 2 units)</option>
                  <option value="other">Other (3+ units, commercial, etc.)</option>
                </select>
              </div>
            </div>
            <div class="calc-result">
              <div class="calc-result-main">
                <span class="label">Total Land Transfer Tax</span>
                <span id="ltt-total">$0</span>
              </div>
              <div class="calc-result-breakdown">
                <div class="row"><span>Ontario provincial LTT</span><strong id="ltt-ontario">$0</strong></div>
                <div class="row" id="ltt-toronto-row"><span>Toronto Municipal LTT</span><strong id="ltt-mltt">$0</strong></div>
                <div class="row" id="ltt-rebate-row" style="display:none;"><span>First-time buyer rebate</span><strong id="ltt-rebate">$0</strong></div>
              </div>
            </div>
            <p class="calc-disclaimer">For illustrative purposes only. Toronto MLTT luxury tiers (above $3M) apply only to single-family residences. NRST (25% non-resident tax) not included. Always confirm final figures with your real estate lawyer.</p>
            <dl class="calc-legend">
              <div><dt>LTT</dt><dd>Land Transfer Tax</dd></div>
              <div><dt>MLTT</dt><dd>Municipal Land Transfer Tax (Toronto)</dd></div>
              <div><dt>NRST</dt><dd>Non-Resident Speculation Tax</dd></div>
            </dl>
          </div>

          <p class="legal-note">This guide is informational, not financial or legal advice. Tax rates and rebate amounts are subject to change. Always confirm current figures with your real estate lawyer or the Ministry of Finance before closing.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection heading="Buying in Toronto?" lead="Closing costs catch a lot of first-time buyers off guard. Let's talk through your full budget before you make an offer." />
  <Footer />

  <script>
    function fmtCAD(n) {
      if (!isFinite(n) || isNaN(n) || n < 0) return '$0';
      return n.toLocaleString('en-CA', { style: 'currency', currency: 'CAD', maximumFractionDigits: 2 });
    }
    function ontarioLTT(price, isSingleFamily) {
      if (price <= 0) return 0;
      let t = 0;
      const brackets = [[55000,0.005],[250000,0.010],[400000,0.015],[2000000,0.020]];
      let lower = 0;
      for (const [upper, rate] of brackets) {
        if (price > lower) {
          const taxableInBracket = Math.min(price, upper) - lower;
          if (taxableInBracket > 0) t += taxableInBracket * rate;
        }
        lower = upper;
      }
      if (price > 2000000) t += (price - 2000000) * (isSingleFamily ? 0.025 : 0.020);
      return t;
    }
    function torontoMLTT(price, isSingleFamily) {
      if (price <= 0) return 0;
      let t = 0;
      const brackets = [[55000,0.005],[250000,0.010],[400000,0.015],[2000000,0.020]];
      let lower = 0;
      for (const [upper, rate] of brackets) {
        if (price > lower) {
          const taxableInBracket = Math.min(price, upper) - lower;
          if (taxableInBracket > 0) t += taxableInBracket * rate;
        }
        lower = upper;
      }
      if (price > 2000000) {
        if (isSingleFamily) {
          const luxury = [[3000000,0.025],[4000000,0.035],[5000000,0.045],[10000000,0.055],[20000000,0.065]];
          let lo = 2000000;
          for (const [up, rate] of luxury) {
            if (price > lo) {
              const inB = Math.min(price, up) - lo;
              if (inB > 0) t += inB * rate;
            }
            lo = up;
          }
          if (price > 20000000) t += (price - 20000000) * 0.075;
        } else {
          t += (price - 2000000) * 0.020;
        }
      }
      return t;
    }
    function update() {
      const price = parseFloat(document.getElementById('ltt-price').value) || 0;
      const inToronto = document.getElementById('ltt-toronto').value === 'yes';
      const isFirstTime = document.getElementById('ltt-firsttime').value === 'yes';
      const isSingle = document.getElementById('ltt-type').value === 'single';
      const ont = ontarioLTT(price, isSingle);
      const mltt = inToronto ? torontoMLTT(price, isSingle) : 0;
      let ontRebate = 0, mlttRebate = 0;
      if (isFirstTime) {
        ontRebate = Math.min(4000, ont);
        if (inToronto) mlttRebate = Math.min(4475, mltt);
      }
      const totalRebate = ontRebate + mlttRebate;
      const total = ont + mltt - totalRebate;
      document.getElementById('ltt-ontario').textContent = fmtCAD(ont - ontRebate) + (ontRebate > 0 ? ' (after rebate)' : '');
      document.getElementById('ltt-mltt').textContent = fmtCAD(mltt - mlttRebate) + (mlttRebate > 0 ? ' (after rebate)' : '');
      document.getElementById('ltt-total').textContent = fmtCAD(total);
      document.getElementById('ltt-toronto-row').style.display = inToronto ? 'flex' : 'none';
      document.getElementById('ltt-rebate-row').style.display = isFirstTime ? 'flex' : 'none';
      document.getElementById('ltt-rebate').textContent = '−' + fmtCAD(totalRebate);
    }
    document.querySelectorAll('#ltt-price,#ltt-toronto,#ltt-firsttime,#ltt-type').forEach(el => {
      el.addEventListener('input', update);
      el.addEventListener('change', update);
    });
    update();
  </script>
</BaseLayout>
