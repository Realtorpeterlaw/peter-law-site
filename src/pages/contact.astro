---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
---
<BaseLayout title="Contact — Peter Law · Toronto Real Estate" description="Get in touch with Peter Law. Email, phone, or book a 15-minute discovery call.">

  <TopBar />
  <Header active={null} ctaLabel="Or book a call" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Get in touch</div>
      <h1>The fastest way to a real answer.</h1>
      <p>Send a message, text, or book a call directly. I usually reply within a few hours on weekdays.</p>
    </div>
  </section>

  <section class="major" style="padding-top:32px;">
    <div class="wrap">
      <div class="contact-grid">
        <form class="contact-form" method="POST" action="/api/contact">
          <div class="form-row">
            <label for="name">Name <span class="optional">(optional)</span></label>
            <input id="name" name="name" type="text" autocomplete="name" />
          </div>
          <div class="form-row">
            <label for="email">Email <span class="required">*</span></label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="form-row">
            <label for="phone">Phone <span class="optional">(optional)</span></label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" />
          </div>
          <div class="form-row">
            <label for="message">What do you need? <span class="required">*</span></label>
            <textarea id="message" name="message" rows="6" required placeholder="Where you're looking, when you want to move, anything I should know."></textarea>
          </div>
          <!-- Honeypot: hidden from humans, bots fill it -->
          <div class="hp-field" aria-hidden="true">
            <label for="website">Website (leave blank)</label>
            <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <button type="submit" class="btn-primary">Send message
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <p class="form-trust">I'll reply from peter@realtorpeterlaw.com. Your details aren't shared with anyone.</p>
        </form>

        <aside class="contact-side">
          <h3>Other ways</h3>
          <ul class="contact-list">
            <li>
              <span class="contact-lbl">Phone / text</span>
              <a href="tel:+16478888472">647-888-8472</a>
            </li>
            <li>
              <span class="contact-lbl">Email</span>
              <a href="mailto:peter@realtorpeterlaw.com">peter@realtorpeterlaw.com</a>
            </li>
            <li>
              <span class="contact-lbl">Book a call</span>
              <a href={BOOKING_URL}>15-min intro on Cal.com</a>
            </li>
            <li>
              <span class="contact-lbl">Office</span>
              HomeLife Golconda Realty Inc.<br>215 – 3601 HWY 7 East<br>Markham, ON L3R 0M3
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
