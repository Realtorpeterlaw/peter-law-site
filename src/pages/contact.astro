---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const BOOKING_URL = "https://cal.com/peter-law-c5lm9q";
// Formspree form ID — replace xnjrzgda after creating the form at https://formspree.io/forms
const FORMSPREE_ENDPOINT = "https://formspree.io/f/xnjrzgda";
---
<BaseLayout title="Contact — Peter Law · Toronto Real Estate" description="Get in touch with Peter Law. Email, phone, or book a 15-minute discovery call.">

  <TopBar />
  <Header active="contact" ctaLabel="Or book a call" />

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow">Get in touch</div>
      <h1>The fastest way to a real answer.</h1>
      <p>Send a message, text, or book a call directly.</p>
    </div>
  </section>

  <section class="major" style="padding-top:32px;">
    <div class="wrap">
      <div class="contact-grid">
        <form class="contact-form" method="POST" action={FORMSPREE_ENDPOINT}>
          <div class="form-row">
            <label for="name">Name <span class="required">*</span></label>
            <input id="name" name="name" type="text" autocomplete="name" required />
          </div>
          <div class="form-row">
            <label for="email">Email <span class="required">*</span></label>
            <input id="email" name="email" type="email" autocomplete="email" required />
          </div>
          <div class="form-row">
            <label for="phone">Phone <span class="required">*</span></label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" required />
          </div>
          <div class="form-row">
            <label for="message">What do you need? <span class="required">*</span></label>
            <textarea id="message" name="message" rows="6" required placeholder="Where you're looking, when you want to move, anything I should know."></textarea>
          </div>
          <!-- Formspree honeypot field — bots fill this, real users don't see it -->
          <div class="hp-field" aria-hidden="true">
            <label for="_gotcha">Don't fill this out</label>
            <input id="_gotcha" name="_gotcha" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <!-- Formspree subject + redirect after submit -->
          <input type="hidden" name="_subject" value="New message from realtorpeterlaw.com" />
          <input type="hidden" name="_next" value="https://www.realtorpeterlaw.com/contact/thanks" />
          <button type="submit" class="btn-primary">Send message
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>

        </form>

        <aside class="contact-side">
          <h3>Contact me</h3>
          <ul class="contact-list">
            <li>
              <span class="contact-lbl">Phone / text</span>
              <a href="tel:+16478888472">647-888-8472</a>
            </li>
            <li>
              <span class="contact-lbl">Email</span>
              <a href="mailto:Admin@RealtorPeterLaw.com">Admin@RealtorPeterLaw.com</a>
            </li>
            <li>
              <span class="contact-lbl">Book a call</span>
              <a href={BOOKING_URL}>15-min Call</a>
            </li>
            <li>
              <span class="contact-lbl">Office</span>
              HomeLife Golconda Realty Inc.<br>215 – 3601 HWY 7 East<br>Markham, ON L3R 0M3<br><a href="tel:+19058888819">905-888-8819</a>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
